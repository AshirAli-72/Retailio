@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@rendermode RenderMode.InteractiveServer

<div class="management-container @(showForm ? "modal-active" : "")">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-package page-header-icon"></i>
                <h2 class="page-header-title">Product & Service Management</h2>
            </div>
            <button class="btn-primary" @onclick="ShowAddForm">
                <i class="ph-plus-circle"></i> Add New Item
            </button>
        </div>

        <!-- Modern Flasher Notification -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div style="position: fixed; top: 24px; right: 24px; z-index: 10000; min-width: 320px; max-width: 450px; padding: 1rem 1.25rem; border-radius: 12px; background: rgba(5, 150, 105, 0.95); backdrop-filter: blur(10px); color: white; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35), 0 2px 8px rgba(0, 0, 0, 0.1); animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1); border: 1px solid rgba(255, 255, 255, 0.2);">
                <div style="width: 32px; height: 32px; background: rgba(255, 255, 255, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="ph-check-circle" style="font-size: 1.25rem;"></i>
                </div>
                <span style="flex: 1;">@successMessage</span>
            </div>
        }
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="position: fixed; top: 24px; right: 24px; z-index: 10000; min-width: 320px; max-width: 450px; padding: 1rem 1.25rem; border-radius: 12px; background: rgba(239, 68, 68, 0.95); backdrop-filter: blur(10px); color: white; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 8px 24px rgba(239, 68, 68, 0.35), 0 2px 8px rgba(0, 0, 0, 0.1); animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1); border: 1px solid rgba(255, 255, 255, 0.2);">
                <div style="width: 32px; height: 32px; background: rgba(255, 255, 255, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="ph-warning" style="font-size: 1.25rem;"></i>
                </div>
                <span style="flex: 1;">@errorMessage</span>
            </div>
        }

        <div class="table-container">
            <div class="table-responsive">
                <table class="styled-table" style="margin-bottom: 0;">
                <thead>
                    <tr>
                        <th style="padding-left: 1.5rem;">ID</th>
                        <th>Pic</th>
                        <th>Product Name</th>
                        <th>Barcode</th>
                        <th>State</th>
                        <th>Unit</th>
                        <th>Item Type</th>
                        <th>Stock</th>
                        <th>Category</th>
                        <th>Brand</th>
                        <th>Status</th>
                        <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in productList)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem;">@item.id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.pic))
                                {
                                    <img src="/product-images/@System.IO.Path.GetFileName(item.pic)" alt="Product" style="width: 40px; height: 40px; object-fit: cover; border-radius: 8px;" />
                                }
                                else
                                {
                                    <div style="width: 40px; height: 40px; background: #f1f5f9; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #94a3b8;">
                                        <i class="ph-image" style="font-size: 1.25rem;"></i>
                                    </div>
                                }
                            </td>
                            <td class="font-medium">@item.prod_name</td>
                            <td>@(item.barcode ?? "-")</td>
                            <td>@(item.prod_state ?? "-")</td>
                            <td>@(item.unit ?? "-")</td>
                            <td>@(item.item_type ?? "-")</td>
                            <td>@(item.StockQty.ToString("N0"))</td>
                            <td class="font-sm">@GetCategoryName(item.category_id)</td>
                            <td class="font-sm">@GetBrandName(item.brand_id)</td>
                            <td>
                                <span class="status-badge @(item.status == "Enable" ? "status-enabled" : (item.status == "Disable" ? "status-discontinued" : "status-out-of-stock"))">
                                    @(item.status ?? "N/A")
                                </span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <button class="btn-icon-sm btn-edit" @onclick="() => EditProduct(item)" title="Edit">
                                        <i class="ph-pencil"></i>
                                    </button>
                                    <button class="btn-icon-sm btn-delete" @onclick="() => DeleteProduct(item.id)" title="Delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!productList.Any())
                    {
                        <tr>
                            <td colspan="12" class="empty-state">
                                <i class="ph-package empty-state-icon"></i>
                                <p>No products found. Click <strong>Add New Item</strong> to get started.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (productList.Any())
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing <b>@((currentPage - 1) * pageSize + 1)</b> to <b>@(Math.Min(currentPage * pageSize, totalCount))</b> of <b>@totalCount</b> entries
                </div>
                <div class="pagination-controls">
                    <button class="btn-pagination" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                        <i class="ph-caret-left"></i>
                    </button>
                    
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNumber = i;
                        @if (i == 1 || i == TotalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                        {
                            <button class="btn-pagination @(currentPage == pageNumber ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                                @pageNumber
                            </button>
                        }
                        else if (i == currentPage - 3 || i == currentPage + 3)
                        {
                            <span class="pagination-ellipsis">...</span>
                        }
                    }

                    <button class="btn-pagination" @onclick="NextPage" disabled="@(currentPage == TotalPages)">
                        <i class="ph-caret-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>
</div>

@if (showForm)
{
    <div class="modal-overlay">
        <div class="modal-content" style="max-width: 600px;">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    <i class="ph-package @(editingProduct == null ? "form-icon-primary" : "")"></i>
                    @(editingProduct == null ? "Add New Product" : "Edit Product")
                </div>
                <button type="button" class="form-panel-close" @onclick="HideForm"><i class="ph-x"></i></button>
            </div>

            <div class="form-panel-body" style="display: flex; flex-direction: column; gap: 1.25rem;">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; font-size: 0.9rem;">
                        <i class="ph-warning"></i> @errorMessage
                    </div>
                }

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Product Name</label>
                    <input type="text" @bind="productModel.prod_name" class="form-control" placeholder="Enter product name" required />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Barcode (Auto-generated if blank)</label>
                    <input type="text" @bind="productModel.barcode" class="form-control" placeholder="Enter or scan barcode" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Category</label>
                    <div style="display: flex; gap: 8px;">
                        <select @bind="productModel.category_id" class="form-control" style="flex: 1;">
                            <option value="">-- Select Category --</option>
                            @foreach (var cat in categoryList)
                            {
                                <option value="@cat.id">@cat.category_title</option>
                            }
                        </select>
                        <button type="button" class="btn-primary" @onclick="OpenCategoryModal" style="padding: 0.6rem 0.8rem; flex-shrink: 0;">
                            <i class="ph-plus" style="font-size: 1.2rem;"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Brand</label>
                    <div style="display: flex; gap: 8px;">
                        <select @bind="productModel.brand_id" class="form-control" style="flex: 1;">
                            <option value="">-- Select Brand --</option>
                            @foreach (var br in brandList)
                            {
                                <option value="@br.id">@br.brand_title</option>
                            }
                        </select>
                        <button type="button" class="btn-primary" @onclick="OpenBrandModal" style="padding: 0.6rem 0.8rem; flex-shrink: 0;">
                            <i class="ph-plus" style="font-size: 1.2rem;"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Item State</label>
                    <select @bind="productModel.prod_state" class="form-control">
                        <option value="pieces">pieces</option>
                        <option value="pack">pack</option>
                    </select>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Size / Capacity</label>
                    <input type="number" @bind="productModel.size" @bind:after="SyncStatus" class="form-control" placeholder="e.g. 100" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Manufacture Date</label>
                    <input type="date" value="@FormatDateForInput(productModel.manufacture_date)" @onchange="@(e => productModel.manufacture_date = FormatDateFromInput(e.Value?.ToString()))" class="form-control" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Expiry Date</label>
                    <input type="date" value="@FormatDateForInput(productModel.expiry_date)" @onchange="@(e => productModel.expiry_date = FormatDateFromInput(e.Value?.ToString()))" class="form-control" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Status</label>
                    <select @bind="productModel.status" @bind:after="SyncStatus" class="form-control">
                        <option value="Enable">Enable</option>
                        <option value="Disable">Disable</option>
                    </select>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Remarks</label>
                    <textarea class="form-control" rows="2" @bind="productModel.remarks" placeholder="Optional remarks"></textarea>
                </div>

                <hr style="margin: 0.5rem 0; border: none; border-top: 2px dashed #e2e8f0;" />

                <div class="form-panel-title" style="margin-bottom: 0.5rem;">
                    <i class="ph-stack form-icon-primary"></i> Pricing Details
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Purchase Price</label>
                    <input type="number" step="0.01" @bind="stockModel.pur_price" @bind:after="CalculateTotalPurPrice" class="form-control" placeholder="0.00" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Sale Price</label>
                    <input type="number" step="0.01" @bind="stockModel.sale_price" class="form-control" placeholder="0.00" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Wholesale Price</label>
                    <input type="number" step="0.01" @bind="stockModel.whole_sale_price" class="form-control" placeholder="0.00" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label" style="color: #BC1823; font-weight: 800;">Stock Alert Level</label>
                    <input type="number" step="1" @bind="stockModel.stock_alert" class="form-control" style="border: 1.5px solid #BC1823;" placeholder="Alert at qty..." />
                </div>

                @* Removed redundant stock date fields as requested - synced from product dates *@

                <hr style="margin: 0.5rem 0; border: none; border-top: 2px dashed #e2e8f0;" />

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Product Image</label>
                    <div style="display:flex; gap:1.5rem; align-items:flex-start; background: #fff5f6; padding:1.25rem; border-radius:12px; border:2px dashed #fecdd3;">
                        <div style="width:90px; height:90px; border-radius:8px; background: white; display:flex; align-items:center; justify-content:center; overflow:hidden; border: 3px solid white; box-shadow: 0 4px 10px rgba(188, 24, 35, 0.1);">
                            @if (!string.IsNullOrEmpty(GetImageUrl()))
                            {
                                <img src="@GetImageUrl()" style="width:100%; height:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <i class="ph-image" style="font-size:2rem; color: #fecdd3;"></i>
                            }
                        </div>
                        <div style="flex:1;">
                            <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" style="border: 1px solid #fecdd3; background: white;" />
                            <p style="font-size:.78rem; color:#475569; margin-top:.6rem; font-weight: 500;">
                                <i class="ph-info" style="color: var(--primary);"></i> PNG, JPG or JPEG. Max 5MB.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-panel-footer">
                <button type="button" class="btn-cancel" @onclick="HideForm" disabled="@isSubmitting">Cancel</button>
                <button type="button" class="btn-save" @onclick="SaveProduct" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <i class="ph-spinner ph-spin"></i> @("Saving...")
                    }
                    else
                    {
                        <i class="ph-check"></i> @(editingProduct == null ? "Save Product" : "Update Product")
                    }
                </button>
            </div>
        </div>
    </div>
}


<!-- Category Modal -->
@if (showCategoryModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="modal-content-v3">
            <div class="m-header">
                <div class="m-title">
                    <i class="ph-tag-bold" style="color: #BC1823; font-size: 1.5rem;"></i>
                    <span>Add New Category</span>
                </div>
                <button type="button" class="m-close" @onclick="CloseCategoryModal"><i class="ph-x"></i></button>
            </div>

            <div class="m-body">
                <div class="m-form-group">
                    <label>Category Title</label>
                    <input type="text" @bind="newCategoryTitle" placeholder="Enter category title" />
                </div>
                @if (!string.IsNullOrEmpty(categoryErrorMessage))
                {
                    <div style="padding: 10px; border-radius: 8px; background: #fee2e2; color: #ef4444; font-size: 0.85rem; border: 1px solid #fecaca;">
                        <i class="ph-warning"></i> @categoryErrorMessage
                    </div>
                }
            </div>

            <div class="m-footer">
                <button type="button" class="btn-c-cancel" @onclick="CloseCategoryModal">Cancel</button>
                <button type="button" class="btn-c-save" @onclick="SaveCategory">
                    <i class="ph-check-bold"></i> Save Category
                </button>
            </div>
        </div>
    </div>
}

<!-- Brand Modal -->
@if (showBrandModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="modal-content-v3">
            <div class="m-header">
                <div class="m-title">
                    <i class="ph-award-bold" style="color: #BC1823; font-size: 1.5rem;"></i>
                    <span>Add New Brand</span>
                </div>
                <button type="button" class="m-close" @onclick="CloseBrandModal"><i class="ph-x"></i></button>
            </div>

            <div class="m-body">
                <div class="m-form-group">
                    <label>Brand Title</label>
                    <input type="text" @bind="newBrandTitle" placeholder="Enter brand title" />
                </div>
                @if (!string.IsNullOrEmpty(brandErrorMessage))
                {
                    <div style="padding: 10px; border-radius: 8px; background: #fee2e2; color: #ef4444; font-size: 0.85rem; border: 1px solid #fecaca;">
                        <i class="ph-warning"></i> @brandErrorMessage
                    </div>
                }
            </div>

            <div class="m-footer">
                <button type="button" class="btn-c-cancel" @onclick="CloseBrandModal">Cancel</button>
                <button type="button" class="btn-c-save" @onclick="SaveBrand">
                    <i class="ph-check-bold"></i> Save Brand
                </button>
            </div>
        </div>
    </div>
}



@code {
    private List<ProductService> productList = new();
    private List<Category> categoryList = new();
    private List<Brand> brandList = new();
    private ProductService productModel = new();
    private StockDetail stockModel = new();
    private bool showForm = false;
    private ProductService? editingProduct = null;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;
    private IBrowserFile? selectedFile;
    private string? imgUrl;

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    // Category modal fields
    private bool showCategoryModal = false;
    private string newCategoryTitle = "";
    private string? categoryErrorMessage;

    // Brand modal fields
    private bool showBrandModal = false;
    private string newBrandTitle = "";
    private string? brandErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        using var context = DbFactory.CreateDbContext();
        totalCount = await context.products_services.CountAsync();
        
        var prodsData = await context.products_services
            .GroupJoin(
                context.stock_details.AsNoTracking(),
                p => p.barcode,
                s => s.item_barcode,
                (p, s) => new { p, stock = s.OrderByDescending(x => x.id).FirstOrDefault() }
            )
            .OrderByDescending(x => x.p.id)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
            
        productList = prodsData.Select(x => {
            x.p.StockQty = x.stock != null ? x.stock.quantity : 0;
            return x.p;
        }).ToList();
            
        categoryList = await context.categories.ToListAsync();
        brandList = await context.brands.ToListAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadProducts();
    }

    private async Task NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            await LoadProducts();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadProducts();
        }
    }

    private string GetCategoryName(int? categoryId)
    {
        if (categoryId == null) return "-";
        var cat = categoryList.FirstOrDefault(c => c.id == categoryId);
        return cat?.category_title ?? "-";
    }

    private string GetBrandName(int? brandId)
    {
        if (brandId == null) return "-";
        var br = brandList.FirstOrDefault(b => b.id == brandId);
        return br?.brand_title ?? "-";
    }

    private void ShowAddForm()
    {
        productModel = new ProductService {
            status = "Enable",
            item_type = "Inventory",
            unit = "kg",
            prod_state = "pieces",
            size = 0
        };
        stockModel = new StockDetail { stock_alert = 5 };
        editingProduct = null;
        errorMessage = null;
        selectedFile = null;
        imgUrl = null;
        showForm = true;
    }

    private async Task EditProduct(ProductService item)
    {
        editingProduct = item;
        
        // Load latest stock details
        using var context = DbFactory.CreateDbContext();
        var stock = await context.stock_details.AsNoTracking()
            .OrderByDescending(s => s.id)
            .FirstOrDefaultAsync(s => s.item_barcode == item.barcode);
            
        productModel = new ProductService
        {
            id = item.id,
            prod_name = item.prod_name,
            barcode = item.barcode,
            manufacture_date = stock?.date_of_manafacture ?? item.manufacture_date,
            expiry_date = stock?.date_of_expiry ?? item.expiry_date,
            prod_state = item.prod_state,
            unit = item.unit,
            item_type = item.item_type,
            size = (int?)(stock?.quantity ?? 0),
            pic = item.pic,
            status = item.status,
            remarks = item.remarks,
            category_id = item.category_id,
            brand_id = item.brand_id
        };

        stockModel = stock != null ? new StockDetail {
            id = stock.id,
            item_barcode = stock.item_barcode,
            quantity = stock.quantity,
            pur_price = stock.pur_price,
            sale_price = stock.sale_price,
            whole_sale_price = stock.whole_sale_price,
            stock_alert = stock.stock_alert,
            date_of_manafacture = stock.date_of_manafacture,
            date_of_expiry = stock.date_of_expiry,
            total_pur_price = stock.total_pur_price
        } : new StockDetail { item_barcode = item.barcode };

        CalculateTotalPurPrice();

        errorMessage = null;
        selectedFile = null;
        imgUrl = null;
        showForm = true;
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            selectedFile = e.File;
            errorMessage = null;
            if (selectedFile.Size > 5120000)
            {
                errorMessage = "Select an image less than 5MB.";
                selectedFile = null;
                imgUrl = null;
                return;
            }
            using var stream = selectedFile.OpenReadStream(5120000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            imgUrl = $"data:{selectedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Image preview error: " + ex.Message;
        }
    }

    private string GetImageUrl()
    {
        if (!string.IsNullOrEmpty(imgUrl)) return imgUrl;
        if (!string.IsNullOrEmpty(productModel.pic))
        {
            try { return "/product-images/" + Path.GetFileName(productModel.pic); }
            catch { return "/product-images/" + productModel.pic; }
        }
        return "";
    }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(productModel.prod_name)) { errorMessage = "Product name is required."; return; }

        isSubmitting = true;
        try
        {
            if (selectedFile != null)
            {
                string storagePath = @"D:\netcore\E-Invoice_system\bin\Debug\images";
                if (!Directory.Exists(storagePath)) Directory.CreateDirectory(storagePath);
                string fileName = Guid.NewGuid().ToString() + Path.GetExtension(selectedFile.Name);
                string path = Path.Combine(storagePath, fileName);

                if (!string.IsNullOrEmpty(productModel.pic) && productModel.pic != path)
                    if (File.Exists(productModel.pic)) try { File.Delete(productModel.pic); } catch {}

                await using var stream = selectedFile.OpenReadStream(5120000);
                await using var fs = new FileStream(path, FileMode.Create);
                await stream.CopyToAsync(fs);
                productModel.pic = path;
            }

            if (string.IsNullOrWhiteSpace(productModel.barcode)) productModel.barcode = await GenerateUniqueBarcode();

            // Final sync before save
            stockModel.quantity = productModel.size ?? 0;
            stockModel.date_of_manafacture = productModel.manufacture_date;
            stockModel.date_of_expiry = productModel.expiry_date;
            CalculateTotalPurPrice();

            using var context = DbFactory.CreateDbContext();
            // Identfiy current state for history before saving
            var oldStock = await context.stock_details.AsNoTracking()
                .OrderByDescending(s => s.id)
                .FirstOrDefaultAsync(s => s.item_barcode == productModel.barcode);
                
            decimal oldQty = oldStock?.quantity ?? 0;
            decimal oldPur = oldStock?.pur_price ?? 0;
            decimal oldSale = oldStock?.sale_price ?? 0;

            bool isPriceChanged = oldStock != null && (oldStock.pur_price != stockModel.pur_price || oldStock.sale_price != stockModel.sale_price);

            if (editingProduct == null)
            {
                context.products_services.Add(productModel);
                await context.SaveChangesAsync();
            }
            // Note: Per user request, we do NOT update products_services during Edit anymore
            
            // Save/Update stock details
            stockModel.item_barcode = productModel.barcode;
            if (oldStock == null || isPriceChanged)
            {
                // Create new record for price change or new product
                context.stock_details.Add(new StockDetail {
                    item_barcode = productModel.barcode,
                    quantity = stockModel.quantity,
                    pur_price = stockModel.pur_price,
                    sale_price = stockModel.sale_price,
                    whole_sale_price = stockModel.whole_sale_price,
                    stock_alert = stockModel.stock_alert,
                    date_of_manafacture = stockModel.date_of_manafacture,
                    date_of_expiry = stockModel.date_of_expiry,
                    total_pur_price = stockModel.total_pur_price
                });
            }
            else
            {
                // Just update the existing record if only quantity/alert changed
                var existing = await context.stock_details.FirstOrDefaultAsync(s => s.id == oldStock.id);
                if (existing != null)
                {
                    existing.quantity = stockModel.quantity;
                    existing.stock_alert = stockModel.stock_alert;
                    existing.date_of_manafacture = stockModel.date_of_manafacture;
                    existing.date_of_expiry = stockModel.date_of_expiry;
                    existing.total_pur_price = stockModel.total_pur_price;
                    context.stock_details.Update(existing);
                }
            }

            // Log Stock History
            var history = new StockHistory
            {
                date = DateTime.Now.ToString("yyyy-MM-dd"),
                old_quantity = oldQty,
                new_quantity = stockModel.quantity,
                old_purchase_price = oldPur,
                new_purchase_price = stockModel.pur_price,
                old_sale_price = oldSale,
                new_sale_price = stockModel.sale_price,
                remarks = editingProduct == null ? "CREATE" : "EDIT",
                product_id = productModel.id
            };
            context.stock_histories.Add(history);
            
            await context.SaveChangesAsync();

            await JSRuntime.InvokeVoidAsync("clearNavCache");
            await LoadProducts();
            HideForm();
            successMessage = editingProduct == null ? "Product created successfully!" : "Product updated successfully!";
            errorMessage = null;
            _ = Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { successMessage = null; StateHasChanged(); }));
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving product: " + ex.Message;
            successMessage = null;
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string> GenerateUniqueBarcode()
    {
        using var context = DbFactory.CreateDbContext();
        var barcodes = await context.products_services.AsNoTracking()
            .Where(p => p.barcode != null && p.barcode.StartsWith("P"))
            .Select(p => p.barcode).ToListAsync();

        long maxId = 0;
        foreach (var code in barcodes)
            if (code!.Length > 1 && long.TryParse(code.Substring(1), out long currentId) && currentId > maxId) maxId = currentId;

        return $"P{(maxId + 1):D10}";
    }

    private async Task DeleteProduct(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var prod = await context.products_services.FindAsync(id);
        if (prod != null)
        {
            var stock = await context.stock_details.FirstOrDefaultAsync(s => s.item_barcode == prod.barcode);
            if (stock != null) context.stock_details.Remove(stock);

            context.products_services.Remove(prod);
            await context.SaveChangesAsync();
            await LoadProducts();
        }
    }

    // Category Modal Methods
    private void OpenCategoryModal()
    {
        newCategoryTitle = "";
        categoryErrorMessage = null;
        showCategoryModal = true;
    }

    private void CloseCategoryModal()
    {
        showCategoryModal = false;
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategoryTitle))
        {
            categoryErrorMessage = "Category title is required.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var category = new Category { category_title = newCategoryTitle };
        context.categories.Add(category);
        await context.SaveChangesAsync();
        categoryList = await context.categories.ToListAsync();
        productModel.category_id = category.id;
        CloseCategoryModal();
        StateHasChanged();
    }

    // Brand Modal Methods
    private void OpenBrandModal()
    {
        newBrandTitle = "";
        brandErrorMessage = null;
        showBrandModal = true;
    }

    private void CloseBrandModal()
    {
        showBrandModal = false;
    }

    private async Task SaveBrand()
    {
        if (string.IsNullOrWhiteSpace(newBrandTitle))
        {
            brandErrorMessage = "Brand title is required.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var brand = new Brand { brand_title = newBrandTitle };
        context.brands.Add(brand);
        await context.SaveChangesAsync();
        brandList = await context.brands.ToListAsync();
        productModel.brand_id = brand.id;
        CloseBrandModal();
        StateHasChanged();
    }

    private void SyncStatus()
    {
        if (productModel.size == 0)
        {
            productModel.status = "Disable";
        }
        else if (productModel.size > 0)
        {
            productModel.status = "Enable";
        }
        
        // Sync Quantity with Size
        stockModel.quantity = productModel.size ?? 0;
        CalculateTotalPurPrice();
        
        StateHasChanged();
    }

    private void CalculateTotalPurPrice()
    {
        stockModel.total_pur_price = stockModel.quantity * stockModel.pur_price;
        StateHasChanged();
    }
    private string? FormatDateForInput(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return null;
        if (DateTime.TryParse(dateStr, out var dt)) return dt.ToString("yyyy-MM-dd");
        return null;
    }

    private string? FormatDateFromInput(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return null;
        if (DateTime.TryParse(dateStr, out var dt)) return dt.ToString("yyyy-MM-dd");
        return dateStr;
    }
