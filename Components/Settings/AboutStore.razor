@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject Microsoft.Extensions.Caching.Memory.IMemoryCache Cache
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer

<link href="/css/settings/store_config.css" rel="stylesheet" />
<link href="/css/settings/about.css" rel="stylesheet" />
<link href="/css/settings/index.css" rel="stylesheet" />

<div class="management-container">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-storefront page-header-icon"></i>
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                    <h2 class="page-header-title">Store Configuration</h2>
                    <p class="text-muted font-sm" style="margin: 0;">Configure your store information for invoices and receipts</p>
                </div>
            </div>
            <div class="page-header-actions">
                <a href="/settings" class="btn-secondary">
                    <i class="ph-arrow-left"></i> Back to Settings
                </a>
            </div>
        </div>



        <div style="padding: 2rem;">
            <div class="about-grid-2">
                <!-- Left Side: Form Fields -->
                <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <!-- Section 1: Basic Information -->
                    <div class="about-section-card">
                        <h3 class="about-section-title">
                            <i class="ph-storefront" style="color: var(--primary); font-size: 1.25rem;"></i>
                            Basic Information
                        </h3>
                        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                            <div class="form-group">
                                <label class="form-label">Shop Name</label>
                                <input type="text" class="form-control" @bind="storeConfig.ShopName" placeholder="Enter your shop name" />
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
                                <div class="form-group">
                                    <label class="form-label">Owner Name</label>
                                    <input type="text" class="form-control" @bind="storeConfig.OwnerName" placeholder="Owner full name" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">City</label>
                                    <input type="text" class="form-control" @bind="storeConfig.City" placeholder="City name" />
                                </div>
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
                                <div class="form-group">
                                    <label class="form-label">Branch</label>
                                    <input type="text" class="form-control" @bind="storeConfig.Branch" placeholder="Branch name" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Shop No</label>
                                    <input type="text" class="form-control" @bind="storeConfig.ShopNo" placeholder="Shop number" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Contact & Details -->
                    <div class="about-section-card">
                        <h3 class="about-section-title">
                            <i class="ph-phone" style="color: var(--primary); font-size: 1.25rem;"></i>
                            Contact & Business Details
                        </h3>
                        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                            <div class="form-group">
                                <label class="form-label">Address</label>
                                <textarea class="form-control" @bind="storeConfig.Address" placeholder="Enter complete address" rows="2"></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Business Nature</label>
                                <input type="text" class="form-control" @bind="storeConfig.BusinessNature" placeholder="e.g., Retail, Wholesale, Services" />
                            </div>

                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
                                <div class="form-group">
                                    <label class="form-label">Phone 1</label>
                                    <input type="tel" class="form-control" @bind="storeConfig.Phone1" placeholder="Primary phone number" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Phone 2</label>
                                    <input type="tel" class="form-control" @bind="storeConfig.Phone2" placeholder="Secondary phone number" />
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Comments / Remarks</label>
                                <textarea class="form-control" @bind="storeConfig.Comments" placeholder="Additional comments or notes (optional)" rows="3"></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Side: Logo Upload -->
                <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                    <div class="about-logo-upload-box">
                        <h3 class="about-section-title" style="justify-content: center;">
                            <i class="ph-image" style="color: var(--primary); font-size: 1.25rem;"></i>
                            Store Logo
                        </h3>
                        <p style="margin: 0.5rem 0 0 0; font-size: 0.85rem; color: var(--text-muted);">Your logo appears on invoices and receipts</p>
                            
                            <!-- Logo Preview Area -->
                            <div style="width: 100%; height: 220px; margin-bottom: 1.25rem; background: var(--bg-light); border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 2px dashed var(--border); transition: all 0.3s;">
                                @if (!string.IsNullOrEmpty(storeConfig.LogoPath))
                                {
                                    <img src="@GetLogoUrl()" style="max-width: 100%; max-height: 100%; object-fit: contain; padding: 1rem;" alt="Store Logo" />
                                }
                                else
                                {
                                    <div style="text-align: center;">
                                        <i class="ph-storefront" style="font-size: 3.5rem; color: var(--border); display: block; margin-bottom: 0.75rem;"></i>
                                        <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0; font-weight: 600;">No Logo Uploaded</p>
                                        <p style="font-size: 0.8rem; color: var(--border); margin: 0.25rem 0 0 0;">Upload your store logo</p>
                                    </div>
                                }
                            </div>
                            
                            <!-- Upload Button -->
                            <label class="btn-primary" style="margin: 0; cursor: pointer; justify-content: center; width: 100%; margin-bottom: 0.75rem; padding: 0.85rem 1.5rem; font-size: 0.95rem;">
                                <i class="ph-upload-simple" style="font-size: 1.1rem;"></i> 
                                <span>Upload Logo</span>
                                <InputFile OnChange="HandleLogoUpload" class="hidden-input" accept="image/*" style="display:none;" />
                            </label>
                            
                            <!-- Remove Button -->
                            @if (!string.IsNullOrEmpty(storeConfig.LogoPath))
                            {
                                <button type="button" @onclick="RemoveLogo" style="width: 100%; padding: 0.75rem 1.5rem; background: #fee2e2; color: #ef4444; border: 2px solid #fecaca; border-radius: 10px; font-weight: 600; cursor: pointer; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; font-size: 0.9rem;">
                                    <i class="ph-trash"></i> Remove Logo
                                </button>
                            }
                            
                            <div style="margin-top: 1.25rem; padding: 0.75rem; background: var(--bg-light); border-radius: 8px; border: 1px solid var(--border);">
                                <p style="margin: 0; font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem;">
                                    <i class="ph-info" style="color: var(--primary);"></i> 
                                    <strong>Accepted:</strong> PNG, JPG, JPEG
                                </p>
                                <p style="margin: 0.4rem 0 0 0; font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem;">
                                    <i class="ph-info" style="color: var(--primary);"></i> 
                                    <strong>Max Size:</strong> 2MB
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Save Configuration Button at the End -->
            <div style="margin-top: 2rem; padding: 1.5rem 0 0.5rem 0; border-top: 2px solid var(--border); display: flex; justify-content: flex-end; gap: 1rem; flex-wrap: wrap;">
                <a href="/settings" class="btn-secondary" style="flex: 0 1 auto;">
                    <i class="ph-x"></i> Cancel
                </a>
                <button type="button" class="btn-primary" @onclick="SaveConfiguration" disabled="@isSaving" style="flex: 0 1 auto;">
                    @if (isSaving)
                    {
                        <i class="ph-spinner ph-spin"></i> <span>Saving...</span>
                    }
                    else
                    {
                        <i class="ph-floppy-disk"></i> <span>Save Configuration</span>
                    }
                </button>
            </div>
        </div>
    </div>


@code {
    private StoreConfiguration storeConfig = new();
    private bool isSaving = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguration();
    }

    private async Task LoadConfiguration()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            var config = await context.store_configurations.FirstOrDefaultAsync();
            if (config != null)
            {
                // Create a new instance and copy values to avoid tracking issues
                storeConfig = new StoreConfiguration
                {
                    Id = config.Id,
                    ShopName = config.ShopName,
                    OwnerName = config.OwnerName,
                    City = config.City,
                    Address = config.Address,
                    BusinessNature = config.BusinessNature,
                    Branch = config.Branch,
                    ShopNo = config.ShopNo,
                    Phone1 = config.Phone1,
                    Phone2 = config.Phone2,
                    LogoPath = config.LogoPath,
                    Comments = config.Comments
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading configuration: " + ex.Message;
        }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            var logoFolderPath = Path.Combine(Environment.ContentRootPath, "bin", "Debug", "Logo");
            if (!Directory.Exists(logoFolderPath)) Directory.CreateDirectory(logoFolderPath);

            var fileName = $"logo_{Guid.NewGuid().ToString().Substring(0, 8)}{Path.GetExtension(file.Name)}";
            var logoFilePath = Path.Combine(logoFolderPath, fileName);

            // Read file into memory first
            await using var stream = file.OpenReadStream(2 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            var fileBytes = memoryStream.ToArray();
            
            // Save to bin\Debug\Logo
            await File.WriteAllBytesAsync(logoFilePath, fileBytes);

            // Store the absolute path in database as requested
            storeConfig.LogoPath = logoFilePath;
            errorMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = "Logo upload failed: " + ex.Message;
            StateHasChanged();
        }
    }

    private void RemoveLogo()
    {
        // Delete from bin\Debug\Logo
        if (!string.IsNullOrEmpty(storeConfig.LogoPath))
        {
            try
            {
                // Try deleting if it exists
                if (File.Exists(storeConfig.LogoPath))
                {
                    File.Delete(storeConfig.LogoPath);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting old logo: {ex.Message}");
            }
        }
        
        storeConfig.LogoPath = null;
        Cache.Remove("Layout_Logo");
        Cache.Remove("StoreLogo");
    }

    private string GetLogoUrl()
    {
        if (string.IsNullOrEmpty(storeConfig.LogoPath)) return "";
        
        // Extract filename from the full path and serve via /store-logo
        string fileName = Path.GetFileName(storeConfig.LogoPath);
        return $"/store-logo/{fileName}";
    }

    private async Task SaveConfiguration()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            using var context = DbFactory.CreateDbContext();
            
            var existing = await context.store_configurations.FirstOrDefaultAsync();
            if (existing != null)
            {
                // Update existing - manually set each property (NOT Id)
                existing.ShopName = storeConfig.ShopName;
                existing.OwnerName = storeConfig.OwnerName;
                existing.City = storeConfig.City;
                existing.Branch = storeConfig.Branch;
                existing.Address = storeConfig.Address;
                existing.ShopNo = storeConfig.ShopNo;
                existing.BusinessNature = storeConfig.BusinessNature;
                existing.Phone1 = storeConfig.Phone1;
                existing.Phone2 = storeConfig.Phone2;
                existing.LogoPath = storeConfig.LogoPath;
                existing.Comments = storeConfig.Comments;
                
                // Mark as modified to ensure EF Core tracks the changes
                context.Entry(existing).State = Microsoft.EntityFrameworkCore.EntityState.Modified;
            }
            else
            {
                // Create new
                var newConfig = new StoreConfiguration
                {
                    ShopName = storeConfig.ShopName,
                    OwnerName = storeConfig.OwnerName,
                    City = storeConfig.City,
                    Branch = storeConfig.Branch,
                    Address = storeConfig.Address,
                    ShopNo = storeConfig.ShopNo,
                    BusinessNature = storeConfig.BusinessNature,
                    Phone1 = storeConfig.Phone1,
                    Phone2 = storeConfig.Phone2,
                    LogoPath = storeConfig.LogoPath,
                    Comments = storeConfig.Comments
                };
                context.store_configurations.Add(newConfig);
            }

            await context.SaveChangesAsync();
            await JS.InvokeVoidAsync("showToast", "Success", "Store configuration saved successfully!", "success");
            
            // Reload to ensure we have the latest data
            await LoadConfiguration();
            
            Cache.Remove("Layout_Logo");
            Cache.Remove("StoreLogo");
        }
        catch (Exception ex)
        {
            errorMessage = "Save failed: " + ex.Message;
            await JS.InvokeVoidAsync("showToast", "Error", errorMessage, "error");
        }
        finally
        {
            isSaving = false;
        }
    }
}
