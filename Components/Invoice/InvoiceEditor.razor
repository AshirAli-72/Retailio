@namespace E_Invoice_system.Components.Invoice
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<div class="form-panel-body">
    <!-- Modern Flasher Notification -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div style="position: fixed; top: 24px; right: 24px; z-index: 10000; min-width: 320px; max-width: 450px; padding: 1rem 1.25rem; border-radius: 12px; background: rgba(5, 150, 105, 0.95); backdrop-filter: blur(10px); color: white; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 8px 24px rgba(5, 150, 105, 0.35), 0 2px 8px rgba(0, 0, 0, 0.1); animation: slideInRight 0.4s cubic-bezier(0.16, 1, 0.3, 1); border: 1px solid rgba(255, 255, 255, 0.2);">
            <div style="width: 32px; height: 32px; background: rgba(255, 255, 255, 0.2); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <i class="ph-check-circle" style="font-size: 1.25rem;"></i>
            </div>
            <span style="flex: 1;">@successMessage</span>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.25rem;">
            <i class="ph-warning" style="font-size: 1.1rem;"></i> @errorMessage
        </div>
    }

    <!-- Invoice Header Details -->
    <div class="form-group">
        <label class="form-label">Invoice Date</label>
        <input class="form-control" type="date" value="@invoiceDate" @onchange="@(e => invoiceDate = e.Value?.ToString() ?? DateTime.Now.ToString("yyyy-MM-dd"))" />
    </div>

    <div class="form-group">
        <label class="form-label">Seller Company Name</label>
        <input class="form-control" @bind="companyName" placeholder="Enter store name" />
    </div>

    <div class="form-group">
        <label class="form-label">Seller Phone</label>
        <input class="form-control" @bind="companyPhone" placeholder="Enter store phone" />
    </div>

    <div class="form-group">
        <label class="form-label">Select Customer</label>
        <select class="form-control" @onchange="OnCustomerChanged">
            <option value="">-- Choose Customer --</option>
            @foreach (var c in customersList)
            {
                <option value="@c.id" selected="@(selectedCustomer?.id == c.id)">@c.name</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">Invoice Number</label>
        <input class="form-control" @bind="invoiceNo" placeholder="Auto-generated if blank" />
    </div>

    <hr style="margin: 0.5rem 0; border: none; border-top: 2px dashed #e2e8f0;" />

    <div class="form-panel-title" style="margin-bottom: 1rem;">
        <i class="ph-shopping-cart form-icon-primary"></i>
        Line Items
    </div>

    <!-- Add Item Form -->
    <div style="background: var(--bg-light); padding: 1.25rem; border-radius: 12px; border: 1px solid var(--border); margin-bottom: 1.25rem;">
        <div class="form-group" style="margin-bottom: 0;">
            <label class="form-label">Add Product / Service</label>
            <div style="display: flex; gap: 0.75rem;">
                <select id="productSelect" class="form-control" @onchange="OnProductSelected" style="flex:1;">
                    <option value="0">-- Select Product --</option>
                    @foreach (var p in productsList)
                    {
                        <option value="@p.id" selected="@(selectedProductId == p.id)">@p.prod_name (@(p.item_type ?? "N/A"))</option>
                    }
                </select>
                <button type="button" class="btn-primary" @onclick="AddItem" style="flex-shrink: 0;">
                    <i class="ph-plus"></i> Add
                </button>
            </div>
        </div>
    </div>

    <!-- Items Table -->
    <div class="table-responsive" style="border: 1px solid var(--border); border-radius: 12px; max-height: 300px; overflow-y: auto; margin-bottom: 1.25rem;">
        <table class="styled-table" style="margin: 0; box-shadow: none;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem;">Product/Service</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Total</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (invoiceItems.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="empty-state" style="padding: 2.5rem;">
                            <i class="ph-shopping-cart empty-state-icon"></i>
                            <p>No items added yet. Select a product above to get started.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in invoiceItems)
                    {
                        <tr>
                            <td style="padding-left: 1.5rem;">
                                <div class="font-medium">@item.Name</div>
                                <div class="font-sm text-muted">Exp: @(item.ExpiryDate ?? "N/A")</div>
                            </td>
                            <td>
                                <input type="number" @bind="item.Qty" @bind:after="() => CalculateItemTotal(item)" class="form-control" style="width: 80px; height: 36px; padding: 0.35rem 0.6rem;" />
                            </td>
                            <td>
                                <input type="number" step="0.01" @bind="item.Price" @bind:after="() => CalculateItemTotal(item)" class="form-control" style="width: 100px; height: 36px; padding: 0.35rem 0.6rem;" />
                            </td>
                            <td class="font-bold" style="color: var(--primary);">
                                @CurrencyService.GetSymbol()@item.Total.ToString("F2")
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <button type="button" @onclick="() => RemoveItem(item)" class="btn-icon-sm btn-delete">
                                    <i class="ph-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <!-- Summary Section -->
    <div style="background: var(--bg-light); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border);">
        <div class="form-group">
            <label class="form-label">Invoice Status</label>
            <select class="form-control" @bind="status">
                <option value="Paid">Paid</option>
                <option value="Pending">Pending</option>
                <option value="Cancelled">Cancelled</option>
            </select>
        </div>
        
        <div class="form-group">
            <label class="form-label">Payment Method</label>
            <select class="form-control" @bind="paymentMethod">
                <option value="Cash">Cash</option>
                <option value="Bank Transfer">Bank Transfer</option>
                <option value="Online">Online</option>
                <option value="Credit">Credit</option>
            </select>
        </div>

        <div style="padding-top: 1rem; border-top: 1px solid var(--border); margin-top: 0.5rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                <span class="text-muted font-medium">Subtotal:</span>
                <span class="font-bold">@CurrencyService.GetSymbol()@subtotal.ToString("F2")</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem; align-items: center;">
                <span class="text-muted font-medium">Discount:</span>
                <input type="number" step="0.01" @bind="discount" class="form-control" style="width: 120px; text-align: right; height: 38px;" />
            </div>
            <hr style="margin: 1rem 0; border: none; border-top: 2px solid var(--border);" />
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <span class="font-bold" style="font-size: 1.15rem; color: var(--text);">Total Amount:</span>
                <span class="font-bold" style="font-size: 1.35rem; color: var(--primary);">@CurrencyService.GetSymbol()@total.ToString("F2")</span>
            </div>
        </div>
    </div>
</div>

<div class="form-panel-footer">
    <button type="button" class="btn-save" style="width: 100%; justify-content: center;" @onclick="SubmitInvoice" disabled="@isSubmitting">
        @if (isSubmitting)
        {
            <i class="ph-spinner ph-spin"></i> @("Generating Invoice...")
        }
        else
        {
            <i class="ph-check-circle"></i> @("Generate & Save Invoice")
        }
    </button>
</div>


@code {
    private List<customers> customersList = new();
    private List<ProductService> productsList = new();
    private List<InvoiceItem> invoiceItems = new();

    private customers? selectedCustomer;
    private string? invoiceNo;
    private string invoiceDate = DateTime.Now.ToString("yyyy-MM-dd");
    private string status = "Paid";
    private string paymentMethod = "Cash";
    private decimal discount = 0;
    private int selectedProductId;
    private string? companyName;
    private string? companyPhone;
    private bool isSubmitting = false;
    private string? errorMessage;
    private string? successMessage;

    [Parameter] public string? UserName { get; set; }



    protected override async Task OnInitializedAsync()
    {
        await CurrencyService.GetSymbolAsync();
        using var context = DbFactory.CreateDbContext();
        customersList = await context.customers.OrderBy(c => c.name).ToListAsync();
        
        // Use a more resilient way to fetch Available products (handling potential status padding in DB)
        var allProducts = await context.products_services.ToListAsync();
        productsList = allProducts.Where(p => !string.IsNullOrEmpty(p.status) && p.status.Trim().Equals("Enable", StringComparison.OrdinalIgnoreCase)).ToList();

        // Load store configuration for defaults
        var storeConfig = await context.store_configurations.FirstOrDefaultAsync();
        if (storeConfig != null)
        {
            companyName = storeConfig.ShopName;
            companyPhone = storeConfig.Phone1;
        }
    }

    private void OnCustomerChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedCustomer = customersList.FirstOrDefault(c => c.id == id);
        }
        else
        {
            selectedCustomer = null;
        }
        StateHasChanged();
    }

    private void OnProductSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedProductId = id;
        }
        else
        {
            selectedProductId = 0;
        }
        StateHasChanged();
    }

    private async Task AddItem()
    {
        if (selectedProductId == 0) 
        {
            errorMessage = "Please select a product from the list first.";
            return;
        }

        var product = productsList.FirstOrDefault(p => p.id == selectedProductId);
        if (product != null)
        {
            invoiceItems.Add(new InvoiceItem
            {
                Name = product.prod_name,
                Qty = 1,
                Price = 0,
                ExpiryDate = product.expiry_date,
                Total = 0
            });
            errorMessage = null; 
            selectedProductId = 0; // Reset after success
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            errorMessage = "Selected product not found or no longer available.";
        }
    }

    private void RemoveItem(InvoiceItem item)
    {
        invoiceItems.Remove(item);
    }

    private void CalculateItemTotal(InvoiceItem item)
    {
        item.Total = item.Qty * item.Price;
    }

    private decimal subtotal => invoiceItems.Sum(i => i.Total);
    private decimal total => subtotal - discount;

    private async Task SubmitInvoice()
    {
        if (selectedCustomer == null) { errorMessage = "Please select a customer."; return; }
        if (invoiceItems.Count == 0) { errorMessage = "Please add at least one item."; return; }

        isSubmitting = true;
        try
        {
            using var context = DbFactory.CreateDbContext();

            // Get Current User ID
            var user = await context.users.AsNoTracking().FirstOrDefaultAsync(u => u.username == UserName);
            int? currentUserId = user?.id;

            // Get store configuration for seller info
            var storeConfig = await context.store_configurations.FirstOrDefaultAsync();

            var invoice = new invoices
            {
                invoice_no = string.IsNullOrWhiteSpace(invoiceNo) ? $"INV-{DateTime.Now.ToString("ddMMyyHHmm")}" : (invoiceNo.Length > 50 ? invoiceNo.Substring(0, 50) : invoiceNo),
                date = DateTime.TryParse(invoiceDate, out var dt) ? dt.ToString("yyyy-MM-dd") : DateTime.Now.ToString("yyyy-MM-dd"),
                seller_name = companyName?.Length > 100 ? companyName.Substring(0, 100) : companyName,
                seller_contact = companyPhone?.Length > 50 ? companyPhone.Substring(0, 50) : companyPhone,
                seller_address = storeConfig?.Address?.Length > 255 ? storeConfig.Address.Substring(0, 255) : storeConfig?.Address,
                customer_name = selectedCustomer.name?.Length > 100 ? selectedCustomer.name.Substring(0, 100) : selectedCustomer.name,
                customer_contact = selectedCustomer.contact?.Length > 50 ? selectedCustomer.contact.Substring(0, 50) : selectedCustomer.contact,
                customer_address = selectedCustomer.address?.Length > 255 ? selectedCustomer.address.Substring(0, 255) : selectedCustomer.address,
                prod_name_service = System.Text.Json.JsonSerializer.Serialize(invoiceItems, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }),
                qty_unit_type = $"{invoiceItems.Count} Items",
                price = subtotal,
                discount = discount,
                total_price = total,
                payment = paymentMethod,
                status = status
            };

            context.invoices.Add(invoice);
            await context.SaveChangesAsync();

            successMessage = "Invoice created successfully!";
            await Task.Delay(500);
            // Standard Blazor Navigation
            NavigationManager.NavigateTo("/Invoice/Index", true);
        }
        catch (Exception ex)
        {
            string err = ex.Message;
            if (ex.InnerException != null) err += " | " + ex.InnerException.Message;
            errorMessage = "Error saving invoice: " + err;
            successMessage = null;
            isSubmitting = false;
        }
    }

    public class InvoiceItem

    {
        public string? Name { get; set; }
        public decimal Qty { get; set; }
        public decimal Price { get; set; }
        public string? ExpiryDate { get; set; }
        public decimal Total { get; set; }
    }
}
