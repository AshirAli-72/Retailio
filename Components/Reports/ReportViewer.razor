@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<div class="reports-container">
    <!-- Clean Header -->
    <div class="page-header" style="margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <i class="ph-file-text" style="font-size: 1.75rem; color: var(--primary);"></i>
            <h2 class="page-header-title" style="margin: 0; font-size: 1.5rem; font-weight: 800;">Detailed Reports</h2>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <button @onclick="() => showReportSelector = true" class="btn-primary" style="padding: 0.6rem 1.5rem; border-radius: 8px;">
                <i class="ph-file-search"></i>
                <span>Report Menu</span>
            </button>
            @if (reports != null && reports.Any())
            {
                <button @onclick="ResetFilters" class="btn-secondary" style="padding: 0.6rem 1.5rem; border-radius: 8px;">
                    <i class="ph-arrow-counter-clockwise"></i>
                    <span>Reset</span>
                </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <div style="padding: 10rem; text-align: center;">
            <i class="ph-spinner ph-spin" style="font-size: 3rem; color: var(--primary);"></i>
            <p style="margin-top: 1rem; font-weight: 600; color: var(--text-muted);">Generating your reports...</p>
        </div>
    }
    else if (reportGenerated && reports != null && reports.Any())
    {
        <div class="reports-stack" style="display: flex; flex-direction: column; gap: 2rem;">
            @foreach (var report in reports)
            {
                <div class="report-results" style="background: var(--card-bg); padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border); box-shadow: var(--shadow); animation: fadeIn 0.3s ease;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; border-bottom: 2px solid var(--border); padding-bottom: 1rem;">
                        <h3 style="margin: 0; font-size: 1.25rem; font-weight: 800; color: var(--text);">
                            @report.Title
                            <span style="font-size: 0.875rem; color: var(--text-muted); margin-left: 1rem; font-weight: 500;">
                                (@report.Data?.Count records found)
                            </span>
                        </h3>
                        <div style="display: flex; gap: 0.75rem;" class="no-print">
                            <button @onclick="() => PrintReport(report.Id)" class="btn-icon" title="Print"><i class="ph-printer"></i></button>
                            <button @onclick="() => ExportToCSV(report.Id)" class="btn-icon" title="Export CSV"><i class="ph-file-xls"></i></button>
                        </div>
                    </div>

                    @if (report.Data != null && report.Data.Any())
                    {
                        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                            <table id="@report.Id" class="styled-table" style="width: 100%;">
                                <thead style="position: sticky; top: 0; z-index: 10;">
                                    <tr>
                                        @foreach (var col in report.Data.First().Keys)
                                        {
                                            <th>@col</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in report.Data)
                                    {
                                        <tr>
                                            @foreach (var val in row.Values)
                                            {
                                                <td>@val</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div style="margin-top: 1rem; padding: 1rem; background: var(--bg-light); border-radius: 8px; font-size: 0.85rem; font-weight: 600; color: var(--text-muted); display: flex; justify-content: space-between; border: 1px solid var(--border);">
                            <span>Total Records: @report.Data.Count</span>
                            <span>Period: @fromDate?.ToString("dd-MM-yyyy") - @toDate?.ToString("dd-MM-yyyy")</span>
                        </div>
                    }
                    else
                    {
                        <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
                            <p style="font-weight: 600;">No data available for this report type in the selected range.</p>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else if (!isLoading)
    {
        <div style="padding: 8rem; text-align: center; background: var(--card-bg); border-radius: 12px; border: 2px dashed var(--border); cursor: pointer;" @onclick="() => showReportSelector = true">
            <i class="ph-chart-bar-horizontal" style="font-size: 5rem; color: var(--border); display: block; margin-bottom: 1.5rem;"></i>
            <h3 style="color: var(--text-muted); margin-bottom: 0.5rem; font-weight: 800;">Report Builder</h3>
            <p style="color: var(--text-muted); margin: 0; opacity: 0.8;">Click "Configure Report" to select which data you want to analyze.</p>
        </div>
    }
</div>

<!-- Report Selection Modal -->
@if (showReportSelector)
{
    <div class="modal-overlay" style="display: flex; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 9999;">
        <div class="modal-content" style="background: var(--card-bg); border-radius: 16px; width: 95%; max-width: 550px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); animation: slideUp 0.3s ease;">
            <div class="modal-header" style="padding: 1.5rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: var(--bg-light);">
                <h3 style="margin: 0; font-size: 1.25rem; font-weight: 800; display: flex; align-items: center; gap: 0.75rem;">
                    <i class="ph-list-checks" style="color: var(--primary);"></i>
                    Generate Report
                </h3>
                <button @onclick="() => showReportSelector = false" style="background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);"><i class="ph-x"></i></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <label style="display: block; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">Select Report Sections</label>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 2rem;">
                    @foreach (var opt in availableReports)
                    {
                        <label style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--bg-light); border: 1px solid var(--border); border-radius: 10px; cursor: pointer; transition: all 0.2s; @(selectedReportTypes[opt.Value] ? "border-color: var(--primary); background: var(--primary-glow);" : "")">
                            <input type="checkbox" @bind="selectedReportTypes[opt.Value]" style="width: 18px; height: 18px; accent-color: var(--primary);" />
                            <span style="font-weight: 600; font-size: 0.875rem;">@opt.Label</span>
                        </label>
                    }
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div>
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">From Date</label>
                        <input type="date" class="form-control" @bind="fromDate" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border); font-family: inherit;" />
                    </div>
                    <div>
                        <label style="display: block; font-size: 0.75rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; margin-bottom: 0.5rem;">To Date</label>
                        <input type="date" class="form-control" @bind="toDate" style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border); font-family: inherit;" />
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="padding: 1.5rem; background: var(--bg-light); border-top: 1px solid var(--border); display: flex; gap: 1rem;">
                <button @onclick="() => showReportSelector = false" class="btn-secondary" style="flex: 1; justify-content: center; padding: 0.75rem;">Cancel</button>
                <button @onclick="GenerateReports" class="btn-primary" style="flex: 2; justify-content: center; padding: 0.75rem;">
                    <i class="ph-lightning"></i>
                    Generate Report
                </button>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .primary-glow { background: rgba(188, 24, 35, 0.05); }
</style>

@code {
    private bool showReportSelector = false;
    private DateTime? fromDate = DateTime.Now.AddDays(-30);
    private DateTime? toDate = DateTime.Now;
    private bool isLoading = false;
    private bool reportGenerated = false;
    private string currencySymbol = "$";
    
    private class ReportOption { public string Value { get; set; } = ""; public string Label { get; set; } = ""; }
    private List<ReportOption> availableReports = new();
    private Dictionary<string, bool> selectedReportTypes = new();
    
    private class ReportResult
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public List<Dictionary<string, string>> Data { get; set; } = new();
    }
    
    private List<ReportResult>? reports;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrency();
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        try
        {
            var httpContext = HttpContextAccessor.HttpContext;
            if (httpContext == null) return;

            var userRole = httpContext.Session.GetString("UserRole") ?? "";
            bool isAdmin = userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);

            availableReports = new List<ReportOption>();
            selectedReportTypes = new Dictionary<string, bool>();
            
            Action<string, string> addOption = (val, lbl) => {
                availableReports.Add(new ReportOption { Value = val, Label = lbl });
                selectedReportTypes[val] = false;
            };

            if (isAdmin)
            {
                addOption("sales", "Date Wise");
                addOption("returns", "Return Wise");
                addOption("customers", "Customer Wise");
                addOption("inventory", "Inventory Wise");
                addOption("products", "Product Wise");
                addOption("employees", "Employee Wise");
                addOption("users", "User Wise");
            }
            else
            {
                using var context = DbFactory.CreateDbContext();
                var perms = await context.roles_permissions.Include(p => p.Role)
                    .AsNoTracking()
                    .FirstOrDefaultAsync(p => p.Role.RoleTitle == userRole);

                if (perms != null)
                {
                    if (perms.SaleReport) addOption("sales", "Date Wise");
                    if (perms.ReturnsReport) addOption("returns", "Return Wise");
                    if (perms.CustomerReport) addOption("customers", "Customer Wise");
                    if (perms.Inventory) addOption("inventory", "Inventory Wise");
                    if (perms.ProductReport) addOption("products", "Product Wise");
                    if (perms.EmployeeReport) addOption("employees", "Employee Wise");
                    if (perms.Reports) addOption("users", "User Wise");
                }
            }
            
            if (selectedReportTypes.ContainsKey("sales")) selectedReportTypes["sales"] = true;
        }
        catch { }
    }

    private async Task LoadCurrency()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            var activeCurrency = await context.currencies.FirstOrDefaultAsync(c => c.is_active);
            if (activeCurrency != null) currencySymbol = activeCurrency.symbol ?? "$";
        }
        catch { }
    }

    private async Task ResetFilters()
    {
        fromDate = DateTime.Now.AddDays(-30);
        toDate = DateTime.Now;
        foreach (var key in selectedReportTypes.Keys.ToList()) selectedReportTypes[key] = false;
        if (selectedReportTypes.ContainsKey("sales")) selectedReportTypes["sales"] = true;
        reportGenerated = false;
        reports = null;
    }

    private async Task ExportToCSV(string tableId)
    {
        var report = reports?.FirstOrDefault(r => r.Id == tableId);
        var fileName = $"{(report?.Title ?? "Report").Replace(" ", "_")}_{DateTime.Now:yyyyMMdd}.csv";
        await JSRuntime.InvokeVoidAsync("exportTableToCSV", tableId, fileName);
    }

    private async Task PrintReport(string tableId)
    {
        await JSRuntime.InvokeVoidAsync("printElement", tableId);
    }

    private async Task GenerateReports()
    {
        if (!fromDate.HasValue || !toDate.HasValue)
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Required", "Please select both dates.", "warning");
            return;
        }

        if (!selectedReportTypes.Any(x => x.Value))
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Required", "Please select at least one report type.", "warning");
            return;
        }

        showReportSelector = false;
        isLoading = true;
        reportGenerated = false;
        reports = new List<ReportResult>();
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();

            foreach (var type in selectedReportTypes.Where(x => x.Value))
            {
                var result = new ReportResult { Id = $"table_{type.Key}", Title = GetReportTitle(type.Key) };
                
                switch (type.Key)
                {
                    case "sales": result.Data = await GetSalesReport(context); break;
                    case "returns": result.Data = await GetReturnsReport(context); break;
                    case "customers": result.Data = await GetCustomerReport(context); break;
                    case "inventory": result.Data = await GetInventoryReport(context); break;
                    case "products": result.Data = await GetProductReport(context); break;
                    case "employees": result.Data = await GetEmployeeReport(context); break;
                    case "users": result.Data = await GetUserReport(context); break;
                }
                
                reports.Add(result);
            }

            reportGenerated = true;
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Error", ex.Message, "error");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<List<Dictionary<string, string>>> GetSalesReport(ApplicationDbContext context)
    {
        var allSales = await context.sales.ToListAsync();
        var data = allSales.Where(s => {
            if (DateTime.TryParseExact(s.date, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var dt))
                return dt >= fromDate && dt <= toDate;
            return false;
        }).OrderByDescending(s => s.id).ToList();
        return data.Select(s => new Dictionary<string, string>
        {
            ["Bill #"] = s.billNo ?? "",
            ["Date"] = s.date,
            ["Items"] = s.no_of_items.ToString(),
            ["Qty"] = s.qty.ToString("N2"),
            ["Price"] = FormatCurrency(s.price),
            ["Disc"] = FormatCurrency(s.discount),
            ["Total"] = FormatCurrency(s.total_price),
            ["Payment"] = s.payment_method ?? "",
            ["Status"] = s.status ?? ""
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetReturnsReport(ApplicationDbContext context)
    {
        var allReturns = await context.returns.ToListAsync();
        var data = allReturns.Where(r => {
            if (DateTime.TryParseExact(r.date, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var dt))
                return dt >= fromDate && dt <= toDate;
            return false;
        }).OrderByDescending(r => r.Id).ToList();
        return data.Select(r => new Dictionary<string, string>
        {
            ["Bill #"] = r.billNo ?? "",
            ["Date"] = r.date,
            ["Qty"] = r.qty.ToString("N2"),
            ["Amount"] = FormatCurrency(r.Amount),
            ["Method"] = r.Method ?? "",
            ["Status"] = r.Status ?? ""
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetCustomerReport(ApplicationDbContext context)
    {
        var data = await context.customers.OrderBy(c => c.name).ToListAsync();
        return data.Select(c => new Dictionary<string, string>
        {
            ["ID"] = c.id.ToString(),
            ["Customer Name"] = c.name ?? "",
            ["Contact"] = c.contact ?? "",
            ["Email"] = c.email ?? "",
            ["Address"] = c.address ?? "",
            ["Status"] = c.status ?? ""
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetInventoryReport(ApplicationDbContext context)
    {
        var data = await context.stock_details.OrderByDescending(s => s.id).ToListAsync();
        return data.Select(s => new Dictionary<string, string>
        {
            ["Barcode"] = s.item_barcode ?? "",
            ["Stock Qty"] = s.quantity.ToString("N2"),
            ["Pur. Price"] = FormatCurrency(s.pur_price),
            ["Sale Price"] = FormatCurrency(s.sale_price),
            ["Wholesale"] = FormatCurrency(s.whole_sale_price),
            ["Total Pur. Value"] = FormatCurrency(s.total_pur_price),
            ["Mfg Date"] = s.date_of_manafacture ?? "N/A",
            ["Expiry"] = s.date_of_expiry ?? "N/A"
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetProductReport(ApplicationDbContext context)
    {
        var data = await context.products_services.OrderBy(p => p.prod_name).ToListAsync();
        return data.Select(p => new Dictionary<string, string>
        {
            ["Product Name"] = p.prod_name ?? "",
            ["Barcode"] = p.barcode ?? "",
            ["Type"] = p.item_type ?? "",
            ["Unit"] = p.unit ?? "",
            ["Status"] = p.status ?? "",
            ["Remarks"] = p.remarks ?? ""
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetEmployeeReport(ApplicationDbContext context)
    {
        var data = await context.employees.OrderBy(e => e.full_name).ToListAsync();
        return data.Select(e => new Dictionary<string, string>
        {
            ["Emp Code"] = e.emp_code ?? "",
            ["Full Name"] = e.full_name ?? "",
            ["CNIC"] = e.cnic ?? "",
            ["Mobile"] = e.mobile_no ?? "",
            ["Email"] = e.email ?? "",
            ["Salary"] = FormatCurrency(e.salary),
            ["Status"] = e.status ?? ""
        }).ToList();
    }

    private async Task<List<Dictionary<string, string>>> GetUserReport(ApplicationDbContext context)
    {
        var data = await context.users.Include(u => u.Role).Include(u => u.Employee).OrderBy(u => u.username).ToListAsync();
        return data.Select(u => new Dictionary<string, string>
        {
            ["Username"] = u.username ?? "",
            ["Email"] = u.email ?? "",
            ["Role"] = u.Role?.RoleTitle ?? "N/A",
            ["Employee"] = u.Employee?.full_name ?? "N/A",
            ["Status"] = u.status ?? ""
        }).ToList();
    }

    private string GetReportTitle(string type)
    {
        return type switch
        {
            "sales" => "Date Wise Report", "returns" => "Return Wise Report", "customers" => "Customer Wise Report",
            "inventory" => "Inventory Wise Report", "products" => "Product Wise Report", "employees" => "Employee Wise Report",
            "users" => "User Wise Report", _ => "Report"
        };
    }

    private string FormatCurrency(decimal amount) { return $"{currencySymbol}{amount:N2}"; }
}
