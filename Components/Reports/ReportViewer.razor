@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

@if (currentView == "center")
{
    <ReportsCenter OnViewHub="ShowHub" />
}
else if (currentView == "sales")
{
    <SalesReportsHub OnBack="GoToCenter" />
}
else if (currentView == "inventory")
{
    <InventoryReportsHub OnBack="GoToCenter" />
}
else if (currentView == "customers")
{
    <CustomerReportsHub OnBack="GoToCenter" />
}
else if (currentView == "products")
{
    <ProductReportsHub OnBack="GoToCenter" />
}
else if (currentView == "employees")
{
    <EmployeeReportsHub OnBack="GoToCenter" />
}
else if (currentView == "credits")
{
    <CreditReportsHub OnBack="GoToCenter" />
}
else
{
    <ReportsCenter OnViewHub="ShowHub" />
}

@code {
    private string currentView = "center";

    private void ShowHub(string hubType)
    {
        currentView = hubType;
    }

    private void GoToCenter()
    {
        currentView = "center";
    }
}
