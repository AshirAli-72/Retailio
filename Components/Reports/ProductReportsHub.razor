@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@using E_Invoice_system.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime

<div class="product-hub-container">
    <!-- Breadcrumbs -->
    <div class="hub-breadcrumbs no-print">
        <div class="breadcrumb-item">
            <i class="ph-house-line"></i>
            <span>Dashboard</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item clickable" @onclick="OnBack">
            <span>Reports Center</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item active">
            <span>Product Catalog</span>
        </div>
    </div>

    <!-- Header Section -->
    <div class="hub-header no-print">
        <div class="header-content">
            <h1 class="hub-title">Product Analytics</h1>
            <p class="hub-subtitle">Analyze your inventory composition and product intelligence</p>
        </div>
        <div class="header-actions">
            <button class="btn-outline" @onclick='() => ExportToCSV("productTable")'>
                <i class="ph-file-csv"></i> Export CSV
            </button>
            <button class="btn-primary-gradient" @onclick="PrintReport">
                <i class="ph-printer"></i> Print Catalog
            </button>
        </div>
    </div>

    <!-- Filters Glass -->
    <div class="filters-glass no-print">
        <div class="filters-inner">
            <div class="filter-group">
                <label><i class="ph-calendar"></i> From Date</label>
                <input type="date" @bind="fromDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-calendar"></i> To Date</label>
                <input type="date" @bind="toDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-package"></i> Select Product</label>
                <select @bind="selectedProductId">
                    <option value="All">All Products</option>
                    @foreach (var p in allProductsList)
                    {
                        <option value="@p.id">@p.prod_name</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-tag"></i> Category</label>
                <select @bind="selectedCategory">
                    <option value="All">All Categories</option>
                    @foreach (var cat in categoriesList)
                    {
                        <option value="@cat.id">@cat.category_title</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-check-circle"></i> Status</label>
                <select @bind="selectedStatus">
                    <option value="All">All Statuses</option>
                    <option value="Active">Active Only</option>
                    <option value="Inactive">Inactive Only</option>
                </select>
            </div>
            <div class="filter-actions-row">
                <button class="btn-reset-text" @onclick="ResetFilters">Reset Filters</button>
                <button class="btn-generate-glow" @onclick="LoadData">
                    <i class="ph-lightning"></i> Generate Analysis
                </button>
            </div>
        </div>
    </div>

    <div id="fullReportContainer">
        <!-- Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-card-premium border-purple">
                    <div class="stat-info">
                        <span class="label">Active Products</span>
                        <h2 class="value">@(isGenerated ? allProductsList.Count(p => p.status == (int?)EntityStatus.Active).ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon purple-glow"><i class="ph-package"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #8b5cf6;"></div></div>
                </div>

                <div class="stat-card-premium border-red">
                    <div class="stat-info">
                        <span class="label">Inactive Items</span>
                        <h2 class="value">@(isGenerated ? allProductsList.Count(p => p.status == (int?)EntityStatus.Inactive).ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon red-glow"><i class="ph-prohibit"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #BC1823;"></div></div>
                </div>

                <div class="stat-card-premium border-blue">
                    <div class="stat-info">
                        <span class="label">Total SKUs</span>
                        <h2 class="value">@(isGenerated ? allProductsList.Count.ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon blue-glow"><i class="ph-tag"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #3b82f6;"></div></div>
                </div>

                <div class="stat-card-premium border-orange">
                    <div class="stat-info">
                        <span class="label">Product Categories</span>
                        <h2 class="value">@(isGenerated ? categoriesList.Count.ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon orange-glow"><i class="ph-folders"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #f59e0b;"></div></div>
                </div>
            </div>

            <!-- Chart & Insight Row -->
            <div class="insight-row">
                <div class="glass-card chart-container">
                    <div class="card-header">
                        <h3 class="card-title"><i class="ph-chart-pie"></i> Category Distribution</h3>
                        <div class="card-badge">Product Mix</div>
                    </div>
                    <div class="chart-wrapper">
                        @if (isGenerated)
                        {
                            <canvas id="productHubChart"></canvas>
                        }
                        else
                        {
                            <div class="chart-skeleton">
                                <i class="ph-package"></i>
                                <p>Generate report to see category distribution</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="glass-card side-insights">
                    <div class="insights-tabs">
                        <div class="tab-item active"><i class="ph-magnifying-glass"></i> Top Categories</div>
                    </div>
                    <div class="insights-content">
                        @if (isGenerated && categoryInsights.Any())
                        {
                            @foreach (var cat in categoryInsights.Take(5))
                            {
                                <div class="product-mini-item">
                                    <div class="prod-details">
                                        <span class="prod-name">@cat.Name</span>
                                        <span class="prod-meta">@cat.Count Products</span>
                                    </div>
                                    <div class="prod-value" style="color: #3b82f6;">@cat.Percentage.ToString("N0")%</div>
                                </div>
                            }
                        }
                        else if (!isGenerated)
                        {
                            <div class="empty-mini">Awaiting analysis...</div>
                        }
                        else
                        {
                            <div class="empty-mini">No data available</div>
                        }

                        <div class="mix-header">
                            <h4 class="mix-title">Product Type Mix</h4>
                        </div>
                        <div class="mix-content">
                            @if (isGenerated)
                            {
                                @foreach (var type in typeStats)
                                {
                                    <div class="mix-item">
                                        <div class="mix-labels">
                                            <span>@type.Label</span>
                                            <span>@type.Percent.ToString("N0")%</span>
                                        </div>
                                        <div class="mix-bar-wrap">
                                            <div class="mix-bar" style="width: @(type.Percent)%; background: @(type.Color);"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="mix-skeleton"></div>
                                <div class="mix-skeleton"></div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Table Section -->
            <div class="glass-card table-section">
                <div class="card-header">
                    <h3 class="card-title"><i class="ph-package"></i> Master Product List</h3>
                    <div class="card-actions no-print">
                         <span class="count-badge">@(isGenerated ? products.Count : 0) Records</span>
                    </div>
                </div>
                <div class="table-container">
                    @if (isLoading)
                    {
                        <div class="premium-loader">
                            <i class="ph-spinner ph-spin"></i>
                            <span>Processing Intelligence...</span>
                        </div>
                    }
                    else if (isGenerated && products.Any())
                    {
                        <table class="premium-table" id="productTable">
                            <thead>
                                <tr>
                                    <th>Barcode</th>
                                    <th>Product Name</th>
                                    <th>Category</th>
                                    <th>Unit</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in products)
                                {
                                    <tr>
                                        <td><span class="badge-bill">@p.barcode</span></td>
                                        <td class="font-bold">@p.prod_name</td>
                                        <td>@p.CategoryName</td>
                                        <td>@p.unit</td>
                                        <td>@p.item_type</td>
                                        <td>
                                            <span class="badge-status @(p.status == (int?)EntityStatus.Active ? "sale" : "return")">@PaymentHelper.GetEntityStatusName(p.status)</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (!isGenerated)
                    {
                        <div class="empty-hero">
                            <i class="ph-package"></i>
                            <h3>Catalog Analytics Ready</h3>
                            <p>Set your filters and click <strong>Generate Analysis</strong> to view the product master list.</p>
                        </div>
                    }
                    else
                    {
                        <div class="empty-hero">
                            <i class="ph-package"></i>
                            <h3>Catalog Empty</h3>
                            <p>No products found matching your current parameters.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link href="/css/reports/productreport.css" rel="stylesheet" />

@code {
    [Parameter] public EventCallback OnBack { get; set; }

    private DateTime fromDate = DateTime.Now.AddDays(-30);
    private DateTime toDate = DateTime.Now;
    private string selectedProductId = "All";

    private class ProductVM : ProductService { public string CategoryName { get; set; } = ""; }
    private List<ProductVM> products = new();
    private List<Category> categoriesList = new();
    private List<ProductService> allProductsList = new();
    private bool isLoading = false;
    private bool isGenerated = false;
    private string selectedCategory = "All";
    private string selectedStatus = "All";
    private string currencySymbol = "Rs";
    private StoreConfiguration storeInfo = new();

    private class CatInsight { public string Name { get; set; } = ""; public int Count { get; set; } public decimal Percentage { get; set; } }
    private List<CatInsight> categoryInsights = new();

    private class TypeStat { public string Label { get; set; } = ""; public decimal Percent { get; set; } public string Color { get; set; } = ""; }
    private List<TypeStat> typeStats = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMetadata();
    }

    private async Task LoadMetadata()
    {
        using var context = DbFactory.CreateDbContext();
        categoriesList = await context.categories.AsNoTracking().ToListAsync();
        allProductsList = await context.products_services.AsNoTracking().OrderBy(x => x.prod_name).ToListAsync();
        var currency = await context.currencies.FirstOrDefaultAsync(c => c.is_active);
        if (currency != null) currencySymbol = currency.symbol ?? "Rs";

        var config = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();
        if (config != null) storeInfo = config;
    }

    private async Task ResetFilters()
    {
        selectedCategory = "All";
        selectedStatus = "All";
        selectedProductId = "All";
        fromDate = DateTime.Now.AddDays(-30);
        toDate = DateTime.Now;
        isGenerated = false;
        products.Clear();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        isLoading = true;
        isGenerated = true;
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();
            var query = context.products_services.AsNoTracking();

            if (selectedStatus == "Active") query = query.Where(x => x.status == (int?)EntityStatus.Active);
            else if (selectedStatus == "Inactive") query = query.Where(x => x.status == (int?)EntityStatus.Inactive);
            if (selectedProductId != "All") 
            {
                int pId = int.Parse(selectedProductId);
                query = query.Where(x => x.id == pId);
            }
            if (selectedCategory != "All") 
            {
                int catId = int.Parse(selectedCategory);
                query = query.Where(x => x.category_id == catId);
            }
            
            var data = await query.ToListAsync();
            var cats = categoriesList.ToDictionary(c => c.id, c => c.category_title);

            products = data.Select(p => new ProductVM
            {
                id = p.id,
                prod_name = p.prod_name,
                barcode = p.barcode,
                unit = p.unit,
                category_id = p.category_id,
                status = p.status,
                item_type = p.item_type,
                CategoryName = p.category_id.HasValue && cats.ContainsKey(p.category_id.Value) ? cats[p.category_id.Value] : "N/A"
            }).OrderBy(x => x.prod_name).ToList();

            // Category Insights
            int total = allProductsList.Count;
            categoryInsights = allProductsList.GroupBy(p => p.category_id)
                .Select(g => new CatInsight {
                    Name = g.Key.HasValue && cats.ContainsKey(g.Key.Value) ? cats[g.Key.Value] : "Uncategorized",
                    Count = g.Count(),
                    Percentage = total > 0 ? (g.Count() * 100m / total) : 0
                }).OrderByDescending(x => x.Count).ToList();

            // Chart Data
            var chartLabels = categoryInsights.Select(c => c.Name).ToArray();
            var chartValues = categoryInsights.Select(c => (decimal)c.Count).ToArray();
            await JSRuntime.InvokeVoidAsync("renderReportChart", "productHubChart", new { labels = chartLabels, values = chartValues, label = "Product Count", type = "doughnut" });

            // Type Mix
            var types = allProductsList.GroupBy(p => p.item_type ?? "General")
                .Select(g => new { Label = g.Key, Count = g.Count() })
                .ToList();
            
            typeStats = types.Select((t, index) => new TypeStat {
                Label = t.Label,
                Percent = total > 0 ? (t.Count * 100m / total) : 0,
                Color = index % 2 == 0 ? "#8b5cf6" : "#3b82f6"
            }).ToList();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task PrintReport() { 
        string logoUrl = "";
        if (!string.IsNullOrEmpty(storeInfo.LogoPath)) logoUrl = $"/store-logo/{Path.GetFileName(storeInfo.LogoPath)}";

        var printData = new {
            shopName = storeInfo.ShopName,
            address = storeInfo.Address,
            phone = storeInfo.Phone1,
            email = "", 
            logoUrl = logoUrl
        };

        await JSRuntime.InvokeVoidAsync("printElement", "fullReportContainer", "Product Catalog Report", printData); 
    }
    private async Task ExportToCSV(string id) { await JSRuntime.InvokeVoidAsync("exportTableToCSV", id, "Product_Report.csv"); }
}

