@using E_Invoice_system.Models
@using E_Invoice_system.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime

<div class="sales-hub-container">
    <!-- Breadcrumbs -->
    <div class="hub-breadcrumbs no-print">
        <div class="breadcrumb-item">
            <i class="ph-house-line"></i>
            <span>Dashboard</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item clickable" @onclick="OnBack">
            <span>Reports Center</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item active">
            <span>Sales & Revenue</span>
        </div>
    </div>

    <!-- Header Section -->
    <div class="hub-header no-print">
        <div class="header-content">
            <h1 class="hub-title">Sales Analytics</h1>
            <p class="hub-subtitle">Monitor your business performance and revenue growth</p>
        </div>
        <div class="header-actions">
            <button class="btn-outline" @onclick='() => ExportToCSV("salesTable")'>
                <i class="ph-file-csv"></i> Export CSV
            </button>
            <button class="btn-primary-gradient" @onclick="PrintReport">
                <i class="ph-printer"></i> Print Report
            </button>
        </div>
    </div>

    <!-- Advanced Filters -->
    <div class="filters-glass no-print">
        <div class="filters-inner">
            <div class="filter-group">
                <label><i class="ph-calendar"></i> From Date</label>
                <input type="date" @bind="fromDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-calendar"></i> To Date</label>
                <input type="date" @bind="toDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-tag"></i> Category</label>
                <select @bind="selectedCategory">
                    <option value="All">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.id">@cat.category_title</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-user"></i> Employee</label>
                <select @bind="selectedEmployee">
                    <option value="All">All Employees</option>
                    @foreach (var emp in employees)
                    {
                        <option value="@emp.id">@emp.full_name</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-credit-card"></i> Method</label>
                <select @bind="selectedPayment">
                    <option value="All">All Methods</option>
                    <option value="Cash">Cash</option>
                    <option value="Card">Card</option>
                    <option value="Online">Online</option>
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-funnel"></i> Type</label>
                <select @bind="selectedType">
                    <option value="Sale">Sales Only</option>
                    <option value="Return">Returns Only</option>
                </select>
            </div>
            <div class="filter-actions-row">
                <button class="btn-reset-text" @onclick="ResetFilters">Reset Filters</button>
                <button class="btn-generate-glow" @onclick="GenerateReport">
                    <i class="ph-lightning"></i> Generate Analysis
                </button>
            </div>
        </div>
    </div>

    <div id="fullReportContainer">
        <!-- Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-card-premium border-red">
                    <div class="stat-info">
                        <span class="label">Gross Revenue</span>
                        <h2 class="value">@currencySymbol @(isGenerated ? totalRevenue.ToString("N0") : "---")</h2>
                    </div>
                    <div class="stat-icon red-glow"><i class="ph-trend-up"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #BC1823;"></div></div>
                </div>

                <div class="stat-card-premium border-green">
                    <div class="stat-info">
                        <span class="label">Transactions</span>
                        <h2 class="value">@(isGenerated ? totalTransactions.ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon green-glow"><i class="ph-receipt"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #10b981;"></div></div>
                </div>

                <div class="stat-card-premium border-blue">
                    <div class="stat-info">
                        <span class="label">Avg Transaction</span>
                        <h2 class="value">@currencySymbol @(isGenerated ? avgTransaction.ToString("N0") : "---")</h2>
                    </div>
                    <div class="stat-icon blue-glow"><i class="ph-shopping-cart"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #3b82f6;"></div></div>
                </div>

                <div class="stat-card-premium border-orange">
                    <div class="stat-info">
                        <span class="label">Total Discounts</span>
                        <h2 class="value">@currencySymbol @(isGenerated ? totalDiscounts.ToString("N0") : "---")</h2>
                    </div>
                    <div class="stat-icon orange-glow"><i class="ph-percent"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #f59e0b;"></div></div>
                </div>
            </div>

            <!-- Chart & Insight Row -->
            <div class="insight-row">
                <div class="glass-card chart-container">
                    <div class="card-header">
                        <h3 class="card-title"><i class="ph-chart-line-up"></i> Revenue Performance</h3>
                        <div class="card-badge">Daily Breakdown</div>
                    </div>
                    <div class="chart-wrapper">
                        @if (isGenerated)
                        {
                            <canvas id="salesHubChart"></canvas>
                        }
                        else
                        {
                            <div class="chart-skeleton">
                                <i class="ph-chart-line"></i>
                                <p>Generate report to see trends</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="glass-card side-insights">
                    <div class="insights-tabs">
                        <div class="tab-item active"><i class="ph-trophy"></i> Best Sellers</div>
                    </div>
                    <div class="insights-content">
                        @if (isGenerated && topProducts.Any())
                        {
                            @foreach (var prod in topProducts.Take(4))
                            {
                                <div class="product-mini-item">
                                    <div class="prod-details">
                                        <span class="prod-name">@prod.Name</span>
                                        <span class="prod-meta">@prod.Count Sales</span>
                                    </div>
                                    <div class="prod-value">@currencySymbol@prod.Revenue.ToString("N0")</div>
                                </div>
                            }
                        }
                        else if (!isGenerated)
                        {
                            <div class="empty-mini">Awaiting analysis...</div>
                        }
                        else
                        {
                            <div class="empty-mini">No data available</div>
                        }

                        <div class="mix-header">
                            <h4 class="mix-title">Payment Distribution</h4>
                        </div>
                        <div class="mix-content">
                            @if (isGenerated)
                            {
                                @foreach (var pay in paymentStats)
                                {
                                    <div class="mix-item">
                                        <div class="mix-labels">
                                            <span>@pay.Method</span>
                                            <span>@pay.Percent.ToString("N0")%</span>
                                        </div>
                                        <div class="mix-bar-wrap">
                                            <div class="mix-bar" style="width: @(pay.Percent)%; background: @(pay.Color);"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="mix-skeleton"></div>
                                <div class="mix-skeleton"></div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Large Table Section -->
            <div class="glass-card table-section">
                <div class="card-header">
                    <h3 class="card-title"><i class="ph-list-bullets"></i> Transaction Ledger</h3>
                    <div class="card-actions no-print">
                            <span class="count-badge">@(isGenerated ? reportData.Count : 0) Records</span>
                    </div>
                </div>
                <div class="table-container">
                    @if (isLoading)
                    {
                        <div class="premium-loader">
                            <i class="ph-spinner ph-spin"></i>
                            <span>Processing Intelligence...</span>
                        </div>
                    }
                    else if (isGenerated && reportData.Any())
                    {
                        <table class="premium-table" id="salesTable">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Invoice No</th>
                                    <th>Items</th>
                                    <th>Subtotal</th>
                                    <th>Discount</th>
                                    <th>Net Total</th>
                                    <th>Payment</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in reportData)
                                {
                                    <tr>
                                        <td class="td-date">@sale.date</td>
                                        <td><span class="badge-bill">@sale.inv_no</span></td>
                                        <td class="td-center">@sale.no_of_items</td>
                                        <td>@currencySymbol@sale.price.ToString("N2")</td>
                                        <td class="text-orange">@currencySymbol@sale.discount.ToString("N2")</td>
                                        <td><strong class="text-primary">@currencySymbol@sale.total_price.ToString("N2")</strong></td>
                                        <td><span class="badge-method">@sale.payment_method</span></td>
                                        <td>
                                            @if (sale.is_returned) { <span class="badge-status return">Returned</span> }
                                            else { <span class="badge-status sale">Success</span> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (!isGenerated)
                    {
                        <div class="empty-hero">
                            <i class="ph-lightning"></i>
                            <h3>Ready for Analysis</h3>
                            <p>Set your criteria above and click <strong>Generate Analysis</strong> to visualize your sales data.</p>
                        </div>
                    }
                    else
                    {
                        <div class="empty-hero">
                            <i class="ph-file-search"></i>
                            <h3>No Transactions Found</h3>
                            <p>Adjust your filters or generate a new report to view data.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link href="/css/reports/salereport.css" rel="stylesheet" />

@code {
    [Parameter] public EventCallback OnBack { get; set; }

    private DateTime fromDate = DateTime.Now.AddDays(-30);
    private DateTime toDate = DateTime.Now;
    private string selectedCategory = "All";
    private string selectedEmployee = "All";
    private string selectedPayment = "All";
    private string selectedType = "Sale";

    private decimal totalRevenue = 0;
    private int totalTransactions = 0;
    private decimal avgTransaction = 0;
    private decimal totalDiscounts = 0;
    private string currencySymbol = "Rs";

    private List<Category> categories = new();
    private List<E_Invoice_system.Models.Employee> employees = new();
    private List<Sale> reportData = new();
    private bool isLoading = false;
    private bool isGenerated = false;
    private StoreConfiguration storeInfo = new();

    private class TopProduct { public string Name { get; set; } = ""; public int Count { get; set; } public decimal Revenue { get; set; } }
    private List<TopProduct> topProducts = new();

    private class PaymentStat { public string Method { get; set; } = ""; public decimal Percent { get; set; } public string Color { get; set; } = ""; }
    private List<PaymentStat> paymentStats = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMetadata();
    }

    private async Task LoadMetadata()
    {
        using var context = DbFactory.CreateDbContext();
        categories = await context.categories.AsNoTracking().ToListAsync();
        employees = await context.employees.AsNoTracking().ToListAsync();
        
        var currency = await context.currencies.FirstOrDefaultAsync(c => c.is_active);
        if (currency != null) currencySymbol = currency.symbol ?? "Rs";

        var config = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();
        if (config != null) storeInfo = config;
    }

    private async Task ResetFilters()
    {
        fromDate = DateTime.Now.AddDays(-30);
        toDate = DateTime.Now;
        selectedCategory = "All";
        selectedEmployee = "All";
        selectedPayment = "All";
        selectedType = "Sale";
        reportData.Clear();
        isGenerated = false;
        StateHasChanged();
    }

    private async Task GenerateReport()
    {
        isLoading = true;
        isGenerated = true;
        StateHasChanged();

        try
        {
            using var context = DbFactory.CreateDbContext();
            var allSales = await context.sales.AsNoTracking().ToListAsync();

            var filtered = allSales.Where(s => {
                if (!DateTime.TryParse(s.date, out var d)) return false;
                bool inRange = d.Date >= fromDate.Date && d.Date <= toDate.Date;
                bool matchPayment = selectedPayment == "All" || s.payment_method == selectedPayment;
                bool matchType = selectedType == "Return" ? s.is_returned : !s.is_returned;
                return inRange && matchPayment && matchType;
            }).ToList();

            reportData = filtered.OrderByDescending(s => s.date).ToList();
            
            totalRevenue = reportData.Sum(s => s.total_price);
            totalTransactions = reportData.Count;
            avgTransaction = totalTransactions > 0 ? totalRevenue / totalTransactions : 0;
            totalDiscounts = reportData.Sum(s => s.discount);

            // Chart Data Calculation
            var chartGroups = reportData.GroupBy(s => s.date)
                .Select(g => new { Date = g.Key, Total = g.Sum(s => s.total_price) })
                .OrderBy(g => g.Date)
                .ToList();

            if (chartGroups.Any())
            {
                var labels = chartGroups.Select(g => g.Date).ToArray();
                var values = chartGroups.Select(g => g.Total).ToArray();
                await JSRuntime.InvokeVoidAsync("renderReportChart", "salesHubChart", new { labels, values, label = "Revenue" });
            }

            // Top Products
            topProducts = reportData.GroupBy(s => s.description ?? "Walk-In")
                .Select(g => new TopProduct { Name = g.Key, Count = g.Count(), Revenue = g.Sum(s => s.total_price) })
                .OrderByDescending(p => p.Revenue)
                .ToList();

            // Payment Mix
            var methods = reportData.GroupBy(s => s.payment_method ?? "Other")
                .Select(g => new { Method = g.Key, Count = g.Count() })
                .ToList();
            
            var colors = new[] { "#BC1823", "#10b981", "#3b82f6", "#f59e0b" };
            paymentStats = methods.Select((m, index) => new PaymentStat {
                Method = m.Method,
                Percent = totalTransactions > 0 ? (m.Count * 100m / totalTransactions) : 0,
                Color = colors[index % colors.Length]
            }).ToList();
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task PrintReport()
    {
        string logoUrl = "";
        if (!string.IsNullOrEmpty(storeInfo.LogoPath)) logoUrl = $"/store-logo/{Path.GetFileName(storeInfo.LogoPath)}";

        var printData = new {
            shopName = storeInfo.ShopName,
            address = storeInfo.Address,
            phone = storeInfo.Phone1,
            email = "", 
            logoUrl = logoUrl
        };

        await JSRuntime.InvokeVoidAsync("printElement", "fullReportContainer", "Sales & Revenue Report", printData);
    }

    private async Task ExportToCSV(string tableId)
    {
        await JSRuntime.InvokeVoidAsync("exportTableToCSV", tableId, $"Sales_Report_{DateTime.Now:yyyyMMdd}.csv");
    }
}
