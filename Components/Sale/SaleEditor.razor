    private async Task SubmitSale()
    {
        if (isSubmitting || !saleItems.Any())
            return;

        isSubmitting = true;

        try
        {
            using var context = DbFactory.CreateDbContext();

            if (paymentMethod == "Cash")
            {
                if ((tenderedAmount ?? 0) <= 0)
                {
                    ShowAlert("Please enter tender amount.");
                    return;
                }

                if ((tenderedAmount ?? 0) < Math.Abs(currentTotal))
                {
                    ShowAlert("Tender amount cannot be less than total.");
                    return;
                }
            }

            var creditCust = paymentMethod == "Credit"
                ? creditSelectedCustomer ?? selectedCustomer
                : null;

            if (paymentMethod == "Credit" && creditCust == null)
            {
                ShowAlert("Please select a customer for credit sale.");
                return;
            }

            if (paymentMethod == "Credit" && creditCust!.credit_limit.HasValue)
            {
                var existing = await context.credits
                    .Where(c => c.customer_id == creditCust.id && c.status != "Paid")
                    .FirstOrDefaultAsync();
                var outstanding = existing?.remaining ?? 0;
                var newCreditTotal = Math.Abs(currentTotal) - creditEntry.paid_amount;
                if (outstanding + newCreditTotal > creditCust.credit_limit.Value)
                {
                    ShowAlert($"Credit limit exceeded! Outstanding: {outstanding:N0}, New credit: {newCreditTotal:N0}, Limit: {creditCust.credit_limit:N0}");
                    return;
                }
            }

            if (string.IsNullOrWhiteSpace(orderInvNo))
                orderInvNo = await GenerateNextInvNoAsync(context);
            await InvokeAsync(StateHasChanged);

            var productNames = saleItems
                .Select(i => i.prod_name_service)
                .Distinct()
                .ToList();

            var productsInSale = await context.products_services
                .Where(p => productNames.Contains(p.prod_name))
                .ToListAsync();

            var barcodesInSale = productsInSale
                .Select(p => p.barcode)
                .Where(b => b != null)
                .ToList();

            var stocksToUpdate = await context.stock_details
                .Where(s => barcodesInSale.Contains(s.item_barcode))
                .ToListAsync();

            int? currentUserId = ResolveCurrentUserId(context);

            Credit? newCredit = null;
            SaleHeader? saleHeader = null;
            string? creditFilePath = null;
            if (paymentMethod == "Credit")
            {
                creditFilePath = await SaveFileAsync(creditEntry.file_browser);
            }

            // Create SaleHeader for all non-return sales (cash + credit)
            if (transMode != "return")
            {
                bool isCredit = paymentMethod == "Credit" && creditCust != null;
                saleHeader = new SaleHeader
                {
                    inv_no = orderInvNo,
                    customer_id = isCredit ? creditCust!.id : selectedCustomer?.id,
                    date = DateTime.Now.ToString("yyyy-MM-dd"),
                    gross_total = saleItems.Sum(i => Math.Abs(i.price * i.qty)),
                    discount = saleItems.Sum(i => Math.Abs(i.discount * i.qty)),
                    net_payable = Math.Abs(currentTotal),
                    paid = isCredit ? creditEntry.paid_amount : (tenderedAmount ?? Math.Abs(currentTotal)),
                    due = isCredit ? creditRemainingAmount : Math.Max(0, Math.Abs(currentTotal) - ((tenderedAmount ?? 0) > 0 ? (tenderedAmount ?? 0) : Math.Abs(currentTotal))),
                    status = isCredit ? (creditRemainingAmount > 0 ? "Pending" : "Paid") : "Paid",
                    payment_method = paymentMethod
                };
                context.SalesHeader.Add(saleHeader);

                if (isCredit)
                {
                    newCredit = await context.credits
                        .Where(c => c.customer_id == creditCust!.id && c.status != "Paid")
                        .FirstOrDefaultAsync();

                    if (newCredit != null)
                    {
                        newCredit.total_credit += Math.Abs(currentTotal);
                        newCredit.paid += creditEntry.paid_amount;
                        newCredit.remaining = newCredit.total_credit - newCredit.paid;
                        newCredit.status = newCredit.remaining > 0 ? "Pending" : "Paid";
                        if (!string.IsNullOrEmpty(creditFilePath))
                            newCredit.file = creditFilePath;
                    }
                    else
                    {
                        newCredit = new Credit
                        {
                            customer_id = creditCust!.id,
                            date = DateTime.Now.ToString("yyyy-MM-dd"),
                            total_credit = Math.Abs(currentTotal),
                            paid = creditEntry.paid_amount,
                            remaining = creditRemainingAmount,
                            payment_method = "Credit",
                            status = creditRemainingAmount > 0 ? "Pending" : "Paid",
                            file = creditFilePath
                        };
                        context.credits.Add(newCredit);
                    }
                }

                await context.SaveChangesAsync();
            }

            var saleRecords = new List<(Sale sale, int itemIndex)>();

            foreach (var item in saleItems)
            {
                if (transMode != "return")
                {
                    var saleProd = productsInSale.FirstOrDefault(p => p.prod_name == item.prod_name_service);
                    var sale = new Models.Sale
                    {
                        sale_id = saleHeader!.id,
                        item_id = saleProd?.id ?? 0,
                        qty = item.qty,
                        unit_price = item.price,
                        total_price = item.total_price,
                        status = saleHeader.status ?? "Paid"
                    };
                    context.sales.Add(sale);
                    saleRecords.Add((sale, saleItems.IndexOf(item)));
                }
                else
                {
                    var saleLine = item.OriginalSaleId > 0
                        ? await context.sales.FindAsync(item.OriginalSaleId)
                        : null;
                    var returnProd = productsInSale
                        .FirstOrDefault(p => p.prod_name == item.prod_name_service);

                    context.returns.Add(new ReturnDetail
                    {
                        inv_no = orderInvNo,
                        date = DateTime.Now.ToString("yyyy-MM-dd"),
                        sale_id = item.OriginalSaleHeaderId > 0 ? item.OriginalSaleHeaderId : (int?)null, // Use null if no sale header ID
                        item_id = returnProd?.id ?? 0,
                        qty = Math.Abs(item.qty),
                        unit_price = item.price,
                        total_price = Math.Abs(item.total_price),
                        payment_method = paymentMethod,
                        status = "Returned"
                    });
                }

                var prod = productsInSale
                    .FirstOrDefault(p => p.prod_name == item.prod_name_service);

                if (prod?.barcode != null)
                {
                    var stock = stocksToUpdate
                        .FirstOrDefault(s => s.item_barcode == prod.barcode);

                    if (stock != null)
                    {
                        int oldStockQty = stock.quantity;
                        stock.quantity -= item.qty;
                        context.stock_details.Update(stock);

                        context.stock_history.Add(new Models.stock_history
                        {
                            product_id = prod.id,
                            user_id = currentUserId,
                            date = DateTime.Now.ToString("yyyy-MM-dd"),
                            old_quantity = oldStockQty,
                            new_quantity = stock.quantity,
                            old_purchase_price = stock.pur_price,
                            new_purchase_price = stock.pur_price,
                            old_sale_price = stock.sale_price,
                            new_sale_price = stock.sale_price,
                            remarks = transMode == "return" ? "Return" : "Sale"
                        });
                    }
                }
            }

            // Save to get Sale IDs, then create CreditDetail records
            await context.SaveChangesAsync();

            if (newCredit != null)
            {
                var totalAmount = saleRecords.Sum(s => Math.Abs(s.sale.total_price));
                var distributed = 0m;
                for (int i = 0; i < saleRecords.Count; i++)
                {
                    var lineAmount = Math.Abs(saleRecords[i].sale.total_price);
                    var linePaid = i < saleRecords.Count - 1
                        ? Math.Round(lineAmount / totalAmount * creditEntry.paid_amount, 2)
                        : creditEntry.paid_amount - distributed;
                    distributed += linePaid;

                    context.credits_details.Add(new CreditDetail
                    {
                        credit_id = newCredit.id,
                        date = DateTime.Now.ToString("yyyy-MM-dd"),
                        sale_id = saleHeader!.id,
                        amount = lineAmount,
                        paid = linePaid,
                        due = lineAmount - linePaid,
                        payment_method = "Credit",
                        status = "Pending",
                        file = creditFilePath
                    });
                }
            }

            if (transMode == "return")
            {
                var originalSaleIds = saleItems
                    .Where(i => i.OriginalSaleId > 0)
                    .Select(i => i.OriginalSaleId)
                    .Distinct()
                    .ToList();

                if (originalSaleIds.Any() && returnFromCredit)
                {
                    // Get all sale details for the original sale to find their sale_id (SaleHeader ID)
                    var originalSaleDetails = await context.sales
                        .Where(sd => originalSaleIds.Contains(sd.id))
                        .ToListAsync();
                    var saleHeaderIds = originalSaleDetails
                        .Select(sd => sd.sale_id)
                        .Distinct()
                        .ToList();

                    // Find associated CreditDetail records using sale_id (SaleHeader ID)
                    var creditLines = await context.credits_details
                        .Where(c => saleHeaderIds.Contains(c.sale_id))
                        .ToListAsync();

                    // Calculate total return amount from items being returned
                    decimal totalReturnAmount = saleItems.Sum(i => Math.Abs(i.total_price));

                    foreach (var creditLine in creditLines)
                    {
                        creditLine.status = "Returned";
                        creditLine.amount -= Math.Min(creditLine.amount, totalReturnAmount);
                        if (creditLine.amount < 0) creditLine.amount = 0;
                        totalReturnAmount -= creditLine.amount;
                        if (totalReturnAmount <= 0) break;
                    }

                    var creditIds = creditLines
                        .Select(c => c.credit_id)
                        .Distinct()
                        .ToList();

                    if (creditIds.Any())
                    {
                        var credits = await context.credits
                            .Where(c => creditIds.Contains(c.id))
                            .ToListAsync();

                        foreach (var credit in credits)
                        {
                            // Recalculate total_credit and remaining based on updated CreditDetails
                            var updatedLines = creditLines.Where(cl => cl.credit_id == credit.id).ToList();
                            decimal newTotalCredit = updatedLines.Sum(cl => cl.amount);
                            decimal newPaid = updatedLines.Sum(cl => cl.paid);
                            decimal newRemaining = newTotalCredit - newPaid;
                            
                            credit.total_credit = newTotalCredit;
                            credit.paid = newPaid;
                            credit.remaining = newRemaining;
                            credit.status = newRemaining > 0 ? "Pending" : "Paid";
                        }
                    }
                }
            }

            await context.SaveChangesAsync();

            await JSRuntime.InvokeVoidAsync("showToast", "Success", "Transaction completed successfully!", "success");

            if (shouldPrintReceipt && !string.IsNullOrWhiteSpace(orderInvNo))
            {
                _receiptSnapshot = BuildReceiptSnapshot();
                if (paymentMethod == "Credit")
                {
                    _receiptSnapshot.CreditPaid = creditEntry.paid_amount;
                    _receiptSnapshot.CreditRemaining = creditRemainingAmount;
                }
                await InvokeAsync(StateHasChanged);
                await Task.Delay(400);
                await JSRuntime.InvokeVoidAsync("printSaleReceipt", orderInvNo);
                _resetAfterPrint = true;
            }
            else
            {
                ResetComponent();
            }

            tenderedAmount = 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] SubmitSale: {ex.ToString()}");
            if (ex.InnerException != null)
                Console.WriteLine($"[ERROR] Inner Exception: {ex.InnerException.ToString()}");

            string errorMsg = $"Save failed: {ex.Message}";
            if (ex.InnerException != null)
                errorMsg += $" Details: {ex.InnerException.Message}";

            await JSRuntime.InvokeVoidAsync("showToast", "Error", errorMsg, "error");
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string FormatCurrency(decimal val) =>
        (val < 0 ? "-" : "") + CurrencyService.GetSymbol() + Math.Abs(val).ToString("N2");

    private static string FormatReceiptAmount(decimal val, ReceiptSnapshot r) =>
        r.CurrencySymbol + Math.Abs(val).ToString("N2");

    private ReceiptSnapshot BuildReceiptSnapshot()
    {
        var symbol = CurrencyService.GetSymbol();
        return new ReceiptSnapshot
        {
            InvNo = orderInvNo,
            Title = transMode == "return" ? "RETURN INVOICE" : (paymentMethod == "Credit" ? "CREDIT INVOICE" : "SALES INVOICE"),
            Date = DateTime.Now.ToString("dd/MM/yyyy HH:mm"),
            Customer = selectedCustomer?.name ?? "Walking Customer",
            Payment = paymentMethod,
            StoreName = currentStore?.ShopName ?? "E-Invoice",
            Address = currentStore?.Address ?? "Gilgit, Pakistan",
            Phone = currentStore?.Phone1 ?? "+92 345 6781267",
            LogoFileName = !string.IsNullOrEmpty(currentStore?.LogoPath)
                ? System.IO.Path.GetFileName(currentStore.LogoPath)
                : null,
            CurrencySymbol = symbol,
            Subtotal = saleItems.Sum(i => i.price * Math.Abs(i.qty)),
            Discount = totalDisc,
            Total = Math.Abs(currentTotal),
            Lines = saleItems.Select(i => new ReceiptLine
            {
                Name = i.prod_name_service,
                Qty = Math.Abs(i.qty),
                Price = i.price,
                Discount = i.discount * Math.Abs(i.qty),
                LineTotal = Math.Abs(i.total_price)
            }).ToList()
        };
    }

    private async Task ToggleFullScreen() =>
        await JSRuntime.InvokeVoidAsync("eval",
            "if (!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen();");

    private void ResetComponent()
    {
        saleItems.Clear();
        selectedCustomer = null;
        customerSearchQuery = null;
        searchQuery = "";
        paymentMethod = "Cash";
        tenderedAmount = null;
        notes = "";
        shouldPrintReceipt = true;
        showPaymentModal = false;
        showCreditModal = false;
        showAddCustomerModal = false;
        creditEntry = new CreditEntry();
        creditSelectedCustomer = null;
        creditCustomerSearch = null;
        transMode = "sale";
        returnFromCredit = false;
        orderInvNo = "";
        _receiptSnapshot = null;
        loadedCredit = null;
        _loadedSaleHeaderId = null; // Clear loaded sale header ID
        _resetAfterPrint = false;

        ApplyFilters();
        StateHasChanged();
    }

