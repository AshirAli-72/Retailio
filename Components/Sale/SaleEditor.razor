    private async void ConfirmAdditionalPayment()
    {
        if (loadedCredit == null || additionalPayment <= 0)
        {
            ShowAlert("Enter a valid payment amount.");
            return;
        }

        if (additionalPayment > loadedCredit.remaining)
        {
            ShowAlert("Payment cannot exceed remaining balance.");
            return;
        }

        using var context = DbFactory.CreateDbContext();

        var credit = await context.credits.FindAsync(loadedCredit.id);
        if (credit == null) return;

        credit.paid += additionalPayment;
        credit.remaining = credit.total_credit - credit.paid;
        credit.status = credit.remaining > 0 ? "Pending" : "Paid";

        // Create a SaleHeader so this payment counts in Total Sales
        var orderInvNo = await GenerateNextInvNoAsync(context);
        var paymentHeader = new SaleHeader
        {
            inv_no = orderInvNo,
            customer_id = credit.customer_id,
            date = DateTime.Now.ToString("yyyy-MM-dd"),
            gross_total = additionalPayment,
            discount = 0,
            net_payable = additionalPayment,
            paid = additionalPayment,
            due = 0,
            status = "Paid",
            payment_method = "Credit"
        };
        context.SalesHeader.Add(paymentHeader);
        await context.SaveChangesAsync();

        var filePath = await SaveFileAsync(additionalPaymentBrowserFile);

        context.credits_details.Add(new CreditDetail
        {
            credit_id = credit.id,
            date = DateTime.Now.ToString("yyyy-MM-dd"),
            sale_id = paymentHeader.id,
            amount = additionalPayment,
            paid = additionalPayment,
            due = 0,
            payment_method = "Credit",
            status = "Paid",
            file = filePath
        });

        if (!string.IsNullOrEmpty(filePath))
        {
            credit.file = filePath;
        }

        await context.SaveChangesAsync();

        loadedCredit = credit;
        additionalPayment = 0;
        additionalPaymentBrowserFile = null;
        additionalPaymentFileName = null;
        ShowAlert("Payment recorded successfully.");
        StateHasChanged();
    }

