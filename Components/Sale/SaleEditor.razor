    private async Task<string> GenerateNextInvNoAsync(ApplicationDbContext context)
    {
        string prefix = transMode == "return" ? "RETURN_" : "SALE_";

        var sequences = new List<int>();

        if (prefix == "SALE_")
        {
            var invs = await context.SalesHeader
                .Where(s => s.inv_no != null && s.inv_no.ToUpper().StartsWith("SALE_"))
                .Select(s => s.inv_no).ToListAsync();
            foreach (var inv in invs) sequences.Add(ParseInvSequence(inv, "SALE_"));
        }
        else // RETURN_
        {
            var invs = await context.returns
                .Where(r => r.inv_no != null && r.inv_no.ToUpper().StartsWith("RETURN_"))
                .Select(r => r.inv_no).ToListAsync();
            foreach (var inv in invs) sequences.Add(ParseInvSequence(inv, "RETURN_"));
        }

        var nextNum = (sequences.Count > 0 ? sequences.Max() : 0) + 1;
        return $"{prefix}{nextNum}";
    }

    private static int ParseInvSequence(string? invNo, string prefix)
    {
        if (string.IsNullOrWhiteSpace(invNo)) return 0;
        var value = invNo.Trim().ToUpperInvariant();
        if (!value.StartsWith(prefix.ToUpperInvariant())) return 0;
        return int.TryParse(value[prefix.Length..], out int n) ? n : 0;
    }

    private static int ParseInvSequence(string? invNo)
    {
        if (string.IsNullOrWhiteSpace(invNo)) return 0;
        var value = invNo.Trim().ToLowerInvariant();
        if (!value.StartsWith("inv")) return 0;
        return int.TryParse(value[3..], out int n) ? n : 0;
    }

