<link href="/css/sale/create.css" rel="stylesheet" />

@code {
    // ── Lists ─────────────────────────────────────────────────────────────────
    private List<ProductDisplay> allProducts = new();
    private List<ProductDisplay> filteredProducts = new();
    private List<customers> allCustomersList = new();
    private List<customers> filteredCustomersList = new();
    private List<SaleItem> saleItems = new();

    // ── UI State ──────────────────────────────────────────────────────────────
    private string searchQuery = "";
    private string searchType = "item";
    private bool showScanMenu = false;
    private string productTypeFilter = "All";
    private string selectedCategory = "all";
    private string transMode = "sale";
    private bool returnFromCredit = false;
    private string? customerSearchQuery;
    private customers? selectedCustomer;
    private bool showCustomerDropdown = false;

    // ── Recovery Modal State ────────────────────────────────────────────────
    private bool showRecoveryModal = false;
    private Recovery recoveryModel = new();
    private customers? recoverySelectedCustomer;
    private Credit? recoveryCustomerCredit;
    private DateTime? recoveryTempDate = null;
    private string? recoveryErrorMessage;
    private bool isRecoverySubmitting = false;

    private void GoToRecovery()
    {
        ShowRecoveryForm();
    }

    private void GoToRecoveryFromCreditModal()
    {
        showCreditModal = false;
        ShowRecoveryForm();
    }

    private void ShowRecoveryForm()
    {
        recoverySelectedCustomer = selectedCustomer ?? creditSelectedCustomer;
        if (recoverySelectedCustomer != null)
        {
            using var context = DbFactory.CreateDbContext();
            recoveryCustomerCredit = context.credits.FirstOrDefault(c => c.customer_id == recoverySelectedCustomer.id);
        }

        recoveryModel = new Recovery
        {
            date = DateTime.Now.ToString("yyyy-MM-dd"),
            status = "Partial"
        };
        recoveryTempDate = DateTime.Now;
        recoveryErrorMessage = null;
        showRecoveryModal = true;
    }

    private void HideRecoveryForm()
    {
        showRecoveryModal = false;
    }

    private async Task OnRecoveryFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            recoveryModel.file = file.Name;
        }
    }

    private async Task SaveRecoveryInSale()
    {
        if (recoveryTempDate.HasValue)
        {
            recoveryModel.date = recoveryTempDate.Value.ToString("yyyy-MM-dd");
        }

        if (recoverySelectedCustomer == null)
        {
            recoveryErrorMessage = "Please select a customer first.";
            return;
        }

        if (recoveryCustomerCredit == null)
        {
            recoveryErrorMessage = "No credit record found for this customer.";
            return;
        }
        if (recoveryModel.paid <= 0)
        {
            recoveryErrorMessage = "Paid amount must be greater than zero.";
            return;
        }
        if (recoveryModel.paid > recoveryCustomerCredit.remaining)
        {
            recoveryErrorMessage = "Paid amount cannot exceed remaining credit.";
            return;
        }

        isRecoverySubmitting = true;
        try
        {
            using var context = DbFactory.CreateDbContext();
            var creditToUpdate = await context.credits.FindAsync(recoveryCustomerCredit.id);
            if (creditToUpdate != null)
            {
                creditToUpdate.total_credit -= recoveryModel.paid;
                creditToUpdate.remaining -= recoveryModel.paid;
                if (creditToUpdate.remaining <= 0)
                {
                    creditToUpdate.status = "Paid";
                }
            }

            recoveryModel.customer_id = recoverySelectedCustomer.id;
            recoveryModel.credit_id = recoveryCustomerCredit.id;
            recoveryModel.total_credit = recoveryCustomerCredit.total_credit;
            recoveryModel.due = recoveryCustomerCredit.remaining;
            recoveryModel.remaining = recoveryCustomerCredit.remaining - recoveryModel.paid;
            context.recoveries.Add(recoveryModel);

            await context.SaveChangesAsync();

            await JSRuntime.InvokeVoidAsync("showToast", "Success", "Recovery saved successfully!", "success");
            HideRecoveryForm();

            // Reload the credit to reflect changes
            using var refreshCtx = DbFactory.CreateDbContext();
            if (selectedCustomer != null)
            {
                loadedCredit = await refreshCtx.credits.FirstOrDefaultAsync(c => c.customer_id == selectedCustomer.id);
            }
            if (creditSelectedCustomer != null)
            {
                loadedCredit = await refreshCtx.credits.FirstOrDefaultAsync(c => c.customer_id == creditSelectedCustomer.id);
            }

            recoveryErrorMessage = null;
        }
        catch (Exception ex)
        {
            recoveryErrorMessage = "Error saving recovery: " + ex.Message;
        }
        finally
        {
            isRecoverySubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool showPaymentModal = false;
    private bool showAddCustomerModal = false;
    private string paymentMethod = "Cash";
    private decimal? tenderedAmount = null;
    private string notes = "";
    private bool shouldPrintReceipt = true;
    private bool isSubmitting = false;
    private string orderInvNo = "";
    private ReceiptSnapshot? _receiptSnapshot;
    private DotNetObjectReference<SaleEditor>? _dotNetRef;
    private bool _resetAfterPrint = false;
    private customers newCustomer = new customers { status = "Active" };
    private StoreConfiguration? currentStore;
    private bool isLoading = true;

    // ── Credit Modal State ────────────────────────────────────────────────────
    private bool showCreditModal = false;
    private CreditEntry creditEntry = new();
    private decimal creditRemainingAmount = 0;
    private string? creditCustomerSearch;
    private bool showCreditCustomerDropdown = false;
    private List<customers> filteredCreditCustomers = new();
    private customers? creditSelectedCustomer;
    private Credit? loadedCredit;
    private decimal additionalPayment = 0;
    private IBrowserFile? additionalPaymentBrowserFile;
    private string? additionalPaymentFileName;

    [Parameter] public string? UserEmail { get; set; }

    private void HandleAdditionalPaymentFile(InputFileChangeEventArgs e)
    {
        additionalPaymentBrowserFile = e.File;
        additionalPaymentFileName = e.File.Name;
    }

    private void HandleCreditEntryFile(InputFileChangeEventArgs e)
    {
        creditEntry.file_browser = e.File;
        creditEntry.file = e.File.Name;
    }

    private async Task<string?> SaveFileAsync(IBrowserFile? file)
    {
        if (file == null) return null;
        try
        {
            var uploads = Path.Combine(WebHostEnvironment.WebRootPath, "credit-files");
            if (!Directory.Exists(uploads)) Directory.CreateDirectory(uploads);
            
            var ext = Path.GetExtension(file.Name);
            var newFileName = $"credit_{DateTime.Now.Ticks}{ext}";
            var path = Path.Combine(uploads, newFileName);
            
            using var fs = new FileStream(path, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 10485760).CopyToAsync(fs); // 10MB limit
            
            return $"/credit-files/{newFileName}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"File upload error: {ex.Message}");
            return null;
        }
    }
    [Parameter] public string? UserName { get; set; }

    // ── Init ──────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await CurrencyService.GetSymbolAsync();
        _ = LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("saleReceiptPrint.init", _dotNetRef);
        }
    }

    public void Dispose() => _dotNetRef?.Dispose();

    [JSInvokable]
    public void OnReceiptPrintFinished()
    {
        _receiptSnapshot = null;
        if (_resetAfterPrint)
        {
            ResetComponent();
            _resetAfterPrint = false;
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = DbFactory.CreateDbContext();

            var prodsData = await context.products_services
                .AsNoTracking()
                .Where(p => p.status == "Enable")
                .GroupJoin(
                    context.stock_details.AsNoTracking(),
                    p => p.barcode,
                    s => s.item_barcode,
                    (p, s) => new { p, stock = s.OrderByDescending(x => x.id).FirstOrDefault() }
                )
                .Select(x => new
                {
                    x.p.id,
                    x.p.prod_name,
                    x.p.pic,
                    x.p.barcode,
                    x.p.expiry_date,
                    x.p.item_type,
                    sale_price = x.stock != null ? x.stock.sale_price : 0,
                    stock_qty = x.stock != null ? x.stock.quantity : 0
                })
                .OrderByDescending(p => p.id)
                .Take(100)
                .ToListAsync();

            allCustomersList = await context.customers
                .AsNoTracking()
                .OrderBy(c => c.name)
                .Take(100)
                .ToListAsync();

            currentStore = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();

            allProducts = prodsData.Select(p =>
            {
                bool isSvc = p.item_type == "Service";
                return new ProductDisplay
                {
                    Id = p.id,
                    Name = p.prod_name ?? "",
                    Price = p.sale_price,
                    Stock = Math.Max(0, p.stock_qty),
                    IsService = isSvc,
                    Image = p.pic,
                    Category = isSvc ? "Beverages" : "Foods",
                    Barcode = p.barcode
                };
            }).ToList();

            filteredProducts = allProducts;
            filteredCustomersList = allCustomersList;
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilters()
    {
        var query = allProducts.AsEnumerable();

        if (productTypeFilter != "All")
        {
            bool isSvc = productTypeFilter == "Service";
            query = query.Where(p => p.IsService == isSvc);
        }

        if (selectedCategory != "all")
            query = query.Where(p => p.Category == selectedCategory);

        if (!string.IsNullOrEmpty(searchQuery) && searchType == "item")
        {
            var s = searchQuery.ToLower();
            query = query.Where(p =>
                p.Name.ToLower().Contains(s) ||
                (p.Barcode != null && p.Barcode.ToLower() == s));
        }

        filteredProducts = query.ToList();
    }

    private void SetCategory(string cat) { selectedCategory = cat; ApplyFilters(); }
    private void SetProductType(string type) { productTypeFilter = type; selectedCategory = "all"; ApplyFilters(); }
    private void ToggleScanMenu() => showScanMenu = !showScanMenu;
    private void SetSearchType(string type) { searchType = type; showScanMenu = false; searchQuery = ""; ApplyFilters(); }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(searchQuery)) return;

        if (searchType == "receipt" && e.Key == "Enter")
        {
            _ = LoadFromReceipt(searchQuery);
            searchQuery = "";
        }
        else if (searchType == "item")
        {
            ApplyFilters();
            var exact = allProducts.FirstOrDefault(p =>
                p.Barcode != null && p.Barcode.ToLower() == searchQuery.ToLower());

            if (exact != null)
            {
                if (transMode == "return")
                {
                    // Check if we've loaded a receipt first
                    if (_loadedSaleHeaderId.HasValue)
                    {
                        // Find the item in already loaded items (from receipt)
                        var loadedItem = saleItems.FirstOrDefault(i => i.prod_name_service == exact.Name);
                        if (loadedItem != null)
                        {
                            // In return mode: decrease the negative quantity (make it less negative)
                            loadedItem.qty += 1;
                            if (loadedItem.qty == 0)
                                saleItems.Remove(loadedItem);
                            else
                                loadedItem.total_price = (loadedItem.price * loadedItem.qty) - (loadedItem.discount * loadedItem.qty);
                        }
                        else
                        {
                            ShowAlert("This item is not in the loaded receipt.");
                        }
                    }
                    else
                    {
                        // Add to return directly (no receipt)
                        AddToSale(exact, true);
                    }
                }
                else
                {
                    AddToSale(exact);
                }

                searchQuery = "";
                ApplyFilters();
            }
        }
    }

    private async Task LoadFromReceipt(string invNo)
    {
        if (string.IsNullOrWhiteSpace(invNo))
            return;

        invNo = invNo.Trim();
        using var context = DbFactory.CreateDbContext();

        if (invNo.StartsWith("SALE_", StringComparison.OrdinalIgnoreCase))
        {
            var parts = invNo.Split('_');
            if (parts.Length < 2 || !int.TryParse(parts[1], out int saleHeaderId))
            {
                ShowAlert("Invalid sale receipt format.");
                return;
            }

            var headerById = await context.SalesHeader.FindAsync(saleHeaderId);
            if (headerById != null)
            {
                if (headerById.payment_method == "Credit")
                {
                    loadedCredit = await context.credits
                        .Where(c => c.customer_id == headerById.customer_id && c.status != "Paid")
                        .FirstOrDefaultAsync();
                    await LoadSaleHeaderForReturn(context, headerById); // Always load for return when scanning receipt!
                    return;
                }

                await LoadSaleHeaderForReturn(context, headerById);
                return;
            }
        }

        var header = await context.SalesHeader
            .FirstOrDefaultAsync(s => s.inv_no == invNo);

        if (header == null)
        {
            ShowAlert("Receipt not found.");
            return;
        }

        await LoadSaleHeaderForReturn(context, header);
    }

    private async Task LoadSaleHeaderForView(ApplicationDbContext context, SaleHeader header)
    {
        var details = await context.sales.Where(d => d.sale_id == header.id).ToListAsync();
        if (!details.Any())
        {
            ShowAlert("No items found for this sale.");
            return;
        }

        var itemIds = details.Select(d => d.item_id).Distinct().ToList();
        var products = await context.products_services
            .Where(p => itemIds.Contains(p.id))
            .ToDictionaryAsync(p => p.id, p => p.prod_name ?? "Item #" + p.id);

        transMode = "sale";
        saleItems = details.Select(d => new SaleItem
        {
            prod_name_service = products.ContainsKey(d.item_id) ? products[d.item_id] : "Item #" + d.item_id,
            qty = Math.Abs(d.qty),
            price = Math.Abs(d.unit_price),
            discount = 0,
            maxStock = 99999,
            total_price = Math.Abs(d.total_price),
            OriginalSaleId = d.id
        }).ToList();

        StateHasChanged();
        await Task.CompletedTask;
    }

    // Track loaded sale header ID for returns
    private int? _loadedSaleHeaderId = null;

    private async Task LoadSaleHeaderForReturn(ApplicationDbContext context, SaleHeader header)
    {
        var details = await context.sales.Where(d => d.sale_id == header.id).ToListAsync();
        if (!details.Any())
        {
            ShowAlert("No items found for this sale.");
            return;
        }

        var itemIds = details.Select(d => d.item_id).Distinct().ToList();
        var products = await context.products_services
            .Where(p => itemIds.Contains(p.id))
            .ToDictionaryAsync(p => p.id, p => p.prod_name ?? "Item #" + p.id);

        // Set selected customer from original sale
        if (header.customer_id.HasValue)
        {
            selectedCustomer = await context.customers.FindAsync(header.customer_id.Value);
            customerSearchQuery = selectedCustomer?.name ?? "";
        }

        // Check if original sale was a credit sale
        returnFromCredit = header.payment_method == "Credit";
        transMode = "return"; // Force to return mode
        _loadedSaleHeaderId = header.id; // Store sale header ID
        saleItems = details.Select(d => new SaleItem
        {
            prod_name_service = products.ContainsKey(d.item_id) ? products[d.item_id] : "Item #" + d.item_id,
            qty = -Math.Abs(d.qty),
            price = Math.Abs(d.unit_price),
            discount = 0,
            maxStock = Math.Abs(d.qty),
            total_price = -Math.Abs(d.total_price),
            OriginalSaleId = d.id,
            OriginalSaleHeaderId = header.id // Set sale header ID
        }).ToList();

        StateHasChanged();
        await Task.CompletedTask;
    }

    private int? ResolveCurrentUserId(ApplicationDbContext context)
    {
        if (string.IsNullOrWhiteSpace(UserName))
            return null;

        var user = context.users.AsNoTracking()
            .FirstOrDefault(u => u.username == UserName || u.email == UserName);
        return user?.id;
    }

    private void AddToSale(ProductDisplay p, bool isReturnWithoutReceipt = false)
    {
        if (transMode == "return" && !isReturnWithoutReceipt && !_loadedSaleHeaderId.HasValue)
        {
            ShowAlert("First scan the receipt, then scan items to return!");
            return;
        }
        
        int qty = transMode == "return" ? -1 : 1;
        var existing = saleItems.FirstOrDefault(i => i.prod_name_service == p.Name);

        if (existing != null)
        {
            if (transMode != "return" && (existing.qty + 1) > p.Stock)
            {
                ShowAlert("Insufficient stock.");
                return;
            }
            existing.qty += qty;
            existing.total_price = (existing.price * existing.qty) - (existing.discount * existing.qty);
            if (existing.qty == 0)
                saleItems.Remove(existing);
        }
        else
        {
            if (transMode != "return" && p.Stock < 1)
            {
                ShowAlert("Out of stock.");
                return;
            }

            saleItems.Add(new SaleItem
            {
                prod_name_service = p.Name,
                qty = qty,
                price = p.Price,
                discount = p.Discount,
                expiry_date = p.Expiry,
                maxStock = transMode == "return" ? 1 : p.Stock,
                image = p.Image,
                total_price = (p.Price * qty) - (p.Discount * qty),
                OriginalSaleId = 0,
                OriginalSaleHeaderId = 0
            });
        }
    }

