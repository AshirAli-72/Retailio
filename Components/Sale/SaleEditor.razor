@namespace E_Invoice_system.Components.Sale
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="pos-container-v2" @onclick="CloseDropdowns">
    <!-- PRODUCT CANVAS (LEFT) -->
    <div class="product-canvas">
        <div class="canvas-header">
            <div class="canvas-header-top" style="justify-content: flex-start; gap: 24px;">
                <h3 class="canvas-title" style="margin: 0; white-space: nowrap;">Sales Transaction</h3>
                
                <div class="search-bar-v2">
                    <i class="ph-magnifying-glass"></i>
                    <input type="text" placeholder="@(searchType == "item" ? "Scan by item barcode" : "Scan by receipt barcode")" 
                           @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearchEnter" />
                </div>

                <div class="scan-dropdown-wrapper">
                    <button type="button" class="btn-scan-type-v3" @onclick="ToggleScanMenu" @onclick:stopPropagation>
                        <i class="ph-magnifying-glass"></i>
                        <span>Scan Item</span>
                        <i class="ph-caret-down"></i>
                    </button>
                    <div class="scan-type-menu @(showScanMenu ? "show" : "")" style="right: 0; left: auto;">
                        <div class="scan-type-item @(searchType == "item" ? "active" : "")" @onclick='() => SetSearchType("item")'>
                            <i class="ph-barcode"></i> Scan Barcode
                        </div>
                        <div class="scan-type-item @(searchType == "receipt" ? "active" : "")" @onclick='() => SetSearchType("receipt")'>
                            <i class="ph-receipt"></i> Scan Receipt
                        </div>
                    </div>
                </div>
                
                <div class="quick-actions-v2" style="margin-left: auto;">
                    <button type="button" class="btn-action-round" @onclick='ResetComponent' title="Clean Form"><i class="ph-arrows-clockwise"></i></button>
                    <button type="button" class="btn-action-round" @onclick="ToggleFullScreen" title="Full Screen"><i class="ph-corners-out"></i></button>
                    <a href="/Sale/Index" class="btn-action-round back" title="Back to List"><i class="ph-arrow-left"></i></a>
                </div>
            </div>
        </div>

        <div class="category-tabs-v2">
            <div class="tab-item @(productTypeFilter == "All" && selectedCategory == "all" ? "active" : "")" @onclick='() => { productTypeFilter = "All"; SetCategory("all"); }'>All</div>
            <div class="tab-item @(productTypeFilter == "Product" ? "active" : "")" @onclick='() => SetProductType("Product")'>Products</div>
            <div class="tab-item @(productTypeFilter == "Service" ? "active" : "")" @onclick='() => SetProductType("Service")'>Services</div>
            
            @if (allProducts.Any(p => p.Category != "Foods" && p.Category != "Beverages"))
            {
                <div style="width: 2px; height: 24px; background: #e2e8f0; margin: 0 10px;"></div>
                @foreach (var cat in allProducts.Where(p => p.Category != "Foods" && p.Category != "Beverages").Select(p => p.Category).Distinct().Where(c => !string.IsNullOrEmpty(c)))
                {
                    <div class="tab-item @(selectedCategory == cat ? "active" : "")" @onclick='() => SetCategory(cat!)'>@cat</div>
                }
            }
        </div>

        <div class="product-grid-v2">
            @if (isLoading)
            {
                <div style="grid-column: 1 / -1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; color: var(--text-muted); text-align: center;">
                    <i class="ph-spinner-gap" style="font-size: 3.5rem; color: var(--primary); opacity: 0.8; animation: spin 1s linear infinite; margin-bottom: 16px;"></i>
                    <h3 style="margin: 0; font-weight: 700; color: var(--text-main);">Loading Products...</h3>
                    <p style="margin: 8px 0 0; font-size: 0.9rem;">Fetching real-time inventory and pricing</p>
                    
                </div>
            }
            else
            {
                @if (!filteredProducts.Any())
                {
                    <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                        <i class="ph-package" style="font-size: 3rem; margin-bottom: 12px; opacity: 0.5;"></i>
                        <h4>No products found</h4>
                    </div>
                }
                @foreach (var p in filteredProducts)
                {
                    <div class="product-card-v2 reveal-up @(p.Stock <= 0 ? "out-of-stock" : "")" @onclick="() => AddToSale(p)">
                        <div class="card-img-wrap">
                            @if (p.Stock <= 0)
                            {
                                <div class="out-of-stock-overlay">Out of Stock</div>
                            }  

                            @if (!string.IsNullOrEmpty(p.Image))
                            {
                                var fileName = System.IO.Path.GetFileName(p.Image);
                                <img src="/product-images/@fileName" alt="Product" onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4MCIgaGVpZ2h0PSI4MCI+PHJlY3Qgd2lkdGg9IjgwIiBoZWlnaHQ9IjgwIiBmaWxsPSIjZjFmNWY5Ii8+PC9zdmc+';" />
                            }
                            else
                            {
                                <i class="@(p.IsService ? "ph-wrench" : "ph-cube-transparent")" style="font-size:2.5rem;color:#cbd5e1;"></i>
                            }
                        </div>
                        <div class="card-content">
                            <h4 class="card-name">@p.Name</h4>
                            <div class="card-footer-info" style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                                <div class="price-tag">@FormatCurrency(p.Price)</div>
                                <div class="stock-badge @(p.Stock <= 5 ? "low-stock" : "")" style="font-size: 0.75rem; font-weight: 700; color: @(p.Stock <= 0 ? "#ef4444" : (p.Stock <= 5 ? "#f97316" : "#64748b"))">
                                    Stock: @p.Stock
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- CHECKOUT PANEL (RIGHT) -->
    <div class="checkout-panel-v2">
        <div class="checkout-header-v2">
            <div>
                <h2>Order Detail</h2>
                <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted);">@saleItems.Count item@(saleItems.Count != 1 ? "s" : "") selected</div>
            </div>
            <div style="display:flex; gap: 8px;">
                <div class="mode-toggle-v2">
                    <div class="toggle-pill">
                        <button type="button" class="tab-item @(transMode == "sale" ? "active" : "")" style="padding: 6px 16px; font-size: 0.8rem;" @onclick='() => SetTransMode("sale")'>Sale</button>
                        <button type="button" class="tab-item @(transMode == "return" ? "active" : "")" style="padding: 6px 16px; font-size: 0.8rem;" @onclick='() => SetTransMode("return")'>Return</button>
                    </div>
                </div>
                <button type="button" class="btn-action-round" style="color:var(--danger); background: #fee2e2; border:none;" @onclick="ClearSaleItems">
                    <i class="ph-trash"></i>
                </button>
            </div>
        </div>

        @if (transMode == "return")
        {
            <div style="margin: 0 24px 12px; padding: 10px; background: #fee2e2; color: #991b1b; border-radius: 12px; font-weight: 700; font-size: 0.75rem; text-align: center;">
                <i class="ph-warning"></i> RETURN MODE ACTIVE
            </div>
        }

        <!-- Customer Selector -->
        <div class="customer-selector-v2">
            <div class="select-wrapper-v2">
                <i class="ph-user-circle"></i>
                <input type="text" class="customer-search-input" placeholder="Search Customer..." 
                       @bind="customerSearchQuery" @bind:event="oninput" @bind:after="FilterCustomers"
                       @onfocus="OnCustomerSearchFocus" 
                       @onclick:stopPropagation />
                
                @if (showCustomerDropdown)
                {
                    <div class="customer-dropdown-results show" @onclick:stopPropagation>
                        @if (!filteredCustomersList.Any())
                        {
                            <div class="no-results">No customers found</div>
                        }
                        @foreach (var c in filteredCustomersList)
                        {
                            <div class="customer-result-item" @onclick="() => SelectCustomer(c)" @onclick:stopPropagation>
                                <div class="cust-avatar">@(string.IsNullOrEmpty(c.name) ? "?" : c.name[0].ToString().ToUpper())</div>
                                <div class="cust-info">
                                    <span class="cust-name">@c.name</span>
                                    <span class="cust-contact">@c.contact</span>
                                </div>
                                @if (selectedCustomer?.id == c.id)
                                {
                                    <i class="ph-check-circle-fill" style="color: var(--success); margin-left: auto;"></i>
                                }
                            </div>
                        }
                    </div>
                }
                <i class="ph-caret-down" @onclick="ToggleCustomerDropdown" @onclick:stopPropagation style="cursor: pointer;"></i>
            </div>
            <button type="button" @onclick="() => showAddCustomerModal = true" class="btn-add-customer" title="Add New Customer">
                <i class="ph-plus-bold"></i>
            </button>
        </div>

            <!-- Items List -->
            <div class="checkout-items-v2">
                @foreach (var item in saleItems)
                {
                    <div class="item-v2 reveal-up">
                        <div class="item-v2-img">
                            @if (!string.IsNullOrEmpty(item.image))
                            {
                                var fileName = System.IO.Path.GetFileName(item.image);
                                <img src="/product-images/@fileName" alt="item" onerror="this.onerror=null;this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI4MCIgaGVpZ2h0PSI4MCI+PHJlY3Qgd2lkdGg9IjgwIiBoZWlnaHQ9IjgwIiBmaWxsPSIjZjFmNWY5Ii8+PC9zdmc+';" />
                            }
                            else
                            {
                                <i class="ph-package" style="font-size:1.5rem;color:#cbd5e1; display: flex; align-items: center; justify-content: center; height: 100%;"></i>
                            }
                        </div>
                    <div class="item-v2-info">
                        <div class="title">@item.prod_name_service</div>
                        <div class="price-input-container">
                            <span>@CurrencyService.GetSymbol()</span>
                            <input type="number" step="0.01" class="manual-price-input"
                                   @bind="item.price" @bind:after="() => CalculateSaleItemTotal(item)" />
                        </div>
                    </div>
                        <div class="item-v2-controls">
                            <div class="qty-stepper">
                                <button type="button" @onclick="() => DecreaseQty(item)">-</button>
                                <input type="number" class="manual-qty-input" 
                                       value="@item.qty" 
                                       @onchange="(e) => UpdateItemQty(item, e.Value?.ToString())" />
                                <button type="button" @onclick="() => IncreaseQty(item)">+</button>
                            </div>
                        </div>
                        <div class="item-total-info">
                            @FormatCurrency(item.total_price)
                        </div>
                        <i class="ph-trash btn-remove-item" @onclick="() => RemoveItem(item)"></i>
                    </div>
                }

                @if (!saleItems.Any())
                {
                    <div class="empty-state-v2">
                        <i class="ph-shopping-cart-simple"></i>
                        <p style="font-weight:700;">Bag is empty</p>
                    </div>
                }
            </div>

            <!-- Checkout Footer -->
            <div class="checkout-footer-v2">
                <div class="price-summary-v2">
                    <div class="summary-line"><span>Subtotal</span><span>@FormatCurrency(totalSub)</span></div>
                    <div class="summary-line" style="color:var(--success); font-weight: 800;"><span>Discount</span><span>- @FormatCurrency(totalDisc)</span></div>
                    
                    <div class="grand-total-row">
                        <div class="total-label">Grand Total</div>
                        <div class="total-value">@FormatCurrency(currentTotal)</div>
                    </div>
                </div>
                <button type="button" class="btn-pay-v2" @onclick="OpenPaymentModal">
                    <i class="ph-credit-card"></i> <span>Proceed to Payment</span>
                </button>
            </div>
        </div>
    </div>


<!-- PAYMENT MODAL -->
@if (showPaymentModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="payment-card">
            <div class="payment-left">
                <h1 class="payment-title">Checkout</h1>
                <p class="payment-subtitle">Complete your transaction by selecting a payment method.</p>
                <div class="method-tabs">
                    <div class="method-tab @(paymentMethod == "Cash" ? "active" : "")" @onclick='() => SetPaymentMethod("Cash")'><i class="ph-money"></i> <span>Cash</span></div>
                    <div class="method-tab @(paymentMethod == "Card" ? "active" : "")" @onclick='() => SetPaymentMethod("Card")'><i class="ph-credit-card"></i> <span>Card</span></div>
                    <div class="method-tab @(paymentMethod == "Transfer" ? "active" : "")" @onclick='() => SetPaymentMethod("Transfer")'><i class="ph-bank"></i> <span>Bank</span></div>
                    <div class="method-tab @(paymentMethod == "Credit" ? "active" : "")" @onclick='() => SetPaymentMethod("Credit")'><i class="ph-user-focus"></i> <span>Credit</span></div>
                </div>
                <div class="web-input-group">
                    <label>Amount Tendered</label>
                    <input type="number" class="web-input" step="0.01" @bind="tenderedAmount" @bind:event="oninput" placeholder="0.00" />
                    <div class="quick-pills">
                        @foreach (var amt in new[] { 10, 20, 50, 100, 500, 1000, 5000 })
                        {
                            <div class="quick-pill" @onclick="() => tenderedAmount = (tenderedAmount ?? 0) + amt">+ @CurrencyService.GetSymbol()@amt</div>
                        }
                        <div class="quick-pill" @onclick="() => tenderedAmount = Math.Abs(currentTotal)">Match Total</div>
                    </div>
                </div>
                <div class="web-input-group">
                    <label>Reference / Note</label>
                    <input type="text" class="web-input" @bind="notes" placeholder="Transaction notes (optional)" />
                </div>
            </div>
            <div class="payment-right">
                <div class="summary-box-web">
                    <div class="summary-web-line">
                        <span style="color:var(--text-muted);font-weight:600;">Total Amount Due</span>
                        <span style="font-weight:800; color: var(--text-main);">@FormatCurrency(currentTotal)</span>
                    </div>
                    <div class="summary-web-line" style="margin-top:8px;">
                        <span style="color:var(--text-muted);font-weight:600;">Total Tendered</span>
                        <span style="font-weight:800; color: var(--text-main);">@FormatCurrency(tenderedAmount ?? 0)</span>
                    </div>
                    @{
                        var change = (tenderedAmount ?? 0) - Math.Abs(currentTotal);
                        <div class="summary-web-line grand">
                            <span>Change Due</span>
                            <span style="color: @(change >= 0 ? "var(--success)" : "var(--danger)")">@FormatCurrency(Math.Abs(change))</span>
                        </div>
                    }
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding:12px 16px;background:var(--surface);border-radius:14px;box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);">
                        <label style="font-weight:800;color:var(--text-main);cursor:pointer;display:flex;align-items:center;gap:8px;font-size:0.9rem;">
                            <i class="ph-printer" style="font-size:1.25rem;color:var(--primary);"></i> Print Receipt
                        </label>
                        <input type="checkbox" style="width:20px;height:20px;cursor:pointer;accent-color:var(--primary);" @bind="shouldPrintReceipt" />
                    </div>
                </div>
                <div style="margin-top:auto;">
                    <p style="font-size:.8rem;color:var(--text-muted);text-align:center;margin-bottom:24px;line-height:1.5;font-weight:600;">
                        By completing this order, you agree to generate an official invoice and update stock levels.
                    </p>
                    <div style="display:flex;gap:12px;">
                        <button type="button" class="btn-confirm-web cancel" style="flex:1;" @onclick="() => showPaymentModal = false">Cancel</button>
                        <button type="button" class="btn-confirm-web confirm @(isSubmitting ? "processing" : "")" style="flex:1;" @onclick="SubmitSale" disabled="@isSubmitting">
                            @if (isSubmitting) { <i class="ph-spinner ph-spin"></i> }
                            else { <span>Complete Order</span> }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (showAddCustomerModal)
{
    <div class="modal-overlay show" style="display: flex;">
        <div class="customer-modal-v3">
            <div class="c-modal-header">
                <div class="c-modal-title">
                    <i class="ph-user-plus-bold" style="color: #BC1823; font-size: 1.5rem;"></i>
                    <span>Add New Customer</span>
                </div>
                <button type="button" class="c-modal-close" @onclick="() => showAddCustomerModal = false"><i class="ph-x"></i></button>
            </div>

            <div class="c-modal-body">
                <div class="c-form-group">
                    <label>Full Name</label>
                    <input type="text" @bind="newCustomer.name" placeholder="Enter customer's full name" />
                </div>
                <div class="c-form-group">
                    <label>Contact Number</label>
                    <input type="text" @bind="newCustomer.contact" placeholder="Enter contact number" />
                </div>
                <div class="c-form-group">
                    <label>Email Address</label>
                    <input type="email" @bind="newCustomer.email" placeholder="Enter email address" />
                </div>
                <div class="c-form-group">
                    <label>Address</label>
                    <textarea rows="3" @bind="newCustomer.address" placeholder="Enter physical address"></textarea>
                </div>
                <div class="c-form-group">
                    <label>Status</label>
                    <div class="c-select-wrapper">
                        <select @bind="newCustomer.status">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <i class="ph-caret-down"></i>
                    </div>
                </div>
            </div>

            <div class="c-modal-footer">
                <button type="button" class="btn-c-cancel" @onclick="() => showAddCustomerModal = false">Cancel</button>
                <button type="button" class="btn-c-save" @onclick="SaveNewCustomer">
                    <i class="ph-check-bold"></i> Save Customer
                </button>
            </div>
        </div>
    </div>
}

<!-- MODERN INVOICE DESIGN (MOCKUP MATCH) -->
<div id="invoice-to-print" class="receipt-hidden">
    <div class="thermal-receipt">
        <div class="rcpt-header">
            @if (!string.IsNullOrEmpty(currentStore?.LogoPath))
            {
                <img src="/store-logo/@System.IO.Path.GetFileName(currentStore.LogoPath)" alt="Logo" class="rcpt-logo" />
            }
            <p class="rcpt-store-info">@(currentStore?.Address ?? "Gilgit, Pakistan")</p>
            <p class="rcpt-store-info">Phone: @(currentStore?.Phone1 ?? "+92 345 6781267")</p>
            <div class="rcpt-divider"></div>
            <h3 class="rcpt-title">@(transMode == "return" ? "RETURN RECEIPT" : "SALE RECEIPT")</h3>
        </div>

        <div class="rcpt-meta">
            <div class="rcpt-meta-row"><span>Bill No:</span> <span>@orderBillNo</span></div>
            <div class="rcpt-meta-row"><span>Date:</span> <span>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span></div>
            <div class="rcpt-meta-row"><span>Customer:</span> <span>@(selectedCustomer?.name ?? "Walking Customer")</span></div>
            <div class="rcpt-meta-row"><span>Payment:</span> <span>@paymentMethod</span></div>
        </div>

        <div class="rcpt-divider"></div>

        <table class="rcpt-table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th style="text-align:center;">Qty</th>
                    <th style="text-align:right;">Price</th>
                    <th style="text-align:right;">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in saleItems)
                {
                    <tr>
                        <td colspan="4" class="rcpt-item-name">@item.prod_name_service</td>
                    </tr>
                    <tr class="rcpt-item-details">
                        <td></td>
                        <td style="text-align:center;">@Math.Abs(item.qty)</td>
                        <td style="text-align:right;">@item.price.ToString("N2")</td>
                        <td style="text-align:right;">@((item.price * Math.Abs(item.qty)).ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="rcpt-divider"></div>

        <div class="rcpt-summary">
            <div class="rcpt-sum-row"><span>Subtotal:</span> <span>@FormatCurrency(totalSub)</span></div>
            <div class="rcpt-sum-row"><span>Discount:</span> <span>-@FormatCurrency(totalDisc)</span></div>
            <div class="rcpt-sum-row total"><span>TOTAL:</span> <span>@FormatCurrency(currentTotal)</span></div>
        </div>

        <div class="rcpt-footer">
            <div class="rcpt-divider"></div>
            <p>Thank You For Your Business!</p>
            <div class="rcpt-barcode-wrap">
                <svg id="rcptBarcodeSvg"></svg>
            </div>
            <p class="rcpt-tagline">Powered by SATA Technologies</p>
        </div>
    </div>
</div>

<link href="/css/sale/create.css" rel="stylesheet" />



@code {
    private List<ProductDisplay> allProducts = new();
    private List<ProductDisplay> filteredProducts = new();
    private List<customers> allCustomersList = new();
    private List<customers> filteredCustomersList = new();
    private List<SaleItem> saleItems = new();

    private string searchQuery = "";
    private string searchType = "item"; // item or receipt
    private bool showScanMenu = false;
    private string productTypeFilter = "All"; // All, Product, or Service
    private string selectedCategory = "all";
    private string transMode = "sale";
    private string? customerSearchQuery;
    private customers? selectedCustomer;
    private bool showCustomerDropdown = false;
    private bool showPaymentModal = false;
    private bool showAddCustomerModal = false;
    private string paymentMethod = "Cash";
    private decimal? tenderedAmount = null;
    private string notes = "";  
    private bool shouldPrintReceipt = true;
    private string? stockAlert;
    private bool isSubmitting = false;
    private string orderBillNo = "";
    private customers newCustomer = new customers { status = "Active" };
    private StoreConfiguration? currentStore;

    [Parameter] public string? UserEmail { get; set; }
    [Parameter] public string? UserName { get; set; }

    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Prime currency symbol before data loading
        await CurrencyService.GetSymbolAsync();

        // Non-blocking initialization so the UI renders instantly
        _ = LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try 
        {
            using var context = DbFactory.CreateDbContext();
            // Sequential data fetching to avoid EF Core concurrency issues
            var prodsData = await context.products_services
                .AsNoTracking()
                .Where(p => p.status == "Enable")
                .GroupJoin(
                    context.stock_details.AsNoTracking(),
                    p => p.barcode,
                    s => s.item_barcode,
                    (p, s) => new { p, stock = s.OrderByDescending(x => x.id).FirstOrDefault() }
                )
                .Select(x => new { 
                    x.p.id, x.p.prod_name, x.p.pic, x.p.barcode,
                    x.p.expiry_date, x.p.prod_state, x.p.unit, x.p.size, x.p.item_type,
                    x.p.category_id, x.p.brand_id,
                    sale_price = x.stock != null ? x.stock.sale_price : 0,
                    stock_qty = x.stock != null ? x.stock.quantity : 0
                })
                .OrderByDescending(p => p.id)
                .Take(50) 
                .ToListAsync();

            allCustomersList = await context.customers
                .AsNoTracking()
                .OrderBy(c => c.name)
                .Take(50) 
                .ToListAsync();

            currentStore = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();

            allProducts = prodsData.Select(p => {
                int stock = Math.Max(0, p.stock_qty);
                bool isSvc = p.item_type == "Service";
                return new ProductDisplay { 
                    Id = p.id, Name = p.prod_name ?? "", Price = p.sale_price, Discount = 0, 
                    Expiry = p.expiry_date, Stock = stock, IsService = isSvc, Image = p.pic, 
                    Category = isSvc ? "Beverages" : "Foods", Barcode = p.barcode 
                };
            }).ToList();
            
            filteredProducts = allProducts;
            filteredCustomersList = allCustomersList;
            ApplyFilters();

            // Optional: simulate network delay briefly for skeleton testing if desired
            // await Task.Delay(500);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally 
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyFilters()
    {
        var query = allProducts.AsEnumerable();

        // 1. Product/Service Type Filter
        if (productTypeFilter != "All") {
            bool isSvc = productTypeFilter == "Service";
            query = query.Where(p => p.IsService == isSvc);
        }

        // 2. Category Filter
        if (selectedCategory != "all") {
            query = query.Where(p => p.Category == selectedCategory);
        }
        
        // 3. Search Filter (if any)
        if (!string.IsNullOrEmpty(searchQuery) && searchType == "item") {
            var s = searchQuery.ToLower();
            query = query.Where(p => p.Name.ToLower().Contains(s) || (p.Barcode != null && p.Barcode.ToLower() == s));
        }

        filteredProducts = query.ToList();
    }

    private void SetCategory(string cat)
    {
        selectedCategory = cat;
        ApplyFilters();
    }

    private void SetProductType(string type)
    {
        productTypeFilter = type;
        selectedCategory = "all"; // Reset category when switching types
        ApplyFilters();
    }

    private void ToggleScanMenu() => showScanMenu = !showScanMenu;

    private void SetSearchType(string type)
    {
        searchType = type;
        showScanMenu = false;
        searchQuery = "";
        ApplyFilters();
    }

    private void HandleSearchEnter(KeyboardEventArgs e) => HandleSearchKeyUp(e);

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(searchQuery)) return;

        // Auto-detect Receipt Scan (SALE_ or RETURN_)
        if (searchQuery.ToUpper().StartsWith("SALE_") || searchQuery.ToUpper().StartsWith("RETURN_")) {
            _ = LoadFromReceipt(searchQuery);
            searchQuery = "";
            return;
        }

        if (searchType == "item") {
            ApplyFilters();
            
            var query = searchQuery.ToLower();
            var exact = allProducts.FirstOrDefault(p => p.Barcode != null && p.Barcode.ToLower() == query);
            if (exact != null) {
                AddToSale(exact);
                searchQuery = "";
                ApplyFilters();
            }
        } else if (e.Key == "Enter" && searchType == "receipt") {
            _ = LoadFromReceipt(searchQuery);
            searchQuery = "";
        }
    }

    private async Task LoadFromReceipt(string billNo)
    {
        using var context = DbFactory.CreateDbContext();
        var sales = await context.sales.Where(s => s.billNo == billNo).ToListAsync();
        if (sales.Any()) {
            transMode = "return";
            saleItems = sales.Select(s => {
                string prodName = "Item #" + s.id;
                if (!string.IsNullOrEmpty(s.description))
                {
                    var parts = s.description.Split(new[] { " | " }, StringSplitOptions.None);
                    if (parts.Length > 0 && !string.IsNullOrWhiteSpace(parts[0]))
                    {
                        prodName = parts[0];
                    }
                }
                return new SaleItem {
                    prod_name_service = prodName,
                    qty = -s.qty,
                    price = s.price,
                    discount = s.qty != 0 ? s.discount / s.qty : 0,
                    expiry_date = s.expiry_date,
                    maxStock = s.qty,
                    total_price = Math.Abs(s.total_price),
                    OriginalSaleId = s.id
                };
            }).ToList();
            StateHasChanged();
        }
    }

    private void AddToSale(ProductDisplay p)
    {
        int qty = transMode == "return" ? -1 : 1;
        var existing = saleItems.FirstOrDefault(i => i.prod_name_service == p.Name);
        if (existing != null) {
            if (transMode == "sale" && (existing.qty + 1) > p.Stock) { ShowAlert("Insufficient stock."); return; }
            existing.qty += qty;
            if (existing.qty == 0) saleItems.Remove(existing);
            else existing.total_price = (existing.price * existing.qty) - (existing.discount * existing.qty);
        } else {
            if (transMode == "sale" && p.Stock < 1) { ShowAlert("Out of stock."); return; }
            saleItems.Add(new SaleItem {
                prod_name_service = p.Name, qty = qty, 
                price = p.Price, discount = p.Discount, expiry_date = p.Expiry, 
                maxStock = p.Stock, image = p.Image, total_price = (p.Price * qty) - (p.Discount * qty)
            });
        }
    }

    private void RemoveItem(SaleItem i) { saleItems.Remove(i); }

    private void ClearSaleItems() { saleItems.Clear(); }

    private void CloseDropdowns() { showCustomerDropdown = false; showScanMenu = false; }
    
    private async Task ToggleCustomerDropdown() {
        showCustomerDropdown = !showCustomerDropdown;
        if (showCustomerDropdown) await FilterCustomers();
    }

    private void SetTransMode(string mode) {
        transMode = mode;
        foreach (var item in saleItems) {
            int abs = Math.Abs(item.qty);
            item.qty = mode == "return" ? -abs : abs;
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        }
    }

    private async Task OnCustomerSearchFocus() {
        showCustomerDropdown = true;
        await FilterCustomers();
    }

    private async Task FilterCustomers() {
        showCustomerDropdown = true;
        if (string.IsNullOrEmpty(customerSearchQuery)) {
            filteredCustomersList = allCustomersList;
            selectedCustomer = null; 
        }
        else {
            var q = customerSearchQuery.ToLower();
            using var context = DbFactory.CreateDbContext();
            filteredCustomersList = await context.customers
                .AsNoTracking()
                .Where(c => c.name.ToLower().Contains(q) || (c.contact != null && c.contact.ToLower().Contains(q)))
                .Take(50)
                .ToListAsync();
        }
        StateHasChanged();
    }

    private void SelectCustomer(customers c) { selectedCustomer = c; customerSearchQuery = c.name; showCustomerDropdown = false; }

    private void UpdateItemQty(SaleItem item, string? val) {
        if (int.TryParse(val, out int q)) {
            q = Math.Abs(q);
            if (transMode == "return") q = -q;
            if (q == 0) { saleItems.Remove(item); return; }
            if (transMode == "sale" && q > item.maxStock) { ShowAlert("Stock limit reached."); return; }
            item.qty = q;
            item.total_price = (item.price * item.qty) - (item.discount * item.qty);
        }
    }

    private void CalculateSaleItemTotal(SaleItem item) {
        item.total_price = (item.price * item.qty) - (item.discount * item.qty);
    }

    private void IncreaseQty(SaleItem i) => UpdateItemQty(i, (Math.Abs(i.qty) + 1).ToString());
    private void DecreaseQty(SaleItem i) => UpdateItemQty(i, (Math.Abs(i.qty) - 1).ToString());

    private decimal totalSub => saleItems.Sum(i => i.price * i.qty);
    private decimal totalDisc => saleItems.Sum(i => i.discount * i.qty);
    private decimal currentTotal => totalSub - totalDisc;

    private void OpenPaymentModal() { if (!saleItems.Any()) return; showPaymentModal = true; tenderedAmount = null; }

    private void SetPaymentMethod(string m) { paymentMethod = m; }

    private void ShowAlert(string msg) { _ = JSRuntime.InvokeVoidAsync("showToast", "Notice", msg, "warning"); }

    private async Task SaveNewCustomer() {
        if (string.IsNullOrEmpty(newCustomer.name)) return;
        using var context = DbFactory.CreateDbContext();
        context.customers.Add(newCustomer);
        await context.SaveChangesAsync();
        await JSRuntime.InvokeVoidAsync("showToast", "Success", "Customer created successfully!", "success");
        allCustomersList.Add(newCustomer);
        SelectCustomer(newCustomer);
        newCustomer = new customers { status = "Active" };
        showAddCustomerModal = false;
    }

    private async Task SubmitSale() {
        if (isSubmitting) return;
        if (!saleItems.Any()) { ShowAlert("Cannot complete an empty order."); return; }

        isSubmitting = true;
        try {
            using var context = DbFactory.CreateDbContext();
            
            // Get Current User ID (Check both username and email as session might store either)
            var user = await context.users.AsNoTracking()
                .FirstOrDefaultAsync(u => u.username == UserName || u.email == UserName);
            int? currentUserId = user?.id;

            int nextIdNum = 1;
            var prefix = transMode == "return" ? "RETURN_" : "SALE_";
            
            // OPTIMIZED: Fetch ONLY the most recent bill number instead of the entire list
            string? lastBillNo = null;
            if (transMode == "return") {
                lastBillNo = await context.returns
                    .Where(r => r.billNo != null && r.billNo.StartsWith(prefix))
                    .OrderByDescending(r => r.Id)
                    .Select(r => r.billNo)
                    .FirstOrDefaultAsync();
            } else {
                lastBillNo = await context.sales
                    .Where(s => s.billNo != null && s.billNo.StartsWith(prefix))
                    .OrderByDescending(s => s.id)
                    .Select(s => s.billNo)
                    .FirstOrDefaultAsync();
            }

            if (!string.IsNullOrEmpty(lastBillNo)) {
                var parts = lastBillNo.Split(new[] { '_', '-' });
                if (parts.Length > 1 && int.TryParse(parts[1], out int n)) nextIdNum = n + 1;
            }
            orderBillNo = $"{prefix}{nextIdNum}";

            
            string customerInfo = selectedCustomer != null ? $" [Customer: {selectedCustomer.name}]" : " [Walk-In]";
            string saleDescription = ((notes ?? "") + customerInfo);
            if (saleDescription.Length > 200) saleDescription = saleDescription.Substring(0, 200);

            // OPTIMIZED: Batch fetch all products in the sale at once instead of N times in loop
            var productNames = saleItems.Select(i => i.prod_name_service).Distinct().ToList();
            var productsInSale = await context.products_services
                .Where(p => productNames.Contains(p.prod_name))
                .ToListAsync();
            
            var barcodesInSale = productsInSale.Select(p => p.barcode).Where(b => b != null).ToList();
            var stocksToUpdate = await context.stock_details
                .Where(s => barcodesInSale.Contains(s.item_barcode))
                .ToListAsync();

            foreach (var item in saleItems) {
                if (transMode == "return") {
                    if (item.OriginalSaleId == 0) {
                        var recentSale = await context.sales
                            .Where(s => s.billNo != null && s.billNo.StartsWith("SALE_"))
                            .OrderByDescending(s => s.id)
                            .FirstOrDefaultAsync();
                        if (recentSale != null) {
                            item.OriginalSaleId = recentSale.id;
                        }
                    }

                    // Update original sale record to mark as returned
                    if (item.OriginalSaleId != 0) {
                        var originalSale = await context.sales.FindAsync(item.OriginalSaleId);
                        if (originalSale != null) {
                            originalSale.is_returned = true;
                            context.sales.Update(originalSale);
                        }
                    }

                    var returnRec = new Models.ReturnDetail {
                        billNo = orderBillNo,
                        SaleId = item.OriginalSaleId,
                        date = DateTime.Now.ToString("yyyy-MM-dd"),
                        no_of_items = saleItems.Count,
                        qty = Math.Abs(item.qty),
                        total_qty = saleItems.Sum(i => Math.Abs(i.qty)),
                        Amount = Math.Abs(item.total_price),
                        Method = paymentMethod,
                        Status = item.prod_name_service
                    };
                    context.returns.Add(returnRec);
                } else {
                    string itemDescription = selectedCustomer?.name ?? "Walk-In";
                    if (itemDescription.Length > 200) itemDescription = itemDescription.Substring(0, 200);

                    var sale = new Models.Sale {
                        billNo = orderBillNo, 
                        date = DateTime.Now.ToString("yyyy-MM-dd"), 
                        no_of_items = saleItems.Count,
                        qty = item.qty,
                        total_qty = saleItems.Sum(i => Math.Abs(i.qty)),
                        price = item.price,
                        discount = item.discount, 
                        total_price = item.total_price, 
                        payment_method = paymentMethod, 
                        status = (paymentMethod == "Credit" || paymentMethod == "Pending") ? "Pending" : "Paid",
                        is_returned = false, 
                        description = itemDescription,
                        expiry_date = item.expiry_date ?? DateTime.Now.ToString("yyyy-MM-dd")
                    };

                    context.sales.Add(sale);
                }
                
                // OPTIMIZED: Use cached stock lookup
                try {
                    var prod = productsInSale.FirstOrDefault(p => p.prod_name == item.prod_name_service);
                    if (prod != null && prod.barcode != null) {
                        var stock = stocksToUpdate.FirstOrDefault(s => s.item_barcode == prod.barcode);
                        if (stock != null) {
                            var newQty = stock.quantity - item.qty;
                            
                            // CRITICAL: Check inventory before allowing sale
                            if (transMode == "sale" && newQty < 0) {
                                throw new Exception($"Insufficient stock for {item.prod_name_service}. Available: {stock.quantity}");
                            }
                            
                            var oldQty = stock.quantity;
                            stock.quantity = newQty;
                            context.stock_details.Update(stock);

// Stock history removed
                        }
                    }
                } catch (Exception ex) { 
                    Console.WriteLine("Stock Update Error: " + ex.Message); 
                }
            }

            await context.SaveChangesAsync();
            
            // 1. Trigger Success Alert
            await JSRuntime.InvokeVoidAsync("window.showToast", "Success", "Transaction successfully completed!", "success");
            
            // 2. Capture required data for receipt before clearing/resetting
            var shouldPrint = shouldPrintReceipt;
            var billNo = orderBillNo;
            var mode = transMode;
            
            // 3. CLOSE MODAL IMMEDIATELY
            showPaymentModal = false;
            await InvokeAsync(StateHasChanged);
            
            // 4. PRINT (after a short delay to allow UI to update)
            if (shouldPrint) {
                try {
                    await Task.Delay(500); // Wait for data binding
                    
                    // Force the barcode to render
                    if (mode != "return") {
                        await JSRuntime.InvokeVoidAsync("renderBarcode", "rcptBarcodeSvg", billNo);
                    }
                    
                    await Task.Delay(300); // Wait for barcode
                    await JSRuntime.InvokeVoidAsync("window.print");
                } catch (Exception jsEx) {
                    Console.WriteLine("Print Error: " + jsEx.Message);
                }
            }

            // 5. AUTO-REFRESH: Reset the terminal cleanly without a hard reload to ensure print dialog finishes
            ResetComponent();
            await InvokeAsync(StateHasChanged);
        } catch (Exception ex) { 
            string errMessage = ex.Message;
            if (ex.InnerException != null) errMessage += " | " + ex.InnerException.Message;
            await JSRuntime.InvokeVoidAsync("window.showToast", "Error", "Save Error: " + errMessage, "error"); 
            StateHasChanged();
        } finally {
            isSubmitting = false;
        }
    }

    private void ResetComponent()
    {
        transMode = "sale";
        selectedCustomer = null;
        customerSearchQuery = "";
        searchQuery = "";
        paymentMethod = "Cash";
        tenderedAmount = null;
        notes = "";
        showPaymentModal = false;
        filteredProducts = allProducts;
        StateHasChanged();
    }

