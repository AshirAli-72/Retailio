<!-- RECOVERY MODAL -->
@if (showRecoveryModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    <i class="ph-plus-circle"></i> Add Recovery
                </div>
                <button type="button" class="form-panel-close" @onclick="HideRecoveryForm"><i class="ph-x"></i></button>
            </div>

            <div class="form-panel-body" style="display: flex; flex-direction: column; gap: 1.25rem;">
                @if (!string.IsNullOrEmpty(recoveryErrorMessage))
                {
                    <div style="padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; font-size: 0.9rem;">
                        <i class="ph-warning"></i> @recoveryErrorMessage
                    </div>
                }

                @if (recoverySelectedCustomer != null && recoveryCustomerCredit != null)
                {
                    <div style="padding: 1rem; background: var(--bg-light); border-radius: 0.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                            <span class="text-muted font-sm">Total Credit</span>
                            <span class="font-bold">@recoveryCustomerCredit.total_credit.ToString("N2")</span>
                        </div>
                        <div style="display: flex; justify-content: space-between;">
                            <span class="text-muted font-sm">Remaining Credit</span>
                            <span class="font-bold text-danger">@recoveryCustomerCredit.remaining.ToString("N2")</span>
                        </div>
                    </div>
                }

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Date</label>
                    <input type="date" @bind="recoveryTempDate" class="form-control" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Paid Amount</label>
                    <input type="number" step="0.01" @bind="recoveryModel.paid" class="form-control" placeholder="Enter paid amount" />
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">Status</label>
                    <select @bind="recoveryModel.status" class="form-control">
                        <option value="Partial">Partial</option>
                        <option value="Paid">Paid</option>
                    </select>
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                    <label class="form-label">File (Optional)</label>
                    <InputFile OnChange="OnRecoveryFileSelected" class="form-control" />
                    @if (!string.IsNullOrEmpty(recoveryModel.file))
                    {
                        <p class="text-muted font-sm mt-2">@System.IO.Path.GetFileName(recoveryModel.file)</p>
                    }
                </div>
            </div>

            <div class="form-panel-footer">
                <button type="button" class="btn-cancel" @onclick="HideRecoveryForm">Cancel</button>
                <button type="button" class="btn-save" @onclick="SaveRecoveryInSale" disabled="@isRecoverySubmitting">
                    @if (isRecoverySubmitting)
                    {
                        <i class="ph-spinner ph-spin"></i>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <i class="ph-check"></i>
                        <span>Save Recovery</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

