@using Retailio.Models
@using Retailio.Data
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime
@rendermode Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer

@if (currentView == "center")
{
    <ReportsCenter UserId="UserId" OnViewHub="ShowHub" />
}
else if (currentView == "sales")
{
    <SalesReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else if (currentView == "inventory")
{
    <InventoryReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else if (currentView == "customers")
{
    <CustomerReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else if (currentView == "products")
{
    <ProductReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else if (currentView == "employees")
{
    <EmployeeReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else if (currentView == "credits")
{
    <CreditReportsHub UserId="UserId" OnBack="GoToCenter" />
}
else
{
    <ReportsCenter UserId="UserId" OnViewHub="ShowHub" />
}

@code {
    [Parameter] public int? UserId { get; set; }

    private string currentView = "center";

    private void ShowHub(string hubType)
    {
        currentView = hubType;
    }

    private void GoToCenter()
    {
        currentView = "center";
    }
}
