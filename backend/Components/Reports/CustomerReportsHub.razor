@using Retailio.Models
@using Retailio.Data
@using Microsoft.EntityFrameworkCore
@using Retailio.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JSRuntime

<div class="customer-hub-container">
    <!-- Breadcrumbs -->
    <div class="hub-breadcrumbs no-print">
        <div class="breadcrumb-item">
            <i class="ph-house-line"></i>
            <span>Dashboard</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item clickable" @onclick="OnBack">
            <span>Reports Center</span>
        </div>
        <i class="ph-caret-right separator"></i>
        <div class="breadcrumb-item active">
            <span>Customer Insights</span>
        </div>
    </div>

    <!-- Header Section -->
    <div class="hub-header no-print">
        <div class="header-content">
            <h1 class="hub-title">Customer Analytics</h1>
            <p class="hub-subtitle">Analyze customer growth and relationship intelligence</p>
        </div>
        <div class="header-actions">
            <button class="btn-outline" @onclick='() => ExportToCSV("customerTable")'>
                <i class="ph-file-csv"></i> Export CSV
            </button>
            <button class="btn-primary-gradient" @onclick="PrintReport">
                <i class="ph-printer"></i> Print Directory
            </button>
        </div>
    </div>

    <!-- Filters Glass -->
    <div class="filters-glass no-print">
        <div class="filters-inner">
            <div class="filter-group">
                <label><i class="ph-calendar"></i> From Date</label>
                <input type="date" @bind="fromDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-calendar"></i> To Date</label>
                <input type="date" @bind="toDate" />
            </div>
            <div class="filter-group">
                <label><i class="ph-users"></i> Select Customer</label>
                <select @bind="selectedCustomerId">
                    <option value="All">All Customers</option>
                    @foreach (var c in allCustomersForDropdown)
                    {
                        <option value="@c.id">@c.name</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <label><i class="ph-funnel"></i> Customer Status</label>
                <select @bind="selectedStatus">
                    <option value="All">All Customers</option>
                    <option value="Active">Active Only</option>
                    <option value="Inactive">Inactive Only</option>
                </select>
            </div>
            <div class="filter-actions-row">
                <button class="btn-reset-text" @onclick="ResetFilters">Reset Filters</button>
                <button class="btn-generate-glow" @onclick="LoadData">
                    <i class="ph-lightning"></i> Generate Analysis
                </button>
            </div>
        </div>
    </div>

    <div id="fullReportContainer">
        <!-- Dashboard Grid -->
        <div class="dashboard-grid">
            <!-- Stats Row -->
            <div class="stats-row">
                <div class="stat-card-premium border-purple">
                    <div class="stat-info">
                        <span class="label">Total Customers</span>
                        <h2 class="value">@(isGenerated ? allCustomers.Count.ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon purple-glow"><i class="ph-users-three"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated ? "100%" : "0%"); background: #8b5cf6;"></div></div>
                </div>

                <div class="stat-card-premium border-green">
                    <div class="stat-info">
                        <span class="label">With Contact Number</span>
                        <h2 class="value">@(isGenerated ? allCustomers.Count(c => !string.IsNullOrEmpty(c.contact)).ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon green-glow"><i class="ph-phone"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated && allCustomers.Count > 0 ? (allCustomers.Count(c => !string.IsNullOrEmpty(c.contact)) * 100 / allCustomers.Count) : 0)%; background: #10b981;"></div></div>
                </div>

                <div class="stat-card-premium border-blue">
                    <div class="stat-info">
                        <span class="label">With Email</span>
                        <h2 class="value">@(isGenerated ? allCustomers.Count(c => !string.IsNullOrEmpty(c.email)).ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon blue-glow"><i class="ph-envelope"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated && allCustomers.Count > 0 ? (allCustomers.Count(c => !string.IsNullOrEmpty(c.email)) * 100 / allCustomers.Count) : 0)%; background: #3b82f6;"></div></div>
                </div>

                <div class="stat-card-premium border-orange">
                    <div class="stat-info">
                        <span class="label">Inactive/Restricted</span>
                        <h2 class="value">@(isGenerated ? allCustomers.Count(c => c.status != (int?)EntityStatus.Active).ToString() : "---")</h2>
                    </div>
                    <div class="stat-icon orange-glow"><i class="ph-warning"></i></div>
                    <div class="stat-progress"><div class="bar" style="width: @(isGenerated && allCustomers.Count > 0 ? (allCustomers.Count(c => c.status != (int?)EntityStatus.Active) * 100 / allCustomers.Count) : 0)%; background: #f59e0b;"></div></div>
                </div>
            </div>

            <!-- Chart & Insight Row -->
            <div class="insight-row">
                <div class="glass-card chart-container">
                    <div class="card-header">
                        <h3 class="card-title"><i class="ph-chart-line-up"></i> Registration Trend</h3>
                        <div class="card-badge">New Acquisitions</div>
                    </div>
                    <div class="chart-wrapper">
                        @if (isGenerated)
                        {
                            <canvas id="customerHubChart"></canvas>
                        }
                        else
                        {
                            <div class="chart-skeleton">
                                <i class="ph-users"></i>
                                <p>Generate report to see acquisition trends</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="glass-card side-insights">
                    <div class="insights-tabs">
                        <div class="tab-item active"><i class="ph-star"></i> Top Customers</div>
                    </div>
                    <div class="insights-content">
                        @if (isGenerated && topCustomersInsights.Any())
                        {
                            @foreach (var cust in topCustomersInsights.Take(5))
                            {
                                <div class="product-mini-item">
                                    <div class="prod-details">
                                        <span class="prod-name">@cust.Name</span>
                                        <span class="prod-meta">@cust.Contact</span>
                                    </div>
                                    <div class="prod-value" style="color: #8b5cf6;">@cust.Status</div>
                                </div>
                            }
                        }
                        else if (!isGenerated)
                        {
                            <div class="empty-mini">Awaiting analysis...</div>
                        }
                        else
                        {
                            <div class="empty-mini">No data available</div>
                        }

                        <div class="mix-header">
                            <h4 class="mix-title">Status Distribution</h4>
                        </div>
                        <div class="mix-content">
                            @if (isGenerated)
                            {
                                @foreach (var stat in statusStats)
                                {
                                    <div class="mix-item">
                                        <div class="mix-labels">
                                            <span>@stat.Label</span>
                                            <span>@stat.Percent.ToString("N0")%</span>
                                        </div>
                                        <div class="mix-bar-wrap">
                                            <div class="mix-bar" style="width: @(stat.Percent)%; background: @(stat.Color);"></div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="mix-skeleton"></div>
                                <div class="mix-skeleton"></div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Table Section -->
            <div class="glass-card table-section">
                <div class="card-header">
                    <h3 class="card-title"><i class="ph-users"></i> Customer Profiles</h3>
                    <div class="card-actions no-print">
                         <span class="count-badge">@(isGenerated ? filteredCustomers.Count : 0) Records</span>
                    </div>
                </div>
                <div class="table-container">
                    @if (isLoading)
                    {
                        <div class="premium-loader">
                            <i class="ph-spinner ph-spin"></i>
                            <span>Loading Profiles...</span>
                        </div>
                    }
                    else if (isGenerated && filteredCustomers.Any())
                    {
                        <table class="premium-table" id="customerTable">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Contact</th>
                                    <th>Email</th>
                                    <th>Address</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in filteredCustomers)
                                {
                                    <tr>
                                        <td class="font-bold">@c.name</td>
                                        <td><span class="badge-bill">@c.contact</span></td>
                                        <td>@(string.IsNullOrEmpty(c.email) ? "-" : c.email)</td>
                                        <td>@c.address</td>
                                        <td><span class="badge-status @(c.status == (int?)EntityStatus.Active ? "sale" : "return")">@PaymentHelper.GetEntityStatusName(c.status)</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (!isGenerated)
                    {
                        <div class="empty-hero">
                            <i class="ph-users"></i>
                            <h3>Customer Intelligence Ready</h3>
                            <p>Filter your customer base and click <strong>Generate Analysis</strong> to view profiles.</p>
                        </div>
                    }
                    else
                    {
                        <div class="empty-hero">
                            <i class="ph-users"></i>
                            <h3>No Customers Found</h3>
                            <p>No matches for your current criteria.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link href="/css/reports/customerreport.css" rel="stylesheet" />

@code {
    [Parameter] public EventCallback OnBack { get; set; }

    private DateTime fromDate = DateTime.Now.AddDays(-30);
    private DateTime toDate = DateTime.Now;
    private string selectedCustomerId = "All";
    private List<customers> allCustomersForDropdown = new();
    private string searchTerm = "";
    private string selectedStatus = "All";
    private List<customers> allCustomers = new();
    private List<customers> filteredCustomers = new();
    private bool isLoading = false;
    private bool isGenerated = false;
    private StoreConfiguration storeInfo = new();

    private class CustomerInsight { public string Name { get; set; } = ""; public string Contact { get; set; } = ""; public string Status { get; set; } = ""; }
    private List<CustomerInsight> topCustomersInsights = new();

    private class StatusStat { public string Label { get; set; } = ""; public decimal Percent { get; set; } public string Color { get; set; } = ""; }
    private List<StatusStat> statusStats = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        allCustomersForDropdown = await context.customers.AsNoTracking().OrderBy(x => x.name).ToListAsync();
        var config = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();
        if (config != null) storeInfo = config;
    }

    private async Task LoadData()
    {
        isLoading = true;
        isGenerated = true;
        StateHasChanged();
        try
        {
            using var context = DbFactory.CreateDbContext();
            allCustomers = await context.customers.AsNoTracking().OrderByDescending(x => x.id).ToListAsync();
            
            filteredCustomers = allCustomers.Where(c => 
                (selectedCustomerId == "All" || c.id.ToString() == selectedCustomerId) &&
                (selectedStatus == "All" || PaymentHelper.GetEntityStatusName(c.status) == selectedStatus)
            ).ToList();

            var config = await context.store_configurations.AsNoTracking().FirstOrDefaultAsync();
            if (config != null) storeInfo = config;

            // Generate Insights
            topCustomersInsights = allCustomers.Select(c => new CustomerInsight { 
                Name = c.name ?? "N/A", 
                Contact = c.contact ?? "-", 
                Status = PaymentHelper.GetEntityStatusName(c.status)
            }).ToList();

            var statuses = allCustomers.GroupBy(c => PaymentHelper.GetEntityStatusName(c.status))
                .Select(g => new { Label = g.Key, Count = g.Count() })
                .ToList();
            
            int total = allCustomers.Count;
            statusStats = statuses.Select(s => new StatusStat {
                Label = s.Label,
                Percent = total > 0 ? (s.Count * 100m / total) : 0,
                Color = s.Label == "Active" ? "#10b981" : "#f59e0b"
            }).ToList();

            // Mock Trend Chart Data (Customer growth is harder without created_at, but we use ID as proxy for now)
            var labels = new[] { "Week 1", "Week 2", "Week 3", "Week 4" };
            var values = new[] { 10, 25, 45, total };
            await JSRuntime.InvokeVoidAsync("renderReportChart", "customerHubChart", new { labels, values, label = "Growth" });
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private void HandleSearch()
    {
        var term = (searchTerm ?? "").ToLower();
        filteredCustomers = allCustomers.Where(c => 
            ((c.name?.ToLower().Contains(term) ?? false) || 
             (c.contact?.ToLower().Contains(term) ?? false) || 
             (c.email?.ToLower().Contains(term) ?? false)) &&
            (selectedStatus == "All" || PaymentHelper.GetEntityStatusName(c.status) == selectedStatus)
        ).ToList();
    }

    private async Task ResetFilters()
    {
        searchTerm = "";
        selectedCustomerId = "All";
        selectedStatus = "All";
        fromDate = DateTime.Now.AddDays(-30);
        toDate = DateTime.Now;
        isGenerated = false;
        filteredCustomers.Clear();
        StateHasChanged();
    }

    private async Task PrintReport() { 
        string logoUrl = "";
        if (!string.IsNullOrEmpty(storeInfo.LogoPath)) logoUrl = $"/store-logo/{Path.GetFileName(storeInfo.LogoPath)}";

        var printData = new {
            shopName = storeInfo.ShopName,
            address = storeInfo.Address,
            phone = storeInfo.Phone1,
            email = "", 
            logoUrl = logoUrl
        };

        await JSRuntime.InvokeVoidAsync("printElement", "fullReportContainer", "Customer Directory", printData); 
    }
    private async Task ExportToCSV(string id) { await JSRuntime.InvokeVoidAsync("exportTableToCSV", id, "Customer_Directory.csv"); }
}

