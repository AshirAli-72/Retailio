@using Retailio.Models
@using Retailio.Data
@using Microsoft.EntityFrameworkCore
@using System.IO
@using Retailio.Services
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Environment
@rendermode RenderMode.InteractiveServer

<link href="/css/employee/index.css" rel="stylesheet" />

<div class="management-container @(showForm ? "modal-active" : "")">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-users-three page-header-icon"></i>
                <h2 class="page-header-title">Employee Management</h2>
            </div>
            <button class="btn-primary" @onclick="ShowAddForm">
                <i class="ph-user-plus"></i> Add New Employee
            </button>
        </div>



        <div class="table-container">
            <div class="table-responsive">
                <table class="styled-table" style="margin-bottom: 0;">
                <thead>
                    <tr>
                        <th style="padding-left: 1.5rem;">Full Name</th>
                        <th>CNIC</th>
                        <th>Mobile</th>
                        <th>Address</th>
                        <th>Email</th>

                        <th>Status</th>
                        <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in employeeList)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem;">@emp.name</td>
                            <td class="text-muted">@emp.cnic</td>
                            <td>@emp.contact</td>
                            <td class="text-muted font-sm" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@emp.address</td>
                            <td class="font-sm">@emp.email</td>
                            <td>
                                <span class="status-badge @(emp.status == (int?)EntityStatus.Active ? "status-active" : "status-inactive")">
                                    @PaymentHelper.GetEntityStatusName(emp.status)
                                </span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <button class="btn-icon-sm btn-edit" @onclick="() => EditEmployee(emp)" title="Edit">
                                        <i class="ph-pencil"></i>
                                    </button>
                                    <button class="btn-icon-sm btn-delete" @onclick="() => DeleteEmployee(emp.id)" title="Delete">
                                        <i class="ph-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!employeeList.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-state">
                                <i class="ph-users-three empty-state-icon"></i>
                                <p>No employees found. Add your first employee to get started.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (employeeList.Any())
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing <b>@((currentPage - 1) * pageSize + 1)</b> to <b>@(Math.Min(currentPage * pageSize, totalCount))</b> of <b>@totalCount</b> entries
                </div>
                <div class="pagination-controls">
                    <button class="btn-pagination" @onclick="PreviousPage" disabled="@(currentPage == 1)">
                        <i class="ph-caret-left"></i>
                    </button>
                    
                    @for (int i = 1; i <= TotalPages; i++)
                    {
                        var pageNumber = i;
                        @if (i == 1 || i == TotalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                        {
                            <button class="btn-pagination @(currentPage == pageNumber ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                                @pageNumber
                            </button>
                        }
                        else if (i == currentPage - 3 || i == currentPage + 3)
                        {
                            <span class="pagination-ellipsis">...</span>
                        }
                    }

                    <button class="btn-pagination" @onclick="NextPage" disabled="@(currentPage == TotalPages)">
                        <i class="ph-caret-right"></i>
                    </button>
                </div>
            </div>
        }
    </div>
</div>
</div>

@if (showForm)
{
    <div class="modal-overlay">
        <div class="modal-content" style="max-width: 650px;">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    <i class="ph-user-circle @(editingEmployee == null ? "form-icon-primary" : "")"></i>
                    @(editingEmployee == null ? "Register New Employee" : "Edit Employee Details")
                </div>
                <button type="button" class="form-panel-close" @onclick="HideForm"><i class="ph-x"></i></button>
            </div>

            <EditForm Model="employeeModel" OnValidSubmit="SaveEmployee">
                <DataAnnotationsValidator />
                
                <div class="form-panel-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 8px; background: #fee2e2; color: #ef4444; border: 1px solid #fecaca; font-size: 0.9rem;">
                            <i class="ph-warning"></i> @errorMessage
                        </div>
                    }

                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <InputText @bind-Value="employeeModel.name" class="form-control" placeholder="Enter full name" />
                        <ValidationMessage For="@(() => employeeModel.name)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">CNIC / ID Number</label>
                        <InputText @bind-Value="employeeModel.cnic" class="form-control" placeholder="e.g. 42101-XXXXXXX-X" />
                        <ValidationMessage For="@(() => employeeModel.cnic)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mobile Number</label>
                        <InputText @bind-Value="employeeModel.contact" class="form-control" placeholder="e.g. 0300-XXXXXXX" />
                        <ValidationMessage For="@(() => employeeModel.contact)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <InputText @bind-Value="employeeModel.email" class="form-control" placeholder="employee@example.com" />
                        <ValidationMessage For="@(() => employeeModel.email)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Residential Address</label>
                        <InputTextArea @bind-Value="employeeModel.address" class="form-control" rows="2" placeholder="Enter full address" />
                        <ValidationMessage For="@(() => employeeModel.address)" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <InputSelect @bind-Value="employeeModel.status" class="form-control">
                            <option value="@((int)EntityStatus.Active)">Active</option>
                            <option value="@((int)EntityStatus.Inactive)">Inactive</option>
                        </InputSelect>
                    </div>

                    <hr style="border: none; border-top: 1px solid #e2e8f0; margin: 1rem 0;" />
                    <p style="font-size: 0.8rem; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">
                        <i class="ph-lock-key"></i> System Access (Login Credentials)
                    </p>

                    <div class="form-group">
                        <label class="form-label">Password @(editingEmployee != null ? "(leave blank to keep current)" : "")</label>
                        <InputText @bind-Value="loginPassword" type="password" class="form-control" placeholder="••••••••" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Roles</label>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.25rem;">
                            @foreach (var role in rolesList)
                            {
                                bool isChecked = selectedRoleIds.Contains(role.Id);
                                <label style="display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.75rem; border-radius: 8px; border: 1.5px solid #e2e8f0; cursor: pointer; @(isChecked ? "background: var(--primary-glow); border-color: var(--primary);" : "")">
                                    <input type="checkbox" checked="@isChecked" @onchange="(e) => ToggleRole(role.Id, (bool)(e.Value ?? false))" style="accent-color: var(--primary);" />
                                    <span style="font-size: 0.85rem; font-weight: 500;">@role.RoleTitle</span>
                                </label>
                            }
                        </div>
                    </div>

                    <!-- Profile Image Section -->
                    <div class="form-group" style="margin-top: 1rem;">
                        <label class="form-label">Profile Image</label>
                        <div style="display:flex; gap:1.5rem; align-items:flex-start; background: #fff5f6; padding:1.25rem; border-radius:12px; border:2px dashed #fecdd3;">
                            <div style="width:90px; height:90px; border-radius:50%; background: white; display:flex; align-items:center; justify-content:center; overflow:hidden; border: 3px solid white; box-shadow: 0 4px 10px rgba(188, 24, 35, 0.1);">
                                @if (!string.IsNullOrEmpty(imgUrl))
                                {
                                    <img src="@imgUrl" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else if (!string.IsNullOrEmpty(employeeModel.image_path))
                                {
                                    <img src="@GetDisplayImageUrl(employeeModel.image_path)" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    <i class="ph-user-focus" style="font-size:2rem; color: #fecdd3;"></i>
                                }
                            </div>
                            <div style="flex:1;">
                                <InputFile OnChange="HandleFileSelected" class="form-control" accept="image/*" style="border: 1px solid #fecdd3; background: white;" />
                                <p style="font-size:.78rem; color:#475569; margin-top:.6rem; font-weight: 500;">
                                    <i class="ph-info" style="color: var(--primary);"></i> Recommended size: 500x500px. Max 5MB.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-panel-footer">
                    @* Removed Delete Account button from form as requested *@
                    <button type="button" class="btn-cancel" @onclick="HideForm" disabled="@isSubmitting">Cancel</button>
                    <button type="submit" class="btn-save" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <i class="ph-spinner ph-spin"></i> @("Processing...")
                        }
                        else
                        {
                            <i class="ph-check"></i> @(editingEmployee == null ? "Register Employee" : "Update Details")
                        }
                    </button>
                </div>
            </EditForm>
    </div>
</div>
}



@code {
    [Parameter] public string? UserName { get; set; }
    [Parameter] public int? UserId { get; set; }

    private List<Employee> employeeList = new();
    private Employee employeeModel = new();
    private bool showForm = false;
    private Employee? editingEmployee = null;
    private bool isSubmitting = false;
    private string? errorMessage;
    private IBrowserFile? selectedFile;
    private string? imgUrl;

    // Login credential fields
    private string? loginPassword;
    private HashSet<int> selectedRoleIds = new();
    private List<Role> rolesList = new();

    // Pagination state
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalCount = 0;
    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        await LoadEmployees();
    }

    private async Task LoadRoles()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();
            rolesList = await context.roles
                .Where(r => r.RoleTitle != "SuperAdmin" && r.RoleTitle != "Admin")
                .OrderBy(r => r.Id)
                .ToListAsync();
        }
        catch { }
    }

    private async Task LoadEmployees()
    {
        using var context = DbFactory.CreateDbContext();
        totalCount = await context.employees.ForTenant(UserId).CountAsync();
        
        employeeList = await context.employees.ForTenant(UserId)
            .OrderByDescending(e => e.id)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
            
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadEmployees();
    }

    private async Task NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            await LoadEmployees();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadEmployees();
        }
    }

    private string GetDisplayImageUrl(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "";
        try { return "/emp-image/" + Path.GetFileName(path); }
        catch { return ""; }
    }

    private async Task ShowAddForm()
    {
        errorMessage = null;
        editingEmployee = null;
        selectedFile = null;
        imgUrl = null;
        loginPassword = null;
        selectedRoleIds.Clear();
        showForm = true;
        
        employeeModel = new Employee 
        { 
            status = (int?)EntityStatus.Active
        };
    }

    private async Task EditEmployee(Employee item)
    {
        editingEmployee = item;
        employeeModel = new Employee
        {
            id         = item.id,
            name       = item.name,
            cnic       = item.cnic,
            email      = item.email,
            contact    = item.contact,
            address    = item.address,
            image_path = item.image_path,
            status     = item.status,
            password   = item.password,
            business_id    = item.business_id
        };
        errorMessage = null;
        selectedFile = null;
        imgUrl = null;

        // Pre-fill login credentials from linked user record
        using var context = DbFactory.CreateDbContext();
        var linkedUser = context.users.FirstOrDefault(u => u.email == item.email);
        if (linkedUser != null)
        {
            loginPassword = linkedUser.password; // stored hash; user can overwrite
            await TryLoadEmployeeRoles(linkedUser.id);
        }
        else
        {
            loginPassword = item.password;
            selectedRoleIds.Clear();
        }

        showForm = true;
    }

    private void ToggleRole(int roleId, bool isChecked)
    {
        if (isChecked) selectedRoleIds.Add(roleId);
        else selectedRoleIds.Remove(roleId);
    }

    private async Task TryLoadEmployeeRoles(int userId)
    {
        selectedRoleIds.Clear();
        try
        {
            using var context = DbFactory.CreateDbContext();
            var rpIds = await context.user_has_roles
                .Where(e => e.UserId == userId)
                .Select(e => e.RolesHasPermissionId)
                .ToListAsync();
            if (rpIds.Any())
            {
                var roleIds = await context.roles_has_permissions
                    .Where(rp => rpIds.Contains(rp.Id))
                    .Select(rp => rp.RoleId)
                    .Distinct()
                    .ToListAsync();
                foreach (var rid in roleIds)
                    selectedRoleIds.Add(rid);
            }
        }
        catch { }
    }

    private void HideForm()
    {
        showForm = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            selectedFile = e.File;
            if (selectedFile.Size > 5120000)
            {
                errorMessage = "Select an image less than 5MB.";
                selectedFile = null;
                return;
            }
            using var stream = selectedFile.OpenReadStream(5120000);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            imgUrl = $"data:{selectedFile.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        }
        catch (Exception ex)
        {
            errorMessage = "Preview error: " + ex.Message;
        }
    }

    private async Task SaveEmployee()
    {
        if (string.IsNullOrWhiteSpace(employeeModel.name)) { errorMessage = "Full name is required."; return; }

        isSubmitting = true;
        try
        {
            string storagePath = Path.Combine(Environment.ContentRootPath, "bin", "Debug", "emp_image");
            if (!Directory.Exists(storagePath)) Directory.CreateDirectory(storagePath);

            if (selectedFile != null)
            {
                string fileName = Guid.NewGuid().ToString() + Path.GetExtension(selectedFile.Name);
                string fullPath = Path.Combine(storagePath, fileName);

                // Delete old image if updating
                if (!string.IsNullOrEmpty(employeeModel.image_path))
                    if (File.Exists(employeeModel.image_path)) try { File.Delete(employeeModel.image_path); } catch { }

                await using var stream = selectedFile.OpenReadStream(5120000);
                await using var fs = new FileStream(fullPath, FileMode.Create);
                await stream.CopyToAsync(fs);
                employeeModel.image_path = fullPath; // Store full absolute path
            }

            using var context = DbFactory.CreateDbContext();

            if (editingEmployee == null)
            {
                // ── New employee: create user + employee + roles ────────
                var passwordHash = !string.IsNullOrWhiteSpace(loginPassword)
                    ? PaymentHelper.HashPassword(loginPassword)
                    : string.Empty;

                var newUser = new users
                {
                    name = employeeModel.name,
                    contact = employeeModel.contact,
                    cnic = employeeModel.cnic,
                    email = employeeModel.email,
                    password = passwordHash,
                    business_id = UserId ?? 0,
                    status = (int)EntityStatus.Active
                };
                context.users.Add(newUser);
                await context.SaveChangesAsync();

                employeeModel.password = passwordHash;
                employeeModel.business_id = UserId;
                employeeModel.user_id = newUser.id;
                context.employees.Add(employeeModel);
                await context.SaveChangesAsync();

                // Save user_has_roles for selected roles
                if (selectedRoleIds.Any())
                {
                    var rpLinks = await context.roles_has_permissions
                        .Where(rp => selectedRoleIds.Contains(rp.RoleId))
                        .ToListAsync();
                    foreach (var rp in rpLinks)
                    {
                        context.user_has_roles.Add(new UserHasRoles
                        {
                            UserId = newUser.id,
                            RolesHasPermissionId = rp.Id,
                            business_id = UserId
                        });
                    }
                    await context.SaveChangesAsync();
                }
            }
            else
            {
                // ── Edit employee: update user + employee + roles ────────
                var linkedUser = await context.users.FirstOrDefaultAsync(u => u.id == editingEmployee.user_id || u.email == editingEmployee.email);
                if (linkedUser != null)
                {
                    linkedUser.name = employeeModel.name;
                    linkedUser.contact = employeeModel.contact;
                    linkedUser.cnic = employeeModel.cnic;
                    linkedUser.email = employeeModel.email;
                    if (!string.IsNullOrWhiteSpace(loginPassword) && loginPassword != linkedUser.password)
                    {
                        linkedUser.password = PaymentHelper.HashPassword(loginPassword);
                    }
                }
                else
                {
                    // Create user record if missing (e.g. legacy employee)
                    linkedUser = new users
                    {
                        name = employeeModel.name,
                        contact = employeeModel.contact,
                        cnic = employeeModel.cnic,
                        email = employeeModel.email,
                        password = !string.IsNullOrWhiteSpace(loginPassword)
                            ? PaymentHelper.HashPassword(loginPassword)
                            : employeeModel.password,
                        business_id = UserId ?? 0,
                        status = (int)EntityStatus.Active
                    };
                    context.users.Add(linkedUser);
                }
                await context.SaveChangesAsync();

                if (!string.IsNullOrWhiteSpace(loginPassword) && loginPassword != employeeModel.password)
                {
                    employeeModel.password = PaymentHelper.HashPassword(loginPassword);
                }
                employeeModel.user_id = linkedUser.id;
                context.employees.Update(employeeModel);
                await context.SaveChangesAsync();

                // Re-sync user_has_roles
                var existingUhr = await context.user_has_roles
                    .Where(u => u.UserId == linkedUser.id)
                    .ToListAsync();
                context.user_has_roles.RemoveRange(existingUhr);

                if (selectedRoleIds.Any())
                {
                    var rpLinks = await context.roles_has_permissions
                        .Where(rp => selectedRoleIds.Contains(rp.RoleId))
                        .ToListAsync();
                    foreach (var rp in rpLinks)
                    {
                        context.user_has_roles.Add(new UserHasRoles
                        {
                            UserId = linkedUser.id,
                            RolesHasPermissionId = rp.Id,
                            business_id = UserId
                        });
                    }
                }
                await context.SaveChangesAsync();
            }

            await JSRuntime.InvokeVoidAsync("clearNavCache");
            await LoadEmployees();
            HideForm();
            var msg = editingEmployee == null ? "Employee created successfully!" : "Employee updated successfully!";
            await JSRuntime.InvokeVoidAsync("showToast", "Success", msg, "success");
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = "Error saving employee: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteEmployee(int id)
    {
        using var context = DbFactory.CreateDbContext();
        var emp = await context.employees.FindAsync(id);
        if (emp != null)
        {
            // Delete image file
            if (!string.IsNullOrEmpty(emp.image_path) && File.Exists(emp.image_path))
                try { File.Delete(emp.image_path); } catch { }

            context.employees.Remove(emp);
            await context.SaveChangesAsync();
            await JSRuntime.InvokeVoidAsync("showToast", "Success", "Employee deleted successfully!", "success");
            await LoadEmployees();
        }
    }
    private string? FormatDateForInput(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return null;
        if (DateTime.TryParse(dateStr, out var dt)) return dt.ToString("yyyy-MM-dd");
        return null;
    }

    private string? FormatDateFromInput(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return null;
        if (DateTime.TryParse(dateStr, out var dt)) return dt.ToString("yyyy-MM-dd");
        return dateStr;
    }
}
