@using Retailio.Models
@using Retailio.Data
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Server
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@rendermode RenderMode.InteractiveServer


<link href="/css/settings/user.css" rel="stylesheet" />
<link href="/css/settings/index.css" rel="stylesheet" />

<div class="management-container">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-shield-check page-header-icon"></i>
                <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                    <h2 class="page-header-title">Roles & Permissions</h2>
                    <p class="text-muted font-sm" style="margin: 0;">Control system access and feature visibility per user role</p>
                </div>
            </div>
            <div class="page-header-actions">
                <button class="rp-btn-primary" @onclick="OpenAddRoleModal">
                    <i class="ph-plus"></i> Add Role
                </button>
                <a href="/settings" class="btn-back-hub">
                    <i class="ph-arrow-left"></i> Back to Settings
                </a>
            </div>
        </div>

        <div class="table-container">
            <div class="table-responsive">
                <table class="styled-table" style="margin-bottom: 0;">
                    <thead>
                        <tr>
                            <th style="padding-left: 1.5rem;">Role Name</th>
                            <th>Description</th>
                            <th>Permissions</th>
                            <th style="width: 120px; padding-right: 1.5rem;" class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (rolesList.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="empty-state">
                                <i class="ph-shield-check empty-state-icon"></i>
                                    <p>No roles found. Click "Add Role" to create one.</p>
                                </td>
                            </tr>
                        }
                        @foreach (var role in rolesList)
                        {
                            <tr>
                                <td class="font-bold" style="padding-left: 1.5rem;">@role.RoleTitle</td>
                                <td class="text-muted" style="font-size:0.85rem;">@(string.IsNullOrEmpty(role.Description) ? "-" : role.Description)</td>
                                <td>
                                    @{
                                        var rolePerms = GetRolePermissions(role.Id);
                                    }
                                    @if (rolePerms.Count == 0)
                                    {
                                        <span class="text-muted" style="font-size:0.8rem;">No permissions</span>
                                    }
                                    else
                                    {
                                        <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
                                            @foreach (var perm in rolePerms)
                                            {
                                                <span class="role-badge">@perm</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="text-right" style="padding-right: 1.5rem;">
                                    <div class="actions-container actions-right">
                                        <button class="btn-icon-sm btn-edit" @onclick="() => EditRole(role)" title="Edit">
                                            <i class="ph-pencil"></i>
                                        </button>
                                        <button class="btn-icon-sm btn-delete" @onclick="() => ConfirmDeleteRole(role)" title="Delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="padding: 1rem 1.5rem;">
                <div style="padding: 0.75rem; background: #fee2e2; border-radius: 8px; color: #b91c1c; font-size: 0.85rem;">
                    @errorMessage
                </div>
            </div>
        }
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="rpm-shell" @onclick:stopPropagation>

            <div class="rpm-header">
                <div class="rpm-header-left">
                    <div class="rpm-icon-badge"><i class="ph-shield-check"></i></div>
                    <div>
                        <div class="rpm-title">@(isEditing ? "Edit Role" : "Add New Role")</div>
                        <div class="rpm-subtitle">Configure role access permissions</div>
                    </div>
                </div>
                <button class="rpm-close-btn" type="button" @onclick="CloseModal"><i class="ph-x"></i></button>
            </div>

            <div class="rpm-body">
                <div class="rpm-fields-row">
                    <div class="rpm-field">
                        <label class="rpm-field-label">Role Name</label>
                        <input class="rpm-field-input" type="text" @bind="modalRoleName" @bind:event="oninput" placeholder="e.g. Manager" />
                    </div>
                    <div class="rpm-field rpm-field-wide">
                        <label class="rpm-field-label">Description</label>
                        <input class="rpm-field-input" type="text" @bind="modalDescription" @bind:event="oninput" placeholder="Brief description of this role" />
                    </div>
                </div>

                <div class="rpm-perm-header">
                    <div class="rpm-perm-divider"><span>PERMISSIONS</span></div>
                    <div class="rpm-select-all-wrap" @onclick="ToggleAllPermissions2">
                        <div class="rpm-toggle-sm @(AllPermissionsChecked ? "rpm-toggle-on" : "")"><div class="rpm-toggle-knob"></div></div>
                        <span class="rpm-select-all-text">Select All</span>
                        <span class="rpm-sel-count">@modalSelectedSlugs.Count / @AllSlugs.Count</span>
                    </div>
                </div>

                <div class="rpm-pills-row">
                    <button type="button" class="rpm-pill @(activeCategory == null ? "rpm-pill-on" : "")" @onclick='() => activeCategory = null'>
                        <i class="ph-squares-four"></i> All
                    </button>
                    @foreach (var cat in PermissionCategories)
                    {
                        int selCount = cat.Permissions.Count(p => modalSelectedSlugs.Contains(p.Slug));
                        <button type="button" class="rpm-pill @(activeCategory == cat.Label ? "rpm-pill-on" : "")" @onclick="() => activeCategory = cat.Label">
                            <i class="@GetCategoryIcon(cat.Label)"></i> @cat.Label
                            @if (selCount > 0) { <span class="rpm-pill-dot"></span> }
                        </button>
                    }
                </div>

                <div class="rpm-cards-grid">
                    @foreach (var cat in PermissionCategories)
                    {
                        if (activeCategory != null && activeCategory != cat.Label) continue;
                        foreach (var perm in cat.Permissions)
                        {
                            bool on = modalSelectedSlugs.Contains(perm.Slug);
                            <div class="rpm-card @(on ? "rpm-card-on" : "")" @onclick="() => ToggleModalPermission(perm.Slug, !on)">
                                <div class="rpm-card-body">
                                    <div class="rpm-card-icon"><i class="@GetCategoryIcon(cat.Label)"></i></div>
                                    <div class="rpm-card-text">
                                        <span class="rpm-card-name">@perm.Name</span>
                                        <span class="rpm-card-cat">@cat.Label</span>
                                    </div>
                                </div>
                                <div class="rpm-toggle-sm @(on ? "rpm-toggle-on" : "")"><div class="rpm-toggle-knob"></div></div>
                            </div>
                        }
                    }
                </div>

                @if (!string.IsNullOrEmpty(modalError))
                {
                    <div class="rpm-error-bar"><i class="ph-warning-circle"></i> @modalError</div>
                }
            </div>

            <div class="rpm-footer">
                @if (isEditing)
                {
                    <button class="rpm-btn-del" type="button" @onclick="() => ConfirmDeleteRole(editingRole!)">
                        <i class="ph-trash"></i> Delete Role
                    </button>
                }
                <div class="rpm-footer-right">
                    <button class="rpm-btn-cancel" type="button" @onclick="CloseModal">Cancel</button>
                    <button class="rpm-btn-save" type="button" @onclick="SaveRole" disabled="@isSaving">
                        @if (isSaving) { <i class="ph-spinner ph-spin"></i><span>Saving…</span> }
                        else { <span>@(isEditing ? "Update Role" : "Save Role")</span> }
                    </button>
                </div>
            </div>

        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-content" @onclick:stopPropagation style="max-width: 420px;">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    <i class="ph-warning-fill" style="color: #dc2626;"></i> Confirm Deletion
                </div>
                <button type="button" class="form-panel-close" @onclick="CancelDelete"><i class="ph-x"></i></button>
            </div>
            <div class="form-panel-body">
                <p>Are you sure you want to delete role <strong>"@deletingRole?.RoleTitle"</strong>?</p>
                <p class="text-muted" style="font-size: 0.85rem;">This action cannot be undone. All permissions assigned to this role will also be removed.</p>
            </div>
            <div class="form-panel-footer">
                <button type="button" class="btn-cancel" @onclick="CancelDelete">Cancel</button>
                <button type="button" class="btn-save" style="background: #dc2626;" @onclick="DeleteRole" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <i class="ph-spinner ph-spin"></i><span>Deleting...</span>
                    }
                    else
                    {
                        <span>Confirm Delete</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? UserId { get; set; }

    private List<Role> rolesList = new();
    private Dictionary<int, List<string>> rolePermissionsMap = new();
    private bool isSaving = false;
    private string? errorMessage;

    private bool showModal = false;
    private bool isEditing = false;
    private string modalRoleName = "";
    private string modalDescription = "";
    private HashSet<string> modalSelectedSlugs = new();
    private string? modalError;
    private Role? editingRole = null;

    private bool showDeleteConfirm = false;
    private Role? deletingRole = null;
    private string? activeCategory = null;

    private class PermissionInfo
    {
        public string Slug { get; set; } = "";
        public string Name { get; set; } = "";
    }

    private class PermissionCategory
    {
        public string Label { get; set; } = "";
        public PermissionInfo[] Permissions { get; set; } = Array.Empty<PermissionInfo>();
    }

    // Aligned with PermissionSlugs.cs — obsolete view_* slugs for CRUD sections removed.
    // view_customer, view_product, view_sale, view_inventory, view_employee, view_recovery
    // are NOT in the system. Having any CRUD permission grants section access.
    private static readonly PermissionCategory[] PermissionCategories = new[]
    {
        new PermissionCategory
        {
            Label = "Dashboard",
            Permissions = new[] { new PermissionInfo { Slug = "view_dashboard", Name = "Dashboard Access" } }
        },
        new PermissionCategory
        {
            Label = "Customers",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "create_customer", Name = "Create Customer" },
                new PermissionInfo { Slug = "edit_customer",   Name = "Edit Customer" },
                new PermissionInfo { Slug = "delete_customer", Name = "Delete Customer" }
            }
        },
        new PermissionCategory
        {
            Label = "Products",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "create_product", Name = "Create Product" },
                new PermissionInfo { Slug = "edit_product",   Name = "Edit Product" },
                new PermissionInfo { Slug = "delete_product", Name = "Delete Product" }
            }
        },
        new PermissionCategory
        {
            Label = "Sales",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "create_sale", Name = "Create Sale" },
                new PermissionInfo { Slug = "edit_sale",   Name = "Edit Sale" },
                new PermissionInfo { Slug = "delete_sale", Name = "Delete Sale" }
            }
        },
        new PermissionCategory
        {
            Label = "Employees",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "create_employee", Name = "Create Employee" },
                new PermissionInfo { Slug = "edit_employee",   Name = "Edit Employee" },
                new PermissionInfo { Slug = "delete_employee", Name = "Delete Employee" }
            }
        },
        new PermissionCategory
        {
            Label = "Inventory",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "edit_inventory", Name = "Edit Inventory" }
            }
        },
        new PermissionCategory
        {
            Label = "Recovery",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "create_recovery", Name = "Create Recovery" },
                new PermissionInfo { Slug = "delete_recovery", Name = "Delete Recovery" }
            }
        },
        new PermissionCategory
        {
            Label = "Reports",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "view_report",  Name = "View Reports" },
                new PermissionInfo { Slug = "print_report", Name = "Print Reports" }
            }
        },
        new PermissionCategory
        {
            Label = "Settings",
            Permissions = new[] { new PermissionInfo { Slug = "view_settings", Name = "Settings Access" } }
        },
        new PermissionCategory
        {
            Label = "Users",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "view_users",   Name = "View Users" },
                new PermissionInfo { Slug = "create_user",  Name = "Create User" },
                new PermissionInfo { Slug = "edit_user",    Name = "Edit User" },
                new PermissionInfo { Slug = "delete_user",  Name = "Delete User" }
            }
        },
        new PermissionCategory
        {
            Label = "Roles",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "view_roles",   Name = "View Roles" },
                new PermissionInfo { Slug = "manage_roles", Name = "Manage Roles" }
            }
        },
        new PermissionCategory
        {
            Label = "Currency",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "view_currency",   Name = "View Currency" },
                new PermissionInfo { Slug = "manage_currency", Name = "Manage Currency" }
            }
        },
        new PermissionCategory
        {
            Label = "About",
            Permissions = new[]
            {
                new PermissionInfo { Slug = "view_about", Name = "View About Store" },
                new PermissionInfo { Slug = "edit_about", Name = "Edit About Store" }
            }
        }
    };

    private static readonly HashSet<string> AllSlugs = new(PermissionCategories.SelectMany(c => c.Permissions.Select(p => p.Slug)));

    private bool AllPermissionsChecked => modalSelectedSlugs.Count == AllSlugs.Count;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            rolesList = await context.roles
                .Where(r => r.RoleTitle != "SuperAdmin")
                .OrderBy(r => r.Id)
                .ToListAsync();

            var allRolePerms = await context.roles_has_permissions
                .Join(context.permissions,
                    rp => rp.PermissionId,
                    p => p.Id,
                    (rp, p) => new { rp.RoleId, PermName = p.Slugs ?? p.Slugs ?? "" })
                .ToListAsync();

            rolePermissionsMap = allRolePerms
                .GroupBy(x => x.RoleId)
                .ToDictionary(g => g.Key, g => g.Select(x => x.PermName).ToList());
        }
        catch (Exception ex)
        {
            errorMessage = "Error loading data: " + ex.Message;
        }
    }

    private List<string> GetRolePermissions(int roleId) => rolePermissionsMap.TryGetValue(roleId, out var perms) ? perms : new List<string>();

    private void OpenAddRoleModal()
    {
        isEditing = false;
        editingRole = null;
        modalRoleName = "";
        modalDescription = "";
        modalSelectedSlugs.Clear();
        modalError = null;
        activeCategory = null;
        showDeleteConfirm = false;
        showModal = true;
    }

    private void EditRole(Role role)
    {
        isEditing = true;
        editingRole = role;
        modalRoleName = role.RoleTitle;
        modalDescription = role.Description ?? "";
        modalError = null;
        showDeleteConfirm = false;
        _ = LoadRolePermissionsForEdit(role.Id);
        showModal = true;
    }

    private async Task LoadRolePermissionsForEdit(int roleId)
    {
        modalSelectedSlugs.Clear();
        try
        {
            using var context = DbFactory.CreateDbContext();
            var slugs = await context.roles_has_permissions
                .Where(rp => rp.RoleId == roleId)
                .Join(context.permissions,
                    rp => rp.PermissionId,
                    p => p.Id,
                    (rp, p) => p.Slugs ?? "")
                .ToListAsync();

            foreach (var slug in slugs)
                if (!string.IsNullOrEmpty(slug)) modalSelectedSlugs.Add(slug);
        }
        catch { }

        await InvokeAsync(StateHasChanged);
    }

    private void CloseModal()
    {
        showModal = false;
        showDeleteConfirm = false;
        editingRole = null;
        deletingRole = null;
        modalRoleName = "";
        modalDescription = "";
        modalSelectedSlugs.Clear();
        modalError = null;
        activeCategory = null;
    }

    private void ToggleAllPermissions2()
    {
        if (AllPermissionsChecked)
            modalSelectedSlugs.Clear();
        else
            foreach (var slug in AllSlugs)
                modalSelectedSlugs.Add(slug);
    }

    private void ConfirmDeleteRole(Role role)
    {
        deletingRole = role;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deletingRole = null;
    }

    private async Task DeleteRole()
    {
        if (deletingRole == null) return;

        var roleToDelete = deletingRole;
        isSaving = true;
        modalError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = DbFactory.CreateDbContext();

            var links = await context.roles_has_permissions
                .Where(rp => rp.RoleId == roleToDelete.Id)
                .ToListAsync();

            context.roles_has_permissions.RemoveRange(links);

            var dbRole = await context.roles.FindAsync(roleToDelete.Id);
            if (dbRole != null)
            {
                context.roles.Remove(dbRole);
                await context.SaveChangesAsync();
            }

            await LoadData();
            CloseModal();
            await JS.InvokeVoidAsync("showToast", "Success", $"Role '{roleToDelete.RoleTitle}' deleted successfully!", "success");
        }
        catch (Exception ex)
        {
            modalError = "Error deleting role: " + (ex.InnerException?.Message ?? ex.Message);
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SaveRole()
    {
        if (string.IsNullOrWhiteSpace(modalRoleName))
        {
            modalError = "Please enter a role name.";
            return;
        }

        isSaving = true;
        modalError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            using var context = DbFactory.CreateDbContext();

            Role? role;
            if (isEditing && editingRole != null)
            {
                role = await context.roles.FindAsync(editingRole.Id);
                if (role != null)
                {
                    role.RoleTitle = modalRoleName.Trim();
                    role.Description = string.IsNullOrWhiteSpace(modalDescription) ? null : modalDescription.Trim();
                }
            }
            else
            {
                if (await context.roles.AnyAsync(r => r.RoleTitle.ToLower() == modalRoleName.Trim().ToLower()))
                {
                    modalError = $"Role '{modalRoleName}' already exists.";
                    isSaving = false;
                    return;
                }

                role = new Role
                {
                    RoleTitle = modalRoleName.Trim(),
                    Description = string.IsNullOrWhiteSpace(modalDescription) ? null : modalDescription.Trim(),
                    business_id = UserId ?? 0
                };
                context.roles.Add(role);
            }

            await context.SaveChangesAsync();

            if (role == null)
            {
                modalError = "Role not found.";
                return;
            }

            var existingPerms = await context.permissions.ToListAsync();
            foreach (var slug in AllSlugs)
            {
                if (!existingPerms.Any(p => p.Slugs == slug))
                {
                    var name = GetPermissionDisplayName(slug);
                    context.permissions.Add(new Permission { Slugs = slug, Names = name });
                }
            }
            await context.SaveChangesAsync();

            var freshPerms = await context.permissions.ToListAsync();

            var existingLinks = await context.roles_has_permissions
                .Where(rp => rp.RoleId == role.Id)
                .ToListAsync();
            context.roles_has_permissions.RemoveRange(existingLinks);

            foreach (var slug in modalSelectedSlugs)
            {
                var perm = freshPerms.FirstOrDefault(p => p.Slugs == slug);
                if (perm != null)
                {
                    context.roles_has_permissions.Add(new RolesHasPermission
                    {
                        RoleId = role.Id,
                        PermissionId = perm.Id,
                        business_id = UserId
                    });
                }
            }

            await context.SaveChangesAsync();

            await LoadData();
            CloseModal();
            await JS.InvokeVoidAsync("showToast", "Success", $"Role '{role.RoleTitle}' saved successfully!", "success");
        }
        catch (Exception ex)
        {
            modalError = "Error: " + (ex.InnerException?.Message ?? ex.Message);
        }
        finally
        {
            isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleAllPermissions(ChangeEventArgs e)
    {
        var val = (bool)(e.Value ?? false);
        if (val)
        {
            foreach (var slug in AllSlugs)
                modalSelectedSlugs.Add(slug);
        }
        else
        {
            modalSelectedSlugs.Clear();
        }
    }

    private bool AreAllCategoryPermissionsChecked(PermissionCategory category)
    {
        return category.Permissions.All(p => modalSelectedSlugs.Contains(p.Slug));
    }

    private void ToggleCategory(PermissionCategory category, bool isChecked)
    {
        foreach (var perm in category.Permissions)
        {
            if (isChecked) modalSelectedSlugs.Add(perm.Slug);
            else modalSelectedSlugs.Remove(perm.Slug);
        }
    }

    private void ToggleModalPermission(string slug, bool isChecked)
    {
        if (isChecked) modalSelectedSlugs.Add(slug);
        else modalSelectedSlugs.Remove(slug);
    }

    private static string GetCategoryIcon(string label) => label switch
    {
        "Dashboard"  => "ph-squares-four",
        "Customers"  => "ph-users",
        "Products"   => "ph-package",
        "Sales"      => "ph-receipt",
        "Employees"  => "ph-identification-badge",
        "Inventory"  => "ph-warehouse",
        "Recovery"   => "ph-arrow-counter-clockwise",
        "Reports"    => "ph-chart-bar",
        "Settings"   => "ph-gear",
        "Users"      => "ph-user-circle",
        "Roles"      => "ph-shield-check",
        "Currency"   => "ph-currency-circle-dollar",
        "About"      => "ph-info",
        _            => "ph-circle"
    };

    private static string GetPermissionDisplayName(string slug)
    {
        return slug switch
        {
            "view_dashboard"   => "View Dashboard",
            "create_customer"  => "Create Customer",
            "edit_customer"    => "Edit Customer",
            "delete_customer"  => "Delete Customer",
            "create_product"   => "Create Product",
            "edit_product"     => "Edit Product",
            "delete_product"   => "Delete Product",
            "create_sale"      => "Create Sale",
            "edit_sale"        => "Edit Sale",
            "delete_sale"      => "Delete Sale",
            "edit_inventory"   => "Edit Inventory",
            "create_employee"  => "Create Employee",
            "edit_employee"    => "Edit Employee",
            "delete_employee"  => "Delete Employee",
            "create_recovery"  => "Create Recovery",
            "delete_recovery"  => "Delete Recovery",
            "view_report"      => "View Reports",
            "print_report"     => "Print Reports",
            "view_settings"    => "View Settings",
            "view_users"       => "View Users",
            "create_user"      => "Create User",
            "edit_user"        => "Edit User",
            "delete_user"      => "Delete User",
            "view_roles"       => "View Roles",
            "manage_roles"     => "Manage Roles",
            "view_currency"    => "View Currency",
            "manage_currency"  => "Manage Currency",
            "view_about"       => "View About Store",
            "edit_about"       => "Edit About Store",
            _ => slug
        };
    }
}