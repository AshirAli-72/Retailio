@page "/settings"
@model E_Invoice_system.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "System Settings";
}

@section Styles {
    <link rel="stylesheet" href="~/css/settings/index.css" asp-append-version="true" />
}


<div class="dashboard-panel">
    <div class="page-header">
        <h1 class="page-title-large">
            System Settings
        </h1>
        <a href="/" class="btn-back-hub">
            <i class="ph-house"></i> Back to Dashboard
        </a>
    </div>

    <component type="typeof(E_Invoice_system.Components.Settings.SettingsHub)" render-mode="Server" />
</div>

@section Scripts {
    @* Scripts if needed *@
}
