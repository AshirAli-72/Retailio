<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="view-transition" content="same-origin" />
    <title>@ViewData["Title"] - E-Invoice System</title>
    <base href="~/" />

    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <!-- Phosphor icons (3.8 MB) loaded async — never blocks first paint -->
    <link rel="preload" href="~/lib/phosphor/icons.css" as="style"
          onload="this.onload=null;this.rel='stylesheet'" asp-append-version="true" />
    <noscript><link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" /></noscript>
    <script src="~/lib/chartjs/chart.js" defer></script>

    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/settings.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/invoice.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/product.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
</head>

<body>
    @{
        var userRole = Context.Session.GetString("UserRole") ?? "";
        var userName = Context.Session.GetString("UserName") ?? "User";
        var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U";
    }
    <div class="app-container">
        @using Microsoft.EntityFrameworkCore
        @using E_Invoice_system.Data
        @using E_Invoice_system.Models
        @using Microsoft.AspNetCore.Http
        @using Microsoft.Extensions.Caching.Memory
        @inject IDbContextFactory<ApplicationDbContext> DbFactory
        @inject IMemoryCache LayoutCache
        @{
            // ── Logo ────────────────────────────────────────────────────────
            string logoSrc = "/images/sata-logo.png";
            try
            {
                using var _ctx = DbFactory.CreateDbContext();
                var _store = _ctx.store_configurations.AsNoTracking().FirstOrDefault();
                if (_store != null && !string.IsNullOrEmpty(_store.LogoPath))
                {
                    try { logoSrc = "/store-logo/" + System.IO.Path.GetFileName(_store.LogoPath); }
                    catch { }
                }
            }
            catch { }

            // ── Permissions (cached 30 min per role) ───────────────
            bool isAdmin = userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase);
            RolePermission? perms = null;

            if (!string.IsNullOrEmpty(userRole) && !isAdmin)
            {
                string cacheKey = "Perms_" + userRole;
                if (!LayoutCache.TryGetValue(cacheKey, out perms))
                {
                    try
                    {
                        using var context2 = DbFactory.CreateDbContext();
                        perms = context2.roles_permissions.Include(p => p.Role).AsNoTracking().FirstOrDefault(p => p.Role != null && p.Role.RoleTitle == userRole);
                        if (perms != null) LayoutCache.Set(cacheKey, perms, TimeSpan.FromMinutes(30));
                    }
                    catch { }
                }
            }
        }

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header sidebar-logo-container">
                <div class="sidebar-logo-wrap">
                    <img src="@logoSrc" alt="Logo" class="sidebar-logo" />
                    <span class="sidebar-logo-label">E-Invoice System</span>
                </div>

                <button id="sidebarClose" class="mobile-only mobile-close-btn">
                    <i class="ph-x"></i>
                </button>
            </div>

            <nav class="sidebar-nav" style="margin-top: 1rem;">
                @if (isAdmin || (perms?.Dashboard ?? false))
                {
                    <a href="/" class="nav-item">
                        <i class="ph-house nav-icon"></i>
                        <span>Dashboard</span>
                    </a>
                }

                @if (isAdmin || (perms?.Customers ?? false))
                {
                    <a href="/customer" class="nav-item">
                        <i class="ph-users nav-icon"></i>
                        <span>Customers</span>
                    </a>
                }

                @if (isAdmin || (perms?.Products ?? false))
                {
                    <a href="/product" class="nav-item">
                        <i class="ph-package nav-icon"></i>
                        <span>Products/Services</span>
                    </a>
                }

                @if (isAdmin || (perms?.Inventory ?? false))
                {
                    <a href="/inventory" class="nav-item">
                        <i class="ph-archive nav-icon"></i>
                        <span>Inventory</span>
                    </a>
                }

                @if (isAdmin || (perms?.Sales ?? false))
                {
                    <a href="/sale" class="nav-item">
                        <i class="ph-shopping-cart nav-icon"></i>
                        <span>Sales</span>
                    </a>
                }

                @if (isAdmin || (perms?.Invoices ?? false))
                {
                    <a href="/Invoice" class="nav-item">
                        <i class="ph-file-text nav-icon"></i>
                        <span>Invoices</span>
                    </a>
                }

                @if (isAdmin || (perms?.Employees ?? false))
                {
                    <a href="/employee" class="nav-item">
                        <i class="ph-users-three nav-icon"></i>
                        <span>Employees</span>
                    </a>
                }

                @if (isAdmin || (perms?.Reports ?? false))
                {
                    <a href="/reports" class="nav-item">
                        <i class="ph-chart-bar nav-icon"></i>
                        <span>Reports</span>
                    </a>
                }

                @if (isAdmin || (perms?.Settings ?? false))
                {
                    <a href="/settings" class="nav-item">
                        <i class="ph-gear nav-icon"></i>
                        <span>Settings</span>
                    </a>
                }
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="top-bar">
                <div class="top-bar-left">
                    <button id="sidebarToggle" class="mobile-toggle-btn">
                        <i class="ph-list"></i>
                    </button>
                </div>

                <div class="top-bar-right">
                    <div class="user-profile-wrapper" style="position: relative;">
                        <div class="user-avatar-initial" id="profileDropdownToggle" style="cursor: pointer;">
                            @initial
                        </div>

                        <div class="profile-dropdown" id="profileDropdown">
                            <div style="padding: 12px; border-bottom: 1px solid var(--border);">
                                <div class="user-name" style="font-size: 1rem; font-weight: 800;">@userName</div>
                                <div class="user-role" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">@userRole</div>
                                @{
                                    var displayEmail = Context.Session.GetString("UserEmail");
                                    if (string.IsNullOrEmpty(displayEmail)) {
                                        displayEmail = userName.Contains("@") ? userName : userName + "@system.com";
                                    }
                                }
                                @if (displayEmail != userName)
                                {
                                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; word-break: break-all;">@displayEmail</div>
                                }
                            </div>

                            <div class="dropdown-divider"></div>

                            <form asp-page="/Account/Logout" asp-area="" method="post" style="padding: 0; margin: 0;">
                                <button type="submit" class="dropdown-item" style="width: 100%; border: none; background: transparent; text-align: left; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; color: #ef4444;">
                                    <i class="ph-sign-out"></i>
                                    <span>Logout</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script src="~/js/app-main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div id="toast-container"></div>

    <script>
        // Sidebar Toggle Logic with Overlay
        document.addEventListener("DOMContentLoaded", function () {
            const sidebar = document.getElementById("sidebar");
            const openBtn = document.getElementById("sidebarToggle");
            const closeBtn = document.getElementById("sidebarClose");

            // Create overlay element
            let overlay = document.getElementById('sidebar-overlay');
            if (!overlay) {
                overlay = document.createElement('div');
                overlay.id = 'sidebar-overlay';
                overlay.style.cssText = 'display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:999;';
                document.body.appendChild(overlay);
            }

            function openSidebar() {
                sidebar.classList.add("open");
                overlay.style.display = 'block';
                document.body.style.overflow = 'hidden';
            }

            function closeSidebar() {
                sidebar.classList.remove("open");
                overlay.style.display = 'none';
                document.body.style.overflow = '';
            }

            if (openBtn) {
                openBtn.addEventListener("click", openSidebar);
            }

            if (closeBtn) {
                closeBtn.addEventListener("click", closeSidebar);
            }

            // Close sidebar when clicking overlay
            overlay.addEventListener('click', closeSidebar);

            // Close sidebar when pressing Escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && sidebar.classList.contains('open')) {
                    closeSidebar();
                }
            });
        });

        // Toast message
        (function () {
            var msg = '@Html.Raw((TempData["Success"] as string)?.Replace("'", "\\'") ?? "")';
            if (msg && typeof window.showToast === 'function') {
                window.showToast('Success', msg, 'success');
            }
        })();
    </script>

</body>
</html>

