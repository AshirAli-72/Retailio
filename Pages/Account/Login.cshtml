@page
@model E_Invoice_system.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - E-Invoice System</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/account/login.css" asp-append-version="true" />
</head>
<body>
    
    <div class="login-wrapper">
        <div class="left-side">
            <div class="brand-header">
                <div class="brand-logo-container">
                    <div class="document-icon">
                        <i class="ph-file-text"></i>
                        <div class="check-badge">
                            <i class="ph-check"></i>
                        </div>
                    </div>
                    <div class="brand-text-content">
                        <div class="brand-main-text">E-<span>INVOICE</span></div>
                        <div class="brand-sub-text">
                            <span>SYSTEM</span>
                            <div class="brand-line"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="login-content">
                <h1 class="welcome-title">Welcome <span>Back</span></h1>
                <p class="subtitle">Sign in to continue to your account</p>
                <div class="subtitle-line"></div>

                <form method="post" id="loginForm">
                    <div class="form-group">
                        <div class="input-box">
                            <i class="ph-user"></i>
                            <input asp-for="Email" type="email" id="emailField" placeholder="Email Address" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="input-box">
                            <i class="ph-lock"></i>
                            <input asp-for="Password" type="password" id="passwordField" placeholder="Password" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-login" id="loginBtn">
                        Login <i class="ph-arrow-right"></i>
                    </button>
                </form>
            </div>

            <div class="footer-tagline">
                <strong>Smart</strong> Invoicing,<br>
                <strong>Stronger</strong> Business.
            </div>
        </div>

        <div class="right-side">
            <!-- Sweeping Wave SVG -->
            <div class="wave-container">
                <svg viewBox="0 0 1000 1000" preserveAspectRatio="none" class="wave-svg">
                    <!-- White filled area on the left of the curve -->
                    <path d="M -20 -20 L 80 -20 C 320 100, 220 700, 500 1020 L -20 1020 Z" fill="#fff"></path>
                    <!-- Red sweeping band -->
                    <path d="M 80 -20 C 320 100, 220 700, 500 1020" fill="none" stroke="#BC1823" stroke-width="24"></path>
                    <!-- Thin white/silver line -->
                    <path d="M 110 -20 C 350 100, 250 700, 530 1020" fill="none" stroke="#ffffff" stroke-width="4" opacity="0.8"></path>
                    
                    <!-- Concentric dotted red curves at the bottom center -->
                    <path d="M 350 1020 C 400 920, 500 900, 600 920" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 380 1020 C 430 900, 550 870, 670 900" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 410 1020 C 460 880, 600 840, 740 880" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 440 1020 C 500 860, 660 810, 820 860" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    
                    <!-- Sweeping dotted red curves at the bottom right -->
                    <path d="M 700 1020 C 800 900, 900 750, 1000 700" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 750 1020 C 850 880, 930 730, 1000 650" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 800 1020 C 900 860, 960 710, 1000 600" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 850 1020 C 930 840, 980 690, 1000 550" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                    <path d="M 900 1020 C 960 820, 990 670, 1000 500" fill="none" stroke="rgba(188, 24, 35, 0.35)" stroke-width="2" stroke-dasharray="4, 8"></path>
                </svg>
            </div>
            
            <div class="brand-showcase">
                <img src="/user_logo.png" class="floating-s" alt="S Logo" />
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const loginForm = document.getElementById('loginForm');
            const loginBtn = document.getElementById('loginBtn');
            const emailField = document.getElementById('emailField');
            const passwordField = document.getElementById('passwordField');

            if (loginForm && loginBtn) {
                loginForm.addEventListener('submit', function () {
                    loginBtn.disabled = true;
                    loginBtn.innerHTML = '<span class="btn-loader"></span> Logging in...';
                    if (emailField) emailField.readOnly = true;
                    if (passwordField) passwordField.readOnly = true;
                });
            }
        });
    </script>
</body>
</html>
