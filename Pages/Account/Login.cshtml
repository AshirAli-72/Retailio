@page
@model E_Invoice_system.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - E-Invoice System</title>
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <!-- Phosphor icons (3.8 MB) loaded async — never blocks first paint -->
    <link rel="preload" href="~/lib/phosphor/icons.css" as="style"
          onload="this.onload=null;this.rel='stylesheet'" asp-append-version="true" />
    <noscript><link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" /></noscript>
</head>
<body>
    <div class="login-wrapper">

        <!-- ── Left Red Panel ──────────────────────────────────────── -->
        <div class="left-panel">
            <!-- Rotating tagline at bottom -->
            <div class="overlay-content">
                <h2 id="rotating-text">"E-Invoice System - SATA"</h2>
            </div>
        </div>

        <!-- ── Right Login Card ────────────────────────────────────── -->
        <div class="right-panel">
            <div class="login-card">
                <!-- Login Title -->
                <div class="login-title-section">
                    <h1 class="login-title">Login</h1>
                    <p class="login-subtitle">E-Invoice System</p>
                </div>

                <!-- Notification flasher -->
                @if (TempData["Success"] != null || TempData["Error"] != null)
                {
                    var isError = TempData["Error"] != null;
                    var msg     = TempData["Success"] ?? TempData["Error"];
                    var bg      = isError ? "#dc2626" : "#065f46"; // Solid Colors
                    var borderColor = isError ? "rgba(255,255,255,0.2)" : "rgba(255,255,255,0.2)";
                    var icon    = isError ? "ph-warning-circle" : "ph-check-circle";
                    var progressColor = isError ? "#fca5a5" : "#6ee7b7";
                    var textColor = "#ffffff";

                    <div id="loginFlasher" style="position:fixed;top:24px;right:24px;z-index:10000;
                         min-width:320px;max-width:450px;padding:16px 20px;border-radius:16px;
                         background:@bg;
                         border:1px solid @borderColor;font-size:.9rem;font-weight:600;
                         display:flex;align-items:flex-start;gap:12px;
                         box-shadow:0 12px 32px @(isError ? "rgba(220,38,38,0.4)" : "rgba(6, 78, 59, 0.4)"), 0 4px 12px rgba(0,0,0,.15);
                         animation:slideInRight .5s cubic-bezier(.16,1,.3,1);
                         overflow:hidden;">
                        <div style="width:40px;height:40px;background:rgba(255,255,255,0.25);
                                    border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="@icon" style="font-size:1.25rem;color:@textColor;"></i>
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:700;font-size:.95rem;margin-bottom:4px;color:@textColor;">@(isError ? "Error" : "Success")</div>
                            <div style="font-weight:500;opacity:1;font-size:.85rem;color:@textColor;">@msg</div>
                        </div>
                        <div style="position:absolute;bottom:0;left:0;height:3px;background:rgba(255,255,255,0.5);
                                    border-radius:0 0 16px 16px;animation:progressShrink 3s linear forwards;"></div>
                    </div>
                }

                <div asp-validation-summary="ModelOnly"
                     style="color:#ef4444;font-size:.85rem;margin-top:.75rem;margin-bottom:-.25rem;
                            list-style:none;padding:0;"></div>

                <!-- Login Form -->
                <form method="post" class="login-form" id="loginForm" autocomplete="on">
                    <div class="form-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email"
                               type="email"
                               placeholder="Enter your email"
                               autocomplete="email"
                               inputmode="email"
                               required />
                    </div>

                    <div class="form-group">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password"
                               type="password"
                               placeholder="Enter password"
                               autocomplete="current-password"
                               required />
                    </div>

                    <button type="submit" class="btn-login" id="loginBtn" style="margin-top:.75rem;">
                        Login
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="login-footer-external">
        <p>© 2026 E-Invoice System. Crafted with ❤️ by SATA Technologies Pvt. Ltd.</p>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Focus email for faster login
            const emailInput = document.getElementById('Email');
            if (emailInput && !emailInput.value) emailInput.focus();

            // Auto-hide flasher after 3s
            const flasher = document.getElementById('loginFlasher');
            if (flasher) {
                setTimeout(() => {
                    flasher.style.transition = 'all .4s ease-out';
                    flasher.style.opacity    = '0';
                    flasher.style.transform  = 'translateX(80px)';
                    setTimeout(() => flasher.remove(), 400);
                }, 3000);
            }

            // ── Fast submit feedback ─────────────────────────────────
            const loginForm = document.getElementById('loginForm');
            const loginBtn  = document.getElementById('loginBtn');

            if (loginForm && loginBtn) {
                loginForm.addEventListener('submit', function (e) {
                    // Instant visual feedback — button becomes "Logging in..."
                    loginBtn.disabled   = true;
                    loginBtn.innerText  = 'Logging in…';
                    loginBtn.style.opacity = '0.8';
                    loginBtn.style.cursor  = 'not-allowed';

                    // Safety: re-enable after 10s in case of server error
                    setTimeout(() => {
                        loginBtn.disabled      = false;
                        loginBtn.innerText     = 'Login';
                        loginBtn.style.opacity = '1';
                        loginBtn.style.cursor  = 'pointer';
                    }, 10000);
                });
            }

            // ── Rotating tagline animation ───────────────────────────
            const texts = [
                '"E-Invoice System - SATA"',
                '"Fast & Secure Invoicing"',
                '"Manage Your Sales Easily"'
            ];
            let idx = 0;
            const textEl = document.getElementById('rotating-text');
            if (textEl) {
                setInterval(() => {
                    textEl.style.transition = 'all .5s ease-in';
                    textEl.style.opacity    = '0';
                    textEl.style.transform  = 'translateX(40px)';
                    setTimeout(() => {
                        idx = (idx + 1) % texts.length;
                        textEl.innerText          = texts[idx];
                        textEl.style.transition   = 'none';
                        textEl.style.transform    = 'translateX(-40px)';
                        void textEl.offsetWidth;  // force reflow
                        textEl.style.transition   = 'all .5s ease-out';
                        textEl.style.opacity      = '1';
                        textEl.style.transform    = 'translateX(0)';
                    }, 500);
                }, 3500);
            }
        });
    </script>
</body>
</html>
