@page
@model E_Invoice_system.Pages.Account.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - E-Invoice System</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

        :root {
            --primary-red: #BC1823;
            --dark-bg: #0d1117;
            --text-main: #111827;
            --text-muted: #6b7280;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Outfit', sans-serif;
            height: 100vh;
            overflow: hidden;
            background: #fff;
        }

        .login-wrapper {
            display: flex;
            width: 100%;
            height: 100%;
        }

        /* ── LEFT SIDE (FORM) ── */
        .left-side {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 0 8% 0 12%;
            background: #fff;
            position: relative;
            z-index: 10;
        }

        .login-content {
            max-width: 440px;
            width: 100%;
        }

        .welcome-title {
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.25rem;
            letter-spacing: -1px;
        }

        .welcome-title span {
            color: var(--primary-red);
        }

        .subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-weight: 500;
        }

        .subtitle-line {
            width: 45px;
            height: 3px;
            background: var(--primary-red);
            margin-bottom: 3rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .input-box {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-box i {
            position: absolute;
            left: 18px;
            font-size: 1.4rem;
            color: var(--primary-red);
        }

        .input-box input {
            width: 100%;
            padding: 18px 20px 18px 56px;
            background: #fcfcfc;
            border: 1.5px solid #f1f1f1;
            border-radius: 12px;
            font-size: 1.05rem;
            font-family: inherit;
            color: var(--text-main);
            transition: all 0.3s ease;
        }

        .input-box input::placeholder {
            color: #9ca3af;
        }

        .input-box input:focus {
            outline: none;
            border-color: var(--primary-red);
            background: #fff;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        }

        .password-toggle {
            position: absolute;
            right: 18px;
            cursor: pointer;
            color: #9ca3af !important;
            font-size: 1.3rem !important;
        }

        .btn-login {
            width: 100%;
            padding: 18px;
            background: #9c141d; /* Slightly darker red as in pic */
            color: white;
            border: none;
            border-radius: 14px;
            font-size: 1.2rem;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            transition: all 0.3s;
            margin-top: 2.5rem;
            box-shadow: 0 10px 25px rgba(156, 20, 29, 0.25);
        }

        .btn-login:hover {
            background: #BC1823;
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(156, 20, 29, 0.35);
        }

        .footer-tagline {
            position: absolute;
            bottom: 60px;
            left: 12%;
            border-left: 3px solid var(--primary-red);
            padding-left: 18px;
            font-size: 1.1rem;
            font-weight: 600;
            color: #4b5563;
            line-height: 1.5;
        }

        .footer-tagline strong {
            color: #111827;
        }

        /* ── RIGHT SIDE (VISUAL) ── */
        .right-side {
            flex: 1.1;
            background: var(--dark-bg);
            position: relative;
            overflow: hidden;
        }

        /* The Red Sweep Wave */
        .wave-container {
            position: absolute;
            top: 0;
            left: -1px;
            height: 100%;
            width: 100%;
            z-index: 2;
        }

        .wave-svg {
            height: 100%;
            width: auto;
            min-width: 300px;
        }

        /* Abstract Background Dots (like in pic 2 bottom right) */
        .dots-pattern {
            position: absolute;
            bottom: -50px;
            right: -50px;
            width: 400px;
            height: 400px;
            background-image: radial-gradient(rgba(188, 24, 35, 0.15) 2px, transparent 2px);
            background-size: 30px 30px;
            z-index: 1;
        }

        /* Notification flasher */
        #loginFlasher {
            position: fixed;
            top: 30px;
            left: 30px;
            z-index: 10000;
            padding: 16px 28px;
            border-radius: 16px;
            background: white;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 15px;
            font-weight: 700;
            animation: slideInLeft 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        @@keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-40px); }
            to { opacity: 1; transform: translateX(0); }
        }

        @@media (max-width: 1100px) {
            .right-side { display: none; }
            .left-side { flex: 1; padding: 0 8%; align-items: center; }
            .welcome-title { font-size: 2.8rem; text-align: center; }
            .subtitle { text-align: center; }
            .subtitle-line { margin-inline: auto; }
            .footer-tagline { left: 50%; transform: translateX(-50%); text-align: center; border: none; padding: 0; }
        }
    </style>
</head>
<body>
    
    <div class="login-wrapper">
        
        <div class="left-side">
            <div class="login-content">
                <h1 class="welcome-title">Welcome <span>Back</span></h1>
                <p class="subtitle">Sign in to continue to your account</p>
                <div class="subtitle-line"></div>

                <form method="post" id="loginForm">
                    <div class="form-group">
                        <div class="input-box">
                            <i class="ph-user"></i>
                            <input asp-for="Email" type="email" placeholder="Email Address" required />
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="input-box">
                            <i class="ph-lock"></i>
                            <input asp-for="Password" type="password" id="passwordField" placeholder="Password" required />
                        </div>
                    </div>

                    <button type="submit" class="btn-login" id="loginBtn">
                        Login <i class="ph-arrow-right"></i>
                    </button>
                </form>
            </div>

            <div class="footer-tagline">
                <strong>E-Invoice</strong> System,<br>
                Secure <strong>Business</strong> Intelligence.
            </div>
        </div>

        <div class="right-side">
            <!-- Sweeping Wave SVG -->
            <div class="wave-container">
                <svg viewBox="0 0 500 1000" preserveAspectRatio="none" class="wave-svg">
                    <path d="M0,0 C200,300 200,700 0,1000 L0,1000 L0,0 Z" fill="#fff"></path>
                    <path d="M5,0 C210,310 210,690 5,1000" fill="none" stroke="#BC1823" stroke-width="12" opacity="0.9"></path>
                    <path d="M15,0 C230,320 230,680 15,1000" fill="none" stroke="#fff" stroke-width="2" opacity="0.3"></path>
                </svg>
            </div>

            <div class="dots-pattern"></div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const loginForm = document.getElementById('loginForm');
            const loginBtn = document.getElementById('loginBtn');

            if (loginForm && loginBtn) {
                loginForm.addEventListener('submit', function () {
                    loginBtn.disabled = true;
                    loginBtn.innerHTML = '<i class="ph-spinner ph-spin"></i> Logging in...';
                });
            }
        });
    </script>
</body>
</html>

