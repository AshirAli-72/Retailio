<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>@ViewData["Title"] - Sale Terminal</title>
    
    <!-- Local Fonts: Inter -->
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    
    <!-- Phosphor Icons -->
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="~/css/dashboard/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sale/create.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/invoice/index.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
    
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
</head>
<body>
    <div class="sale-layout-container">
        <!-- Main Content Area (Now Full Width) -->
        <div class="sale-main-wrapper">
            <header class="top-bar">

                <div class="top-bar-left">
                    @using Microsoft.EntityFrameworkCore
                    @using E_Invoice_system.Data
                    @inject IDbContextFactory<ApplicationDbContext> DbFactory
                    @{
                        using var context = DbFactory.CreateDbContext();
                        var store = context.store_configurations.FirstOrDefault();
                        string logoSrc = "/images/sata-logo.png";
                        if (store != null && !string.IsNullOrEmpty(store.LogoPath))
                        {
                            try { logoSrc = "/store-logo/" + System.IO.Path.GetFileName(store.LogoPath); }
                            catch { }
                        }
                    }
                    <div class="top-bar-logo-wrap">
                        <img src="@logoSrc" alt="Logo" class="top-bar-logo" />
                        <span class="top-bar-logo-label">E-Invoice System</span>
                    </div>
                </div>

                <div class="top-bar-center">
                    <span id="liveClock" class="live-clock">Wednesday, July 2, 2025 - 15:55:16</span>
                </div>

                <div class="top-bar-right">
                    @{
                        var userName = Context.Session.GetString("UserName") ?? "User";
                        var userRole = Context.Session.GetString("UserRole") ?? "Staff";
                        var userEmail = Context.Session.GetString("UserEmail") ?? (userName + "@system.com");
                        var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U";
                    }
                    <div class="user-profile-wrapper" style="position: relative;">
                        <div class="user-avatar-initial" id="profileDropdownToggle" style="cursor: pointer;">
                            @initial
                        </div>

                        <div class="profile-dropdown" id="profileDropdown">
                            <div style="padding: 12px; border-bottom: 1px solid var(--border);">
                                <div class="user-name" style="font-size: 1rem; font-weight: 800;">@userName</div>
                                <div class="user-role-label" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">@userRole</div>
                                @{
                                    var displayEmail = Context.Session.GetString("UserEmail");
                                    if (string.IsNullOrEmpty(displayEmail)) {
                                        displayEmail = userName.Contains("@") ? userName : userName + "@system.com";
                                    }
                                }
                                @if (displayEmail != userName)
                                {
                                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; word-break: break-all;">@displayEmail</div>
                                }
                            </div>

                            <div class="dropdown-divider"></div>
                            
                            <form asp-page="/Account/Logout" asp-area="" method="post" style="padding: 0; margin: 0;">
                                <button type="submit" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 12px; border: none; background: transparent; color: #ef4444; font-weight: 700; font-size: 0.85rem; cursor: pointer; text-align: left;">
                                    <i class="ph-sign-out"></i>
                                    Logout
                                </button>
                            </form>
                        </div>
                    </div>
                </header>

            <main class="sale-content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="toast-container"></div>

    <script>
        function updateClock() {
            const now = new Date();
            const isSmall = window.innerWidth < 480;
            const options = isSmall ? { 
                month: 'short', 
                day: 'numeric',
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit',
                hour12: false 
            } : { 
                weekday: 'long', 
                month: 'long', 
                day: 'numeric',
                year: 'numeric',
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit',
                hour12: false 
            };
            const clockEl = document.getElementById('liveClock');
            if (clockEl) {
                let text = now.toLocaleString('en-US', options);
                if (!isSmall) text = text.replace(',', ' -');
                clockEl.innerText = text;
            }
        }
        setInterval(updateClock, 1000);
        updateClock();

        function showToast(title, message, type) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            const isError = type === 'error';
            const iconClass = isError ? 'ph-x-circle' : 'ph-check-circle';
            const iconColor = isError ? '#ef4444' : 'var(--primary)';
            toast.innerHTML = `
                <i class="${iconClass}" style="color:${iconColor}; font-size:1.5rem;"></i>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 0.85rem;">${title}</div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">${message}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, type === 'error' ? 5000 : 3000);
        }

        const successMessage = '@TempData["Success"]';
        if (successMessage) showToast('Success', successMessage);

        // Profile Dropdown (matching dashboard implementation)
        const profileToggle = document.getElementById('profileDropdownToggle');
        const profileDropdown = document.getElementById('profileDropdown');

        if (profileToggle && profileDropdown) {
            profileToggle.addEventListener('click', (e) => {
                e.stopPropagation();
                profileDropdown.classList.toggle('show');
            });

            document.addEventListener('click', () => {
                profileDropdown.classList.remove('show');
            });

            profileDropdown.addEventListener('click', (e) => {
                e.stopPropagation();
            });
        }
    </script>
    <script src="_framework/blazor.server.js"></script>
    <script src="~/js/app-main.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
