<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <title>@ViewData["Title"] - Sale Terminal</title>
    
    <!-- Local Fonts: Inter -->
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    
    <!-- Phosphor Icons -->
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sale.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/invoice.css" asp-append-version="true" />
    
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    
    <style>
        :root {
            --primary: #BC1823;
            --primary-light: rgba(188, 24, 35, 0.1);
            --primary-dark: #9c141d;
            --primary-glow: rgba(188, 24, 35, 0.2);
            --bg-app: #f8fafc;
            --sidebar-bg: #ffffff;
            --surface: #ffffff;
            --surface-hover: #f1f5f9;
            --border: #94a3b8;
            --text-main: #000000;
            --text-muted: #000000;
            --nav-text: #000000;
            --nav-icon: #64748b;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-app);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow: hidden;
            height: 100vh;
        }

        .sale-layout-container {
            display: flex;
            height: 100vh;
            width: 100vw;
            background: var(--bg-app);
            overflow: hidden;
        }


        /* Actual Dashboard Sidebar Styling - Fixed Width match */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 2.5rem 1.5rem;
            display: flex;
            justify-content: center; /* Center logo */
            align-items: center;
        }

        .sidebar-logo {
            height: 80px; /* Increased from 64px */
            width: auto;
        }

        .sidebar-nav {
            flex: 1;
            padding: 0 1.25rem;
            margin-top: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 1.25rem;
            padding: 0.85rem 1.25rem;
            color: var(--nav-text);
            text-decoration: none;
            border-radius: 12px;
            margin-bottom: 0.5rem;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }

        .nav-icon {
            font-size: 1.4rem;
            color: var(--nav-icon);
        }

        .nav-item:hover {
            background-color: #f1f5f9;
            color: var(--primary);
        }

        .sale-main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--bg-app);
        }


        /* Top Bar - Sleeker match to SupaPOS */
        .top-bar {
            height: 60px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            flex-shrink: 0;
            position: relative;
            z-index: 1100;
        }

        .top-bar-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .top-bar-logo {
            height: 48px;
            width: auto;
            transition: height 0.2s;
        }

        @@media (max-width: 768px) {
            .top-bar-logo {
                height: 36px;
            }
        }

        .welcome-msg {
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--text-main);
        }

        .top-bar-right {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .live-clock {
            font-weight: 700;
            color: var(--text-main);
            font-size: 0.95rem;
        }

        .top-bar-center {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        .user-profile-container {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 4px 12px;
            border-radius: 12px;
            background: var(--bg-light);
            border: 1px solid var(--border);
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
        }

        .user-profile-container:hover {
            border-color: var(--primary);
            background: var(--card-bg);
        }

        .user-avatar-initial {
            width: 40px;
            height: 40px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.1rem;
            flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .user-info {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .user-name {
            font-weight: 700;
            font-size: 0.875rem;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role-label {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Profile Dropdown */
        .profile-dropdown {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            width: 240px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            display: none;
            z-index: 2000;
            animation: slideDown 0.3s ease;
        }

        .profile-dropdown.show {
            display: block;
        }

        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .dropdown-email {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 12px;
            word-break: break-all;
        }

        .dropdown-divider {
            height: 1px;
            background: #f1f5f9;
            margin: 12px 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            padding: 10px;
            border: none;
            background: #fef2f2;
            color: #ef4444;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-logout:hover {
            background: #fee2e2;
        }

        .sale-content-body {
            flex: 1;
            overflow: hidden;
        }

        /* CONSOLIDATED MOBILE OVERRIDES */
        @@media (max-width: 1024px) {
            body {
                overflow-y: auto !important;
                height: auto !important;
            }

            .sale-layout-container {
                display: block;
                height: auto;
                overflow: visible;
                width: 100%;
            }

            .sidebar {
                display: none;
            }

            .sale-main-wrapper {
                height: auto;
                overflow: visible;
                display: block;
            }

            .top-bar {
                height: auto;
                min-height: 60px;
                padding: 12px 20px;
                flex-wrap: wrap;
                gap: 12px;
                justify-content: space-between;
                align-items: center;
            }

            .top-bar-left {
                width: auto;
                order: 1;
            }

            .top-bar-right {
                width: auto;
                order: 2;
            }

            .top-bar-center {
                position: relative;
                left: 0;
                transform: none;
                width: 100%;
                order: 3;
                text-align: left;
                padding: 8px 0;
                border-top: 1px solid var(--border);
            }

            .sale-content-body {
                height: auto;
                overflow: visible;
            }
        }

        @@media (max-width: 480px) {
            .top-bar {
                padding: 8px 12px;
                min-height: 50px;
            }
            .welcome-msg {
                display: none; /* Hide on very small screens to save space */
            }
            .top-bar-left {
                gap: 8px !important;
            }
            .user-avatar-initial {
                width: 32px;
                height: 32px;
                font-size: 0.85rem;
            }
            .top-bar-center {
                padding: 4px 0;
            }
            .live-clock {
                font-size: 0.8rem;
            }
        }

        #toast-container {
            position: fixed;
            top: 24px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .toast {
            background: white;
            border: 1px solid var(--border);
            padding: 16px 24px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            transform: translateY(-100px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .toast.show {
            transform: translateY(60px);
        }
    </style>
</head>
<body>
    <div class="sale-layout-container">
        <!-- Main Content Area (Now Full Width) -->
        <div class="sale-main-wrapper">
            <header class="top-bar">

                <div class="top-bar-left">
                    @using Microsoft.EntityFrameworkCore
                    @using E_Invoice_system.Data
                    @inject IDbContextFactory<ApplicationDbContext> DbFactory
                    @{
                        using var context = DbFactory.CreateDbContext();
                        var store = context.store_configurations.FirstOrDefault();
                        string logoSrc = "/images/sata-logo.png";
                        if (store != null && !string.IsNullOrEmpty(store.LogoPath))
                        {
                            try { logoSrc = "/store-logo/" + System.IO.Path.GetFileName(store.LogoPath); }
                            catch { }
                        }
                    }
                    <div class="top-bar-logo-wrap">
                        <img src="@logoSrc" alt="Logo" class="top-bar-logo" />
                        <span class="top-bar-logo-label">E-Invoice System</span>
                    </div>
                </div>

                <div class="top-bar-center">
                    <span id="liveClock" class="live-clock">Wednesday, July 2, 2025 - 15:55:16</span>
                </div>

                <div class="top-bar-right">
                    @{
                        var userName = Context.Session.GetString("UserName") ?? "User";
                        var userRole = Context.Session.GetString("UserRole") ?? "Staff";
                        var userEmail = Context.Session.GetString("UserEmail") ?? (userName + "@system.com");
                        var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpper() : "U";
                    }
                    <div class="user-profile-wrapper" style="position: relative;">
                        <div class="user-avatar-initial" id="profileDropdownToggle" style="cursor: pointer;">
                            @initial
                        </div>

                        <div class="profile-dropdown" id="profileDropdown">
                            <div style="padding: 12px; border-bottom: 1px solid var(--border);">
                                <div class="user-name" style="font-size: 1rem; font-weight: 800;">@userName</div>
                                <div class="user-role-label" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">@userRole</div>
                                @{
                                    var displayEmail = Context.Session.GetString("UserEmail");
                                    if (string.IsNullOrEmpty(displayEmail)) {
                                        displayEmail = userName.Contains("@") ? userName : userName + "@system.com";
                                    }
                                }
                                @if (displayEmail != userName)
                                {
                                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; word-break: break-all;">@displayEmail</div>
                                }
                            </div>

                            <div class="dropdown-divider"></div>
                            
                            <form asp-page="/Account/Logout" asp-area="" method="post" style="padding: 0; margin: 0;">
                                <button type="submit" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 12px; border: none; background: transparent; color: #ef4444; font-weight: 700; font-size: 0.85rem; cursor: pointer; text-align: left;">
                                    <i class="ph-sign-out"></i>
                                    Logout
                                </button>
                            </form>
                        </div>
                    </div>
                </header>

            <main class="sale-content-body">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="toast-container"></div>

    <script>
        function updateClock() {
            const now = new Date();
            const isSmall = window.innerWidth < 480;
            const options = isSmall ? { 
                month: 'short', 
                day: 'numeric',
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit',
                hour12: false 
            } : { 
                weekday: 'long', 
                month: 'long', 
                day: 'numeric',
                year: 'numeric',
                hour: '2-digit', 
                minute: '2-digit', 
                second: '2-digit',
                hour12: false 
            };
            const clockEl = document.getElementById('liveClock');
            if (clockEl) {
                let text = now.toLocaleString('en-US', options);
                if (!isSmall) text = text.replace(',', ' -');
                clockEl.innerText = text;
            }
        }
        setInterval(updateClock, 1000);
        updateClock();

        function showToast(title, message, type) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            const isError = type === 'error';
            const iconClass = isError ? 'ph-x-circle' : 'ph-check-circle';
            const iconColor = isError ? '#ef4444' : 'var(--primary)';
            toast.innerHTML = `
                <i class="${iconClass}" style="color:${iconColor}; font-size:1.5rem;"></i>
                <div style="flex: 1;">
                    <div style="font-weight: 700; font-size: 0.85rem;">${title}</div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">${message}</div>
                </div>
            `;
            container.appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 10);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, type === 'error' ? 5000 : 3000);
        }

        const successMessage = '@TempData["Success"]';
        if (successMessage) showToast('Success', successMessage);

        // Profile Dropdown (matching dashboard implementation)
        const profileToggle = document.getElementById('profileDropdownToggle');
        const profileDropdown = document.getElementById('profileDropdown');

        if (profileToggle && profileDropdown) {
            profileToggle.addEventListener('click', (e) => {
                e.stopPropagation();
                profileDropdown.classList.toggle('show');
            });

            document.addEventListener('click', () => {
                profileDropdown.classList.remove('show');
            });

            profileDropdown.addEventListener('click', (e) => {
                e.stopPropagation();
            });
        }
    </script>
    <script src="_framework/blazor.server.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
