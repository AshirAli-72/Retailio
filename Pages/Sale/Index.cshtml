@page
@model E_Invoice_system.Pages.Sale.IndexModel
@{
    ViewData["Title"] = "Sales";
}

@section Styles {
    <link rel="stylesheet" href="~/css/sale/index.css" asp-append-version="true" />
}


<div class="card card-no-padding">
    <div class="page-header">
        <div class="page-header-left">
            <i class="ph-shopping-cart page-header-icon"></i>
            <div style="display: flex; flex-direction: column; gap: 0.25rem;">
                <h2 class="page-header-title">Transaction Ledger</h2>
                <p class="text-muted font-sm" style="margin: 0;">A complete record of all sales transactions.</p>
            </div>
        </div>
        <a href="/Sale/Create" class="btn-primary">
            <i class="ph-plus-circle"></i> New Sale
        </a>
    </div>


    <!-- Toggle Buttons -->
    <div style="padding: 0 1.5rem 1.5rem 1.5rem;">
        <div class="index-header-row">
            <div class="index-toggle-pill">
                <button id="btnShowSales" type="button" class="toggle-btn @(Model.Tab == "sales" ? "active" : "")" onclick="switchTable('sales')">
                    <i class="ph-shopping-bag"></i> Sales
                </button>
                <button id="btnShowReturns" type="button" class="toggle-btn @(Model.Tab == "returns" ? "active" : "")" onclick="switchTable('returns')">
                    <i class="ph-arrow-counter-clockwise"></i>  Returns
                </button>
                <button id="btnShowCredits" type="button" class="toggle-btn @(Model.Tab == "credits" ? "active" : "")" onclick="switchTable('credits')">
                    <i class="ph-credit-card"></i> Credits
                </button>
            </div>
        </div>
    </div>
    
    <!-- Sales Table -->
    <div class="table-container">
        <div id="salesTableSection" class="table-responsive" style="display: @(Model.Tab == "sales" ? "block" : "none");">
            <div style="padding: 1rem 1.5rem; background: var(--bg-light); border-bottom: 1px solid var(--border);">
                <span class="text-muted font-sm font-bold"><i class="ph-shopping-bag"></i> RECENT SALES</span>
            </div>
            <table class="styled-table" style="min-width: 1000px; margin-bottom: 0;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem;">Invoice No</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Total</th>
                    <th class="text-center">Method</th>
                    <th class="text-center">Status</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Sales.Any())
                {
                    @foreach (var sale in Model.Sales)
                    {
                        <tr>
                            <td style="padding-left: 1.5rem;">
                                <div class="font-bold font-sm font-monospace">@sale.InvNo</div>
                            </td>
                            <td>
                                <div class="font-bold font-sm">@(sale.CustomerName ?? "Walk in")</div>
                            </td>
                            <td>
                                <div class="font-bold font-sm">@sale.Date</div>
                            </td>
                            <td>@sale.qty.ToString("N0")</td>
                            <td class="text-muted">@CurrencyService.GetSymbol()@sale.Price.ToString("N2")</td>
                            <td>
                                <div class="font-bold text-primary">@CurrencyService.GetSymbol()@sale.TotalPrice.ToString("N2")</div>
                            </td>
                            <td class="text-center">
                                <span class="font-medium font-sm">@sale.PaymentMethod</span>
                            </td>
                            <td class="text-center">
                                @{
                                    var statusClass = "status-paid";
                                    var displayStatus = sale.Status ?? "Paid";
                                    if (displayStatus.Equals("Pending", StringComparison.OrdinalIgnoreCase)) {
                                        statusClass = "status-pending";
                                    } else if (displayStatus.Equals("Returned", StringComparison.OrdinalIgnoreCase) || sale.IsReturned) {
                                        statusClass = "status-inactive";
                                        displayStatus = "Returned";
                                    }
                                }
                                <span class="status-badge @statusClass">@displayStatus</span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@sale.id" onsubmit="return confirm('Delete this sale record?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon-sm btn-delete" title="Delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="10" class="empty-state"><p>No sales records found.</p></td></tr>
                }
            </tbody>
        </table>
        @if (Model.Sales.Any())
        {
            <div class="pagination-footer">
                <div class="pagination-info">
                    Showing <span>@((Model.PageNumber - 1) * Model.PageSize + 1)</span> to <span>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</span> of <span>@Model.TotalCount</span> sales
                </div>
                <div class="pagination-controls">
                    @if (Model.PageNumber > 1)
                    {
                        <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber - 1)" asp-route-ReturnPageNumber="@Model.ReturnPageNumber" asp-route-CreditPageNumber="@Model.CreditPageNumber" asp-route-tab="sales" class="btn-pagination">
                            <i class="ph-caret-left"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-left"></i></button>
                    }
                    
                    <button class="btn-pagination active">@Model.PageNumber</button>
                    
                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber + 1)" asp-route-ReturnPageNumber="@Model.ReturnPageNumber" asp-route-CreditPageNumber="@Model.CreditPageNumber" asp-route-tab="sales" class="btn-pagination">
                            <i class="ph-caret-right"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-right"></i></button>
                    }
                </div>
            </div>
        }
        </div>
    </div>

    <!-- Returns Table (Hidden by default) -->
    <div class="table-container">
        <div id="returnsTableSection" class="table-responsive" style="display: @(Model.Tab == "returns" ? "block" : "none");">
            <div style="padding: 1rem 1.5rem; background: var(--bg-light); border-bottom: 1px solid var(--border);">
                <span class="text-danger font-sm font-bold"><i class="ph-arrow-counter-clockwise"></i> RETURNS HISTORY</span>
            </div>
            <table class="styled-table" style="min-width: 1000px; margin-bottom: 0;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem;">Invoice No</th>
                    <th>Item Name</th>
                    <th>Date</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th class="text-center">Payment</th>
                    <th class="text-center">Status</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Returns.Any())
                {
                    @foreach (var ret in Model.Returns)
                    {
                        <tr>
                            <td style="padding-left: 1.5rem;">
                                <div class="font-bold font-sm font-monospace">@ret.InvNo</div>
                            </td>
                            <td>
                                <div class="font-bold text-danger font-sm">@(ret.ItemName ?? "—")</div>
                            </td>
                            <td>
                                <div class="font-bold font-sm">@ret.Date</div>
                            </td>
                            <td>
                                <div class="font-bold">@ret.qty</div>
                            </td>
                            <td>
                                <div class="font-bold text-danger">@CurrencyService.GetSymbol()@Math.Abs(ret.total_price).ToString("N2")</div>
                            </td>
                            <td class="text-center">
                                <span class="font-medium font-sm">@ret.payment_method</span>
                            </td>
                            <td class="text-center">
                                <span class="status-badge status-inactive">Returned</span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <form method="post" asp-page-handler="DeleteReturn" asp-route-id="@ret.Id" onsubmit="return confirm('Delete this return record?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon-sm btn-delete" title="Delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="empty-state"><p>No return records found.</p></td></tr>
                }
            </tbody>
        </table>
        @if (Model.Returns.Any())
        {
            <div class="pagination-footer">
                <div class="pagination-info">
                    Showing <span>@((Model.ReturnPageNumber - 1) * Model.ReturnPageSize + 1)</span> to <span>@(Math.Min(Model.ReturnPageNumber * Model.ReturnPageSize, Model.ReturnTotalCount))</span> of <span>@Model.ReturnTotalCount</span> returns
                </div>
                <div class="pagination-controls">
                    @if (Model.ReturnPageNumber > 1)
                    {
                        <a asp-page="./Index" asp-route-ReturnPageNumber="@(Model.ReturnPageNumber - 1)" asp-route-PageNumber="@Model.PageNumber" asp-route-CreditPageNumber="@Model.CreditPageNumber" asp-route-tab="returns" class="btn-pagination">
                            <i class="ph-caret-left"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-left"></i></button>
                    }
                    
                    <button class="btn-pagination active">@Model.ReturnPageNumber</button>
                    
                    @if (Model.ReturnPageNumber < Model.ReturnTotalPages)
                    {
                        <a asp-page="./Index" asp-route-ReturnPageNumber="@(Model.ReturnPageNumber + 1)" asp-route-PageNumber="@Model.PageNumber" asp-route-CreditPageNumber="@Model.CreditPageNumber" asp-route-tab="returns" class="btn-pagination">
                            <i class="ph-caret-right"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-right"></i></button>
                    }
                </div>
            </div>
        }
        </div>
    </div>

    <!-- Credits Table -->
    <div class="table-container">
        <div id="creditsTableSection" class="table-responsive" style="display: @(Model.Tab == "credits" ? "block" : "none");">
            <div style="padding: 1rem 1.5rem; background: var(--bg-light); border-bottom: 1px solid var(--border);">
                <span class="text-muted font-sm font-bold" style="color: #d97706;"><i class="ph-credit-card"></i> CREDIT SALES (PENDING)</span>
            </div>
            <table class="styled-table" style="min-width: 1100px; margin-bottom: 0;">
            <thead>
                <tr>
                    <th style="padding-left: 1.5rem;">Sale ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Paid</th>
                    <th>Due</th>
                    <th class="text-center">Status</th>
                    <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Credits.Any())
                {
                    @foreach (var credit in Model.Credits)
                    {
                        <tr>
                            <td style="padding-left: 1.5rem;">
                                <div class="font-bold font-sm font-monospace">@credit.SaleId</div>
                            </td>
                            <td>
                                <div class="font-bold font-sm">@credit.CustomerName</div>
                            </td>
                            <td>
                                <div class="font-bold font-sm">@credit.Date</div>
                            </td>
                            <td class="text-muted">@CurrencyService.GetSymbol()@credit.amount.ToString("N2")</td>
                            <td class="text-muted">@CurrencyService.GetSymbol()@credit.paid.ToString("N2")</td>
                            <td>
                                <div class="font-bold text-danger">@CurrencyService.GetSymbol()@credit.due.ToString("N2")</div>
                            </td>
                            <td class="text-center">
                                <span class="status-badge status-pending">@(credit.Status ?? "Pending")</span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <form method="post" asp-page-handler="DeleteCredit" asp-route-id="@credit.id" onsubmit="return confirm('Delete this credit record?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-icon-sm btn-delete" title="Delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="empty-state"><p>No credit records found.</p></td></tr>
                }
            </tbody>
        </table>
        @if (Model.Credits.Any())
        {
            <div class="pagination-footer">
                <div class="pagination-info">
                    Showing <span>@((Model.CreditPageNumber - 1) * Model.CreditPageSize + 1)</span> to <span>@(Math.Min(Model.CreditPageNumber * Model.CreditPageSize, Model.CreditTotalCount))</span> of <span>@Model.CreditTotalCount</span> credits
                </div>
                <div class="pagination-controls">
                    @if (Model.CreditPageNumber > 1)
                    {
                        <a asp-page="./Index" asp-route-CreditPageNumber="@(Model.CreditPageNumber - 1)" asp-route-PageNumber="@Model.PageNumber" asp-route-ReturnPageNumber="@Model.ReturnPageNumber" asp-route-tab="credits" class="btn-pagination">
                            <i class="ph-caret-left"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-left"></i></button>
                    }

                    <button class="btn-pagination active">@Model.CreditPageNumber</button>

                    @if (Model.CreditPageNumber < Model.CreditTotalPages)
                    {
                        <a asp-page="./Index" asp-route-CreditPageNumber="@(Model.CreditPageNumber + 1)" asp-route-PageNumber="@Model.PageNumber" asp-route-ReturnPageNumber="@Model.ReturnPageNumber" asp-route-tab="credits" class="btn-pagination">
                            <i class="ph-caret-right"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-right"></i></button>
                    }
                </div>
            </div>
        }
        </div>
    </div>
</div>

<script>
    function switchTable(type) {
        const salesSection = document.getElementById('salesTableSection');
        const returnsSection = document.getElementById('returnsTableSection');
        const creditsSection = document.getElementById('creditsTableSection');
        const btnSales = document.getElementById('btnShowSales');
        const btnReturns = document.getElementById('btnShowReturns');
        const btnCredits = document.getElementById('btnShowCredits');

        salesSection.style.display = type === 'sales' ? 'block' : 'none';
        returnsSection.style.display = type === 'returns' ? 'block' : 'none';
        creditsSection.style.display = type === 'credits' ? 'block' : 'none';

        btnSales.classList.toggle('active', type === 'sales');
        btnReturns.classList.toggle('active', type === 'returns');
        btnCredits.classList.toggle('active', type === 'credits');
    }
</script>
