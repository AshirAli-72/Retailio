@page
@model E_Invoice_system.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Dashboard Hero / Welcome Section -->
<div class="dashboard-hero">
    <div class="hero-content">
        <h1 class="hero-title">Welcome back, @(HttpContext.Session.GetString("UserName") ?? "Admin")! 👋</h1>
        <p class="hero-subtitle">Here is what's happening with your store today.</p>
    </div>
    <div class="hero-actions">
        <a href="/Sale/Create" class="btn-hero-primary"><i class="ph-shopping-cart-bold"></i> New Sale</a>
        <a href="/Product/Index" class="btn-hero-secondary"><i class="ph-package-bold"></i> Inventory</a>
    </div>
</div>

@if (Model.LowStockCount > 0)
{
    <div class="alert-modern alert-warning slide-in">
        <div class="alert-icon-wrapper">
            <i class="ph-warning-circle-fill"></i>
        </div>
        <div class="alert-text">
            <strong>Action Required:</strong> There are <span>@Model.LowStockCount</span> products running low on stock.
        </div>
        <a asp-page="/Product/Index" class="alert-action">View Products <i class="ph-arrow-right"></i></a>
    </div>
}

<!-- Key Metrics Grid -->
<div class="metrics-grid">
    <div class="metric-card">
        <div class="metric-icon-bg bg-blue">
            <i class="ph-users-three-duotone"></i>
        </div>
        <div class="metric-info">
            <p class="metric-label">Total Customers</p>
            <h3 class="metric-value">@Model.TotalCustomers</h3>
            <div class="metric-trend positive"><i class="ph-trend-up"></i> Active Users</div>
        </div>
    </div>

    <div class="metric-card">
        <div class="metric-icon-bg bg-green">
            <i class="ph-currency-circle-dollar-duotone"></i>
        </div>
        <div class="metric-info">
            <p class="metric-label">Total Revenue</p>
            <h3 class="metric-value">@CurrencyService.GetSymbol()@(Model.TotalSales.ToString("N2"))</h3>
            <div class="metric-trend positive"><i class="ph-trend-up"></i> Total Sales Volume</div>
        </div>
    </div>

    <div class="metric-card">
        <div class="metric-icon-bg bg-orange">
            <i class="ph-package-duotone"></i>
        </div>
        <div class="metric-info">
            <p class="metric-label">Active Products</p>
            <h3 class="metric-value">@Model.TotalProducts</h3>
            <div class="metric-trend neutral"><i class="ph-minus"></i> Current Inventory</div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="dashboard-charts-grid">
    <div class="chart-card span-2">
        <div class="chart-header">
            <div>
                <h3 class="chart-title">Revenue Overview</h3>
                <p class="chart-subtitle">Sales performance over the last 7 days</p>
            </div>
            <div class="chart-action">
                <span class="badge-soft">Weekly</span>
            </div>
        </div>
        <div class="chart-body">
            <canvas id="trendChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-header">
            <div>
                <h3 class="chart-title">Sales vs Returns</h3>
                <p class="chart-subtitle">Transaction ratio</p>
            </div>
        </div>
        <div class="chart-body doughnut-body">
            <canvas id="saleReturnChart"></canvas>
            <div class="doughnut-legend">
                <div class="legend-item">
                    <span class="legend-dot dot-sale"></span>
                    <span class="legend-label">Sales</span>
                    <span class="legend-value">@Model.SaleCount</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot dot-return"></span>
                    <span class="legend-label">Returns</span>
                    <span class="legend-value">@Model.ReturnCount</span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const initCharts = () => {
            if (typeof Chart === 'undefined') {
                setTimeout(initCharts, 100);
                return;
            }

            const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
            const labelColor = currentTheme === 'dark' ? '#94a3b8' : '#64748b';
            const gridColor = currentTheme === 'dark' ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.04)';
            const fontFam = "'Inter', sans-serif";

            Chart.defaults.font.family = fontFam;
            Chart.defaults.color = labelColor;

            // Trend Chart
            const trendChartEl = document.getElementById('trendChart');
            if (trendChartEl) {
                const existingTrend = Chart.getChart(trendChartEl);
                if (existingTrend) existingTrend.destroy();

                const trendCtx = trendChartEl.getContext('2d');
                var gradient = trendCtx.createLinearGradient(0, 0, 0, 350);
                gradient.addColorStop(0, 'rgba(79, 70, 229, 0.4)');
                gradient.addColorStop(1, 'rgba(79, 70, 229, 0.0)');

                new Chart(trendCtx, {
                    type: 'line',
                    data: {
                        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendLabels)),
                        datasets: [{
                            label: 'Sales Trend',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TrendData)),
                            backgroundColor: gradient,
                            borderColor: '#4f46e5',
                            borderWidth: 3,
                            pointBackgroundColor: '#ffffff',
                            pointBorderColor: '#4f46e5',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                titleFont: { size: 13, family: fontFam },
                                bodyFont: { size: 14, weight: 'bold', family: fontFam },
                                padding: 12,
                                cornerRadius: 8,
                                displayColors: false
                            }
                        },
                        scales: {
                            y: { 
                                beginAtZero: true, 
                                grid: { 
                                    color: gridColor,
                                    drawBorder: false 
                                },
                                ticks: { font: { size: 12 } }
                            },
                            x: { 
                                grid: { display: false },
                                ticks: { font: { size: 12 } }
                            }
                        },
                        interaction: { intersect: false, mode: 'index' }
                    }
                });
            }

            // Doughnut Chart
            const saleReturnChartEl = document.getElementById('saleReturnChart');
            if (saleReturnChartEl) {
                const existingSaleReturn = Chart.getChart(saleReturnChartEl);
                if (existingSaleReturn) existingSaleReturn.destroy();

                new Chart(saleReturnChartEl.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Sales', 'Returns'],
                        datasets: [{
                            data: [@Model.SaleCount, @Model.ReturnCount],
                            backgroundColor: ['#10b981', '#ef4444'],
                            hoverOffset: 10,
                            borderWidth: 0,
                            borderRadius: 8,
                            spacing: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '75%',
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)',
                                titleFont: { size: 13 },
                                bodyFont: { size: 14, weight: 'bold' },
                                padding: 12,
                                cornerRadius: 8
                            }
                        },
                        animation: { animateScale: true, animateRotate: true }
                    }
                });
            }
        };

        initCharts();
        window.addEventListener('theme:changed', () => { setTimeout(initCharts, 50); });
    })();
</script>
