@page
@model E_Invoice_system.Pages.Invoice.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Invoices";
}


<div class="management-container">
    <div class="card card-no-padding">
        <div class="page-header">
            <div class="page-header-left">
                <i class="ph-file-text page-header-icon"></i>
                <h2 class="page-header-title">Invoice Management</h2>
            </div>
            <button type="button" onclick="openInvoiceModal()" class="btn-primary">
                <i class="ph-file-plus"></i> Create New Invoice
            </button>
        </div>
        
        <div class="table-container">
            <div class="table-responsive">
                <table class="styled-table" style="min-width: 1100px; margin-bottom: 0;">
                <thead>
                    <tr>
                        <th style="padding-left: 1.5rem; white-space: nowrap;">Invoice #</th>
                        <th style="white-space: nowrap;">Customer Name</th>
                        <th style="white-space: nowrap;">Date</th>
                        <th>Product/Service</th>
                        <th style="white-space: nowrap;">QTY</th>
                        <th style="white-space: nowrap;">Expiry</th>
                        <th>Discount</th>
                        <th>Total</th>
                        <th style="white-space: nowrap;">Method</th>
                        <th>Status</th>
                        <th class="text-right" style="padding-right: 1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Invoices)
                    {
                        <tr>
                            <td class="font-bold" style="padding-left: 1.5rem; white-space: nowrap;">@(item.InvoiceNo ?? item.id.ToString())</td>
                            <td class="font-medium" style="white-space: nowrap;">@item.CustomerName</td>
                            <td style="white-space: nowrap;">@item.Date</td>
                            <td class="font-sm">@item.DisplayName</td>
                            <td class="font-sm">@item.DisplayQty</td>
                            <td class="font-sm text-muted">@item.DisplayExpiry</td>
                            <td class="text-danger font-medium">@CurrencyService.GetSymbol()@(item.Discount.ToString("N2"))</td>
                            <td class="font-bold text-primary">@CurrencyService.GetSymbol()@(item.TotalPrice.ToString("N2"))</td>
                            <td class="font-sm" style="white-space: nowrap;">@item.Payment</td>
                            <td>
                                <span class="status-badge @(item.Status == "Paid" ? "status-active" : (item.Status == "Pending" ? "status-out-of-stock" : "status-inactive"))">
                                    @(item.Status ?? "Draft")
                                </span>
                            </td>
                            <td class="text-right" style="padding-right: 1.5rem;">
                                <div class="actions-container actions-right">
                                    <a href="/Invoice/Details/@item.id" class="btn-icon-sm btn-view" title="View Invoice">
                                        <i class="ph-eye"></i>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.id" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this invoice?')">
                                        <button type="submit" class="btn-icon-sm btn-delete">
                                            <i class="ph-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Invoices.Any())
                    {
                        <tr>
                            <td colspan="11" class="empty-state">
                                <i class="ph-file-text empty-state-icon"></i>
                                <p>No invoices found. Click <strong>Create New Invoice</strong> to start.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Invoices.Any())
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing <b>@((Model.PageNumber - 1) * Model.PageSize + 1)</b> to <b>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))</b> of <b>@Model.TotalCount</b>
                </div>
                <div class="pagination-controls">
                    @if (Model.PageNumber > 1)
                    {
                        <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber - 1)" class="btn-pagination">
                            <i class="ph-caret-left"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-left"></i></button>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        var pageNum = i;
                        @if (i == 1 || i == Model.TotalPages || (i >= Model.PageNumber - 2 && i <= Model.PageNumber + 2))
                        {
                            <a asp-page="./Index" asp-route-PageNumber="@pageNum" class="btn-pagination @(i == Model.PageNumber ? "active" : "")">@i</a>
                        }
                        else if (i == Model.PageNumber - 3 || i == Model.PageNumber + 3)
                        {
                            <span class="pagination-ellipsis">...</span>
                        }
                    }

                    @if (Model.PageNumber < Model.TotalPages)
                    {
                        <a asp-page="./Index" asp-route-PageNumber="@(Model.PageNumber + 1)" class="btn-pagination">
                            <i class="ph-caret-right"></i>
                        </a>
                    }
                    else
                    {
                        <button class="btn-pagination" disabled><i class="ph-caret-right"></i></button>
                    }
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal Overlay for InvoiceEditor -->
<div id="invoiceModalOverlay" class="modal-overlay" style="display: none;">
    <div class="modal-content" style="max-width: 900px; width: 95%;">
        <div class="form-panel-header">
            <div class="form-panel-title">
                <i class="ph-file-plus form-icon-primary"></i>
                Create New Invoice
            </div>
            <button type="button" class="form-panel-close" onclick="closeInvoiceModal()"><i class="ph-x"></i></button>
        </div>
        <div class="form-panel-body" style="padding: 0;">
            <component type="typeof(E_Invoice_system.Components.Invoice.InvoiceEditor)" render-mode="ServerPrerendered" />
        </div>
    </div>
</div>

<script>
    function openInvoiceModal() {
        document.getElementById('invoiceModalOverlay').style.display = 'flex';
        document.body.classList.add('modal-open');
    }
    function closeInvoiceModal() {
        document.getElementById('invoiceModalOverlay').style.display = 'none';
        document.body.classList.remove('modal-open');
    }
</script>
