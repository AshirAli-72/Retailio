@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.PrintModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    Layout = null;
    var billRef = Model.Invoice.invoice_no ?? Model.Invoice.id.ToString();
    var isReturn = Model.Invoice.status?.Contains("Return", StringComparison.OrdinalIgnoreCase) ?? false;
    var symbol = CurrencyService.GetSymbol() ?? "$";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Receipt - @billRef</title>
    <script src="/lib/jsbarcode/JsBarcode.all.min.js"></script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #e2e8f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
            padding: 40px 20px;
            font-family: 'Outfit', sans-serif;
            color: #0f172a;
        }

        .print-controls {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .btn {
            padding: 12px 28px;
            border: none;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .btn-print { background: linear-gradient(135deg, #1e293b, #0f172a); color: white; }
        .btn-print:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        .btn-close { background: linear-gradient(135deg, #ef4444, #dc2626); color: white; }
        .btn-close:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(239,68,68,0.2); }

        /* ── MODERN THERMAL RECEIPT ── */
        .receipt {
            background: #ffffff;
            width: 360px;
            padding: 40px 30px;
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
            font-size: 13px;
            line-height: 1.5;
        }

        .receipt-header {
            text-align: center;
            margin-bottom: 25px;
        }

        .shop-name {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .shop-detail {
            font-size: 12px;
            font-weight: 400;
            color: #64748b;
            margin-bottom: 2px;
        }

        .divider-dashed {
            border: none;
            border-top: 2px dashed #e2e8f0;
            margin: 20px 0;
        }

        .meta-info {
            background: #f8fafc;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid #f1f5f9;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            margin-bottom: 6px;
        }
        .meta-row:last-child { margin-bottom: 0; }
        .meta-row span:first-child { color: #64748b; font-weight: 600; }
        .meta-row span:last-child { font-weight: 700; color: #0f172a; }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 10px 0;
        }

        .items-table thead th {
            font-weight: 700;
            color: #64748b;
            text-align: left;
            padding: 10px 0;
            border-bottom: 2px solid #f1f5f9;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .items-table td {
            padding: 12px 0;
            font-size: 13px;
            font-weight: 600;
            border-bottom: 1px solid #f8fafc;
        }

        .text-right { text-align: right; }
        .text-center { text-align: center; }

        .totals-section {
            margin-top: 15px;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 13px;
            font-weight: 600;
            color: #64748b;
        }

        .total-row.large {
            font-size: 20px;
            font-weight: 800;
            color: #0f172a;
            padding: 15px 0;
            border-top: 2px dashed #e2e8f0;
            border-bottom: 2px dashed #e2e8f0;
            margin: 10px 0;
            align-items: center;
        }

        .footer-section {
            text-align: center;
            margin-top: 30px;
        }

        .thank-you {
            font-size: 16px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .promo-text {
            font-size: 11px;
            color: #64748b;
            font-weight: 400;
        }

        .barcode-container {
            margin-top: 25px;
            text-align: center;
            padding: 15px;
            background: #f8fafc;
            border-radius: 12px;
            border: 1px solid #f1f5f9;
        }

        .barcode-container svg {
            width: 100%;
            max-width: 180px;
            height: auto;
        }

        @@media print {
            body { background: white; padding: 0; }
            .print-controls { display: none; }
            .receipt {
                width: 80mm;
                padding: 5mm;
                margin: 0;
                box-shadow: none;
                border-radius: 0;
            }
            .meta-info, .barcode-container {
                background: transparent;
                border: none;
                padding-left: 0;
                padding-right: 0;
            }
        }
    </style>
</head>
<body>

    <div class="print-controls">
        <button onclick="window.print()" class="btn btn-print">PRINT RECEIPT</button>
        <button onclick="window.close()" class="btn btn-close">CLOSE</button>
    </div>

    <div class="receipt" id="printable-area">
        
        <!-- Header -->
        <div class="receipt-header">
            @if (Model.Store != null && !string.IsNullOrEmpty(Model.Store.LogoPath))
            {
                <img src="/@Model.Store.LogoPath" alt="Logo" style="max-height: 60px; width: auto; margin-bottom: 12px;" />
            }
            <div class="shop-name">@(Model.Store?.ShopName ?? "THE SATA POS")</div>
            <div class="shop-detail">@(Model.Store?.Address ?? "Address")</div>
            <div class="shop-detail">Tel: @(Model.Store?.Phone1 ?? Model.Invoice.seller_contact)</div>
        </div>

        <div class="meta-info">
            <div class="meta-row">
                <span>Date:</span>
                <span>@Model.Invoice.date @DateTime.Now.ToString("HH:mm")</span>
            </div>
            <div class="meta-row">
                <span>Customer:</span>
                <span>@(string.IsNullOrEmpty(Model.Invoice.customer_name) ? "Walk-In" : Model.Invoice.customer_name)</span>
            </div>
            <div class="meta-row">
                <span>Order:</span>
                <span style="color: #0f172a;">#@billRef</span>
            </div>
        </div>

        <!-- Items -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 45%;">Item</th>
                    <th style="width: 15%;" class="text-center">Qty</th>
                    <th style="width: 20%;" class="text-right">Price</th>
                    <th style="width: 20%;" class="text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.IsMultiItem)
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item["name"]</td>
                            <td class="text-center">@item["qty"]</td>
                            <td class="text-right">@(((decimal)item["price"]).ToString("N0"))</td>
                            <td class="text-right">@(((decimal)item["total"]).ToString("N0"))</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td>@Model.Invoice.prod_name_service</td>
                        <td class="text-center">@Model.Invoice.qty_unit_type</td>
                        <td class="text-right">@Model.Invoice.price.ToString("N0")</td>
                        <td class="text-right">@((Model.Invoice.price - Model.Invoice.discount).ToString("N0"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="divider-dashed"></div>

        <!-- Totals -->
        <div class="totals-section">
            <div class="total-row">
                <span>Subtotal</span>
                <span>@symbol@Model.Subtotal.ToString("N0")</span>
            </div>
            @if (Model.Invoice.discount > 0)
            {
                <div class="total-row">
                    <span>Discount</span>
                    <span style="color: #ef4444;">-@symbol@Model.Invoice.discount.ToString("N0")</span>
                </div>
            }
            
            <div class="total-row large">
                <span>Total</span>
                <span>@symbol@Model.Invoice.total_price.ToString("N0")</span>
            </div>

            <div class="total-row">
                <span>Payment Method</span>
                <span class="text-right">@(Model.Invoice.payment == "Card" ? "Credit Card" : (Model.Invoice.payment ?? "Cash"))</span>
            </div>
        </div>

        <div class="footer-section">
            <div class="thank-you">Thank You!</div>
            <div class="promo-text">Please keep this receipt for your records.</div>
        </div>

        <div class="barcode-container">
            <svg id="receipt-barcode"></svg>
            <div style="font-size: 10px; font-weight: 700; color: #64748b; margin-top: 8px; letter-spacing: 1px;">@billRef</div>
        </div>
    </div>

    <script>
        JsBarcode("#receipt-barcode", "@billRef", {
            format: "CODE128",
            width: 1.5,
            height: 40,
            displayValue: false,
            margin: 0,
            lineColor: "#0f172a"
        });
    </script>
</body>
</html>
