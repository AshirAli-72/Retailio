@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.PrintModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice - @(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</title>
    <link rel="stylesheet" href="/lib/inter-font/inter.css" />
    <link rel="stylesheet" href="/css/Invoice/invoice.css">
    
</head>
<body>
    <div class="print-controls no-print">
        <button onclick="window.print()" class="btn btn-print">Print Invoice</button>
        <button onclick="window.close()" class="btn btn-close">Close Tab</button>
    </div>

    <div id="invoice-to-print" class="invoice-paper">
        <div class="receipt-header-v4">
            <h1 class="receipt-shop-name-v4">@Model.Invoice.seller_name</h1>
            <p class="receipt-address-v4">@Model.Invoice.seller_address</p>
            <p class="receipt-phone-v4">@Model.Invoice.seller_contact</p>
        </div>

        <div class="receipt-meta-v4">
            <div class="meta-row-v4">Cashier: @(Model.Invoice.user_id?.ToString() ?? "nill")</div>
            <div class="meta-row-v4">Customer: @Model.Invoice.customer_name</div>
        </div>

        <hr class="receipt-hr-v4" />

        <table class="receipt-table-v4">
            <thead>
                <tr>
                    <th style="width: 40%;">PRODUCT</th>
                    <th class="col-center" style="width: 20%;">QTY</th>
                    <th class="col-center" style="width: 20%;">PRICE</th>
                    <th class="col-right" style="width: 20%;">AMOUNT</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.IsMultiItem)
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item["name"]</td>
                            <td class="col-center">@item["qty"]</td>
                            <td class="col-center">@(((decimal)item["price"]).ToString("N0"))</td>
                            <td class="col-right">@(((decimal)item["total"]).ToString("N0"))</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td>@Model.Invoice.prod_name_service</td>
                        <td class="col-center">@Model.Invoice.qty_unit_type</td>
                        <td class="col-center">@Model.Invoice.price.ToString("N0")</td>
                        <td class="col-right">@((Model.Invoice.price - Model.Invoice.discount).ToString("N0"))</td>
                    </tr>
                }
            </tbody>
        </table>

        <hr class="receipt-hr-v4" />

        <div class="receipt-totals-v4">
            <div class="total-row-v4">
                <span class="total-label-v4">SUB TOTAL</span>
                <span class="total-val-v4">@CurrencyService.GetSymbol()@Model.Subtotal.ToString("N0")</span>
            </div>
            <div class="total-row-v4">
                <span class="total-label-v4">TOTAL</span>
                <span class="total-val-v4">@CurrencyService.GetSymbol()@Model.Invoice.total_price.ToString("N0")</span>
            </div>
            <div class="total-row-v4">
                <span class="total-label-v4">AMOUNT DUE</span>
                <span class="total-val-v4">@CurrencyService.GetSymbol()@Model.Invoice.total_price.ToString("N0")</span>
            </div>
            <div class="total-row-v4">
                <span class="total-label-v4">DEBIT TEND</span>
                <span class="total-val-v4">@CurrencyService.GetSymbol()@Model.Invoice.total_price.ToString("N0")</span>
            </div>
        </div>

        <div class="pay-type-v4">
            <span>PAY TYPE</span>
            <span>@(Model.Invoice.payment == "Card" ? "Credit Card" : Model.Invoice.payment)</span>
        </div>

        <hr class="receipt-hr-v4" />

        <h2 class="thank-you-v4">THANK YOU!</h2>

        <hr class="receipt-hr-v4" />

        <p class="promo-text-v4">*** Refer a Friend To Smoke Drop & Get 5% off. ***</p>

        <hr class="receipt-hr-v4" />

        <p class="copyright-v4">Copyrights 2023, Powered by The SATA POS</p>

        <div class="receipt-footer-v4">
            <div class="footer-meta-v4">
                <div class="footer-item-v4">ORDER: @(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())</div>
                <div class="footer-item-v4">@Model.Invoice.date</div>
            </div>
            <div class="barcode-container-v4">
                <img src="https://barcodeapi.org/api/code128/@(Model.Invoice.invoice_no ?? Model.Invoice.id.ToString())" style="height: 60px; width: auto;" />
            </div>
        </div>
    </div>
</body>
</html>
