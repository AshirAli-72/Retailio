@page "{id:int}"
@model E_Invoice_system.Pages.Invoice.DetailsModel
@inject E_Invoice_system.Services.CurrencyService CurrencyService
@{
    ViewData["Title"] = "Invoice #" + (Model.Invoice.invoice_no ?? Model.Invoice.id.ToString());
    bool isAjax = Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    if (isAjax) { Layout = null; }
    
    var billRef = Model.Invoice.invoice_no ?? Model.Invoice.id.ToString();
    var symbol = CurrencyService.GetSymbol() ?? "$";

    // Dynamic Logo Logic
    string logoUrl = "/favicon.png";
    if (Model.Store != null && !string.IsNullOrEmpty(Model.Store.LogoPath))
    {
        logoUrl = $"/store-logo/{System.IO.Path.GetFileName(Model.Store.LogoPath)}";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/css/invoice/details.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
</head>
<body>
    <div class="invoice-page-wrapper">
        <div class="actions-bar no-print">
            <a href="/Invoice/Index" class="btn-back">
                <i class="ph-arrow-left"></i> Back to Hub
            </a>
            <button onclick="window.print()" class="btn-print">
                <i class="ph-printer"></i> Print Official Invoice
            </button>
        </div>

        <div class="invoice-container">
            <!-- Top Decoration -->
            <div class="top-design">
                <h1>Invoice</h1>
            </div>

            <!-- Header -->
            <div class="header">
                <div class="logo-section">
                    @if (!string.IsNullOrEmpty(Model.Store?.LogoPath))
                    {
                        <img src="@logoUrl" alt="Logo" />
                    }
                    else
                    {
                        <h2 class="brand-name">SATA</h2>
                        <div class="tagline">TECHNOLOGIES</div>
                    }
                    <div style="font-size: 13px; font-weight: 700; color: var(--primary-red); margin-top: 5px; letter-spacing: 1px;">Innovating the Future</div>
                </div>

                <div class="meta-section">
                    <div class="meta-item">
                        <div class="meta-icon"><i class="ph-file-text-bold"></i></div>
                        <div class="meta-label">Invoice No.</div>
                        <div class="meta-value">: @billRef</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-icon"><i class="ph-calendar-bold"></i></div>
                        <div class="meta-label">Invoice Date</div>
                        <div class="meta-value">: @Model.Invoice.date</div>
                    </div>
                </div>
            </div>

            <!-- Billing -->
            <div class="billing-section">
                <div class="bill-card">
                    <div class="bill-header">Bill From</div>
                    <div class="bill-row">
                        <i class="ph-buildings-bold"></i>
                        <span class="b-label">Name of Company</span>
                        <span class="b-value">: @(Model.Store?.ShopName ?? "SATA Technologies")</span>
                    </div>
                    <div class="bill-row">
                        <i class="ph-phone-bold"></i>
                        <span class="b-label">Contact</span>
                        <span class="b-value">: @(Model.Store?.Phone1 ?? "+92 345 6781267")</span>
                    </div>
                    <div class="bill-row">
                        <i class="ph-map-pin-bold"></i>
                        <span class="b-label">Address</span>
                        <span class="b-value">: @(Model.Store?.Address ?? "Gilgit, Pakistan")</span>
                    </div>
                </div>

                <div class="bill-card">
                    <div class="bill-header">Bill To</div>
                    <div class="bill-row">
                        <i class="ph-user-bold"></i>
                        <span class="b-label">Name of Customer</span>
                        <span class="b-value">: @(string.IsNullOrEmpty(Model.Invoice.customer_name) ? "Walking Customer" : Model.Invoice.customer_name)</span>
                    </div>
                    <div class="bill-row">
                        <i class="ph-phone-bold"></i>
                        <span class="b-label">Contact</span>
                        <span class="b-value">: @(Model.Invoice.customer_contact ?? "N/A")</span>
                    </div>
                    <div class="bill-row">
                        <i class="ph-map-pin-bold"></i>
                        <span class="b-label">Address</span>
                        <span class="b-value">: @(Model.Invoice.customer_address ?? "N/A")</span>
                    </div>
                </div>
            </div>

            <!-- Table -->
            <div class="items-section">
                <div class="table-wrapper">
                    <table class="invoice-table">
                        <thead>
                            <tr>
                                <th><i class="ph-cube-bold"></i></th>
                                <th style="width: 45%;">Product</th>
                                <th class="text-center">Price</th>
                                <th class="text-center">Qty</th>
                                <th class="text-right">Total Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.IsMultiItem)
                            {
                                foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="text-center">•</td>
                                        <td>@item["name"]</td>
                                        <td class="text-center">@symbol@(((decimal)item["price"]).ToString("N2"))</td>
                                        <td class="text-center">@item["qty"]</td>
                                        <td class="text-right">@symbol@(((decimal)item["total"]).ToString("N2"))</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td class="text-center">•</td>
                                    <td>@Model.Invoice.prod_name_service</td>
                                    <td class="text-center">@symbol@Model.Invoice.price.ToString("N2")</td>
                                    <td class="text-center">@Model.Invoice.qty_unit_type</td>
                                    <td class="text-right">@symbol@((Model.Invoice.price - Model.Invoice.discount).ToString("N2"))</td>
                                </tr>
                            }
                            @* Filler rows to match mockup style *@
                            @for(int i = (Model.IsMultiItem ? Model.Items.Count() : 1); i < 6; i++) {
                                <tr><td>&nbsp;</td><td></td><td></td><td></td><td></td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Bottom -->
            <div class="bottom-section">
                <div class="notes-box">
                    <h4>Notes</h4>
                    <div class="notes-content">
                        Thank you for your business. Please keep this invoice for your records. All returns are subject to store policy. 
                        This is an electronically generated document.
                    </div>
                </div>

                <div class="summary-col">
                    <table class="summary-table">
                        <tr>
                            <td>Subtotal</td>
                            <td>: @symbol@Model.Subtotal.ToString("N2")</td>
                        </tr>
                        <tr>
                            <td>Tax</td>
                            <td>: @symbol 0.00</td>
                        </tr>
                        <tr>
                            <td>Discount</td>
                            <td>: @symbol@Model.Invoice.discount.ToString("N2")</td>
                        </tr>
                    </table>
                    <div class="total-bar">
                        <div class="total-label">Total Price</div>
                        <div class="total-value-wrap">
                            @symbol@Model.Invoice.total_price.ToString("N2")
                            <i class="ph-caret-right-fill" style="font-size: 20px;"></i>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Wave -->
            <div class="footer-design">
                <div class="footer-item">
                    <i class="ph-phone-fill"></i>
                    <span>@(Model.Store?.Phone1 ?? "+92 345 6781267")</span>
                </div>
                <div class="footer-item">
                    <i class="ph-envelope-simple-fill"></i>
                    <span>info@@sata-tech.com</span>
                </div>
                <div class="footer-item">
                    <i class="ph-globe-fill"></i>
                    <span>www.sata-tech.com</span>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
