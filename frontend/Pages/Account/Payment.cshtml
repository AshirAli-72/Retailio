@page
@model Retailio.Pages.Account.PaymentModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment - Retailio</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    <style>
        :root {
            --primary:      #BC1823;
            --primary-dark: #9c141d;
            --primary-glow: rgba(188,24,35,0.15);
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(145deg, #0f172a 0%, #1a1040 55%, #0f172a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .page-card {
            width: 100%;
            max-width: 520px;
            background: rgba(255,255,255,0.035);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.55);
            animation: fadeUp .55s cubic-bezier(.16,1,.3,1) both;
        }
        @@keyframes fadeUp {
            from { opacity:0; transform:translateY(28px) scale(.97); }
            to   { opacity:1; transform:translateY(0)    scale(1);   }
        }

        .page-header {
            background: linear-gradient(135deg, var(--primary-dark) 0%, #6b0a10 100%);
            padding: 1.6rem 2.5rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }
        .brand-icon {
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.18);
            border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: #fff;
        }
        .brand-name { font-size: 1.45rem; font-weight: 800; color: #fff; letter-spacing: -.4px; }

        .form-panel {
            padding: 2rem 2.25rem;
            background: #fff;
        }

        .form-title { font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-bottom: .2rem; }
        .form-sub   { font-size: .85rem; color: #64748b; margin-bottom: 1.25rem; }
        .form-divider { width: 36px; height: 4px; background: var(--primary); border-radius: 2px; margin-top: .6rem; margin-bottom: 1rem; }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid #e2e8f0;
            font-size: .875rem;
        }
        .summary-row:last-of-type { border-bottom: 2px solid #0f172a; }
        .summary-label { color: #64748b; font-weight: 500; }
        .summary-value { color: #0f172a; font-weight: 700; }

        .plan-badge {
            display: inline-block;
            font-size: .7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .5px;
            padding: .2rem .6rem;
            border-radius: 50px;
            margin-left: .4rem;
        }
        .badge-pro  { background:#fef3c7; color:#92400e; }
        .badge-ent  { background:#ede9fe; color:#4c1d95; }

        .btn-pay {
            width: 100%; margin-top: 1.5rem;
            padding: .85rem;
            background: #059669; color: #fff;
            border: none; border-radius: 11px;
            font-size: .975rem; font-weight: 700; font-family: inherit;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: .5rem;
            transition: all .22s;
            box-shadow: 0 6px 18px rgba(5,150,105,.28);
        }
        .btn-pay:hover:not(:disabled) {
            background: #047857;
            transform: translateY(-1px);
            box-shadow: 0 10px 26px rgba(5,150,105,.38);
        }
        .btn-pay:disabled { opacity: .65; cursor: not-allowed; }

        .btn-cancel {
            width: 100%; margin-top: .75rem;
            padding: .7rem;
            background: transparent;
            color: #64748b;
            border: 1.5px solid #e2e8f0;
            border-radius: 11px;
            font-size: .85rem; font-weight: 600; font-family: inherit;
            cursor: pointer;
            transition: all .18s;
        }
        .btn-cancel:hover { border-color: #94a3b8; color: #0f172a; }

        .spinner {
            width: 17px; height: 17px;
            border: 2.5px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .65s linear infinite;
            display: inline-block;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        .alert-success {
            background:#f0fdf4; border:1px solid #bbf7d0;
            border-radius:10px; padding:.65rem .9rem;
            font-size:.82rem; color:#166534;
            display:flex; align-items:center; gap:.45rem;
            margin-bottom:1rem;
        }
    </style>
</head>
<body>

<div class="page-card">
    <div class="page-header">
        <div class="brand-icon"><i class="ph-storefront"></i></div>
        <span class="brand-name">Retailio</span>
    </div>

    <div class="form-panel">
        <div class="form-title">Complete Payment</div>
        <div class="form-sub">Review your order and pay to activate your account</div>
        <div class="form-divider"></div>

        <div class="summary-row">
            <span class="summary-label">Plan</span>
            <span class="summary-value">
                @switch (Model.Plan)
                {
                    case "professional":
                        <text>Professional <span class="plan-badge badge-pro">$49/mo</span></text>
                        break;
                    case "enterprise":
                        <text>Enterprise <span class="plan-badge badge-ent">$99/mo</span></text>
                        break;
                    default:
                        @Model.Plan
                        break;
                }
            </span>
        </div>
        <div class="summary-row">
            <span class="summary-label">Business</span>
            <span class="summary-value">@Model.BusinessName</span>
        </div>
        <div class="summary-row">
            <span class="summary-label">Account</span>
            <span class="summary-value">@Model.Username</span>
        </div>
        <div class="summary-row">
            <span class="summary-label">Email</span>
            <span class="summary-value">@Model.Email</span>
        </div>
        <div class="summary-row">
            <span class="summary-label">Total</span>
            <span class="summary-value" style="font-size: 1.2rem; color: var(--primary);">@Model.PlanPrice</span>
        </div>

        <form method="post">
            <button type="submit" class="btn-pay" id="payBtn">
                <i class="ph-check-circle"></i>
                <span id="payText">Pay @Model.PlanPrice</span>
            </button>
        </form>

        <form method="get" action="/Account/Register">
            <button type="submit" class="btn-cancel">Cancel and go back</button>
        </form>
    </div>
</div>

<script>
    var form = document.querySelector('form[method="post"]');
    var btn = document.getElementById('payBtn');
    if (form && btn) {
        form.addEventListener('submit', function () {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span><span>Processing payment\u2026</span>';
        });
    }
</script>
</body>
</html>
