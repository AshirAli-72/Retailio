@page
@model Retailio.Pages.Account.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Retailio</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="~/lib/inter-font/inter.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/phosphor/icons.css" asp-append-version="true" />
    <style>
        :root {
            --primary:      #BC1823;
            --primary-dark: #9c141d;
            --primary-glow: rgba(188,24,35,0.15);
            --pro-color:    #f59e0b;
            --ent-color:    #8b5cf6;
            --free-color:   #10b981;
        }
        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

        body {
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            background: linear-gradient(145deg, #0f172a 0%, #1a1040 55%, #0f172a 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        /* ════════════════════════════════
           OUTER CARD — the whole page sits inside one big card
        ════════════════════════════════ */
        .page-card {
            width: 100%;
            max-width: 1060px;
            background: rgba(255,255,255,0.035);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 40px 80px rgba(0,0,0,0.55);
            animation: fadeUp .55s cubic-bezier(.16,1,.3,1) both;
        }
        @@keyframes fadeUp {
            from { opacity:0; transform:translateY(28px) scale(.97); }
            to   { opacity:1; transform:translateY(0)    scale(1);   }
        }

        /* ── header bar ── */
        .page-header {
            background: linear-gradient(135deg, var(--primary-dark) 0%, #6b0a10 100%);
            padding: 1.6rem 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.75rem;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 0.7rem;
        }
        .brand-icon {
            width: 40px; height: 40px;
            background: rgba(255,255,255,0.18);
            border-radius: 11px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: #fff;
            backdrop-filter: blur(4px);
        }
        .brand-name { font-size: 1.45rem; font-weight: 800; color: #fff; letter-spacing: -.4px; }
        .header-right { font-size: 0.82rem; color: rgba(255,255,255,.65); }
        .header-right a { color: #fff; font-weight: 600; text-decoration: none; }
        .header-right a:hover { text-decoration: underline; }

        /* ════════════════════════════════
           INNER LAYOUT — 3 plan cards + form side by side
        ════════════════════════════════ */
        .page-body {
            display: grid;
            grid-template-columns: 1fr 1.35fr;
            min-height: 600px;
        }
        @@media (max-width: 820px) {
            .page-body { grid-template-columns: 1fr; }
        }

        /* ── LEFT: plan picker ── */
        .plan-panel {
            padding: 2rem 1.75rem;
            border-right: 1px solid rgba(255,255,255,.07);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        .panel-title {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: rgba(255,255,255,.4);
            margin-bottom: .25rem;
        }

        /* plan card */
        .plan-card {
            background: rgba(255,255,255,.04);
            border: 1.5px solid rgba(255,255,255,.09);
            border-radius: 16px;
            padding: 1.1rem 1.15rem 1rem;
            cursor: pointer;
            transition: all .22s;
            position: relative;
            overflow: hidden;
        }
        .plan-card:hover {
            background: rgba(255,255,255,.08);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,.3);
        }
        .plan-card.active {
            border-color: var(--accent);
            background: rgba(var(--accent-rgb),.1);
            box-shadow: 0 0 0 3px rgba(var(--accent-rgb),.2);
        }
        .plan-card[data-plan="free_trial"]       { --accent:#10b981; --accent-rgb:16,185,129; }
        .plan-card[data-plan="professional"]     { --accent:#f59e0b; --accent-rgb:245,158,11; }
        .plan-card[data-plan="enterprise"]       { --accent:#8b5cf6; --accent-rgb:139,92,246; }

        .popular-ribbon {
            position: absolute;
            top: .55rem; right: .75rem;
            background: var(--pro-color);
            color: #000;
            font-size: .58rem; font-weight: 800;
            text-transform: uppercase; letter-spacing: .5px;
            padding: .15rem .55rem;
            border-radius: 50px;
            z-index: 3;
        }

        .plan-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: .55rem;
            gap: 0.5rem;
        }
        .plan-badge {
            font-size: .65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .5px;
            padding: .18rem .55rem;
            border-radius: 50px;
        }
        .badge-free { background:rgba(16,185,129,.2);  color:#34d399; }
        .badge-pro  { background:rgba(245,158,11,.2);  color:#fbbf24; }
        .badge-ent  { background:rgba(139,92,246,.2);  color:#a78bfa; }

        .plan-price-wrap { text-align: right; flex-shrink: 0; }
        .plan-price { font-size: 1.25rem; font-weight: 800; color:#fff; line-height:1; white-space:nowrap; }
        .plan-price sub { font-size: .7rem; font-weight: 400; color:rgba(255,255,255,.45); vertical-align:baseline; }

        .plan-label { font-size: .95rem; font-weight: 700; color: #fff; margin-bottom: .15rem; }

        .plan-select-btn {
            margin-top: .85rem;
            width: 100%;
            padding: .55rem;
            border-radius: 9px;
            border: none;
            font-size: .8rem; font-weight: 700;
            font-family: inherit;
            cursor: pointer;
            transition: all .18s;
            letter-spacing: .02em;
        }
        .btn-free { background:#10b981; color:#fff; }
        .btn-free:hover { background:#059669; }
        .btn-pro  { background:var(--pro-color); color:#000; }
        .btn-pro:hover  { background:#d97706; }
        .btn-ent  { background:rgba(139,92,246,.85); color:#fff; }
        .btn-ent:hover  { background:#7c3aed; }
        .plan-card.active .plan-select-btn::after { content:' ✓'; }

        /* ── RIGHT: form ── */
        .form-panel {
            padding: 2rem 2.25rem;
            background: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-top {
            margin-bottom: 1.4rem;
        }
        .form-title { font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-bottom: .2rem; }
        .form-sub   { font-size: .85rem; color: #64748b; }
        .form-divider { width: 36px; height: 4px; background: var(--primary); border-radius: 2px; margin-top: .6rem; }

        /* selected plan chip inside form */
        .plan-chip {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .3rem .75rem;
            border-radius: 50px;
            font-size: .75rem;
            font-weight: 700;
            margin-bottom: 1.1rem;
            transition: background .2s, color .2s;
        }
        .chip-free { background:#dcfce7; color:#166534; }
        .chip-pro  { background:#fef3c7; color:#92400e; }
        .chip-ent  { background:#ede9fe; color:#4c1d95; }

        /* alert bars */
        .alert-error {
            background:#fef2f2; border:1px solid #fecaca;
            border-radius:10px; padding:.7rem .9rem;
            font-size:.85rem; color:#dc2626;
            display:flex; align-items:center; gap:.5rem;
            margin-bottom:1rem;
        }
        .alert-info {
            background:#f0fdf4; border:1px solid #bbf7d0;
            border-radius:10px; padding:.65rem .9rem;
            font-size:.82rem; color:#166534;
            display:flex; align-items:center; gap:.45rem;
            margin-bottom:1rem;
        }
        .alert-warn {
            background:#fffbeb; border:1px solid #fde68a;
            border-radius:10px; padding:.65rem .9rem;
            font-size:.82rem; color:#92400e;
            display:flex; align-items:center; gap:.45rem;
            margin-bottom:1rem;
        }

        /* fields */
        .field-row { display:grid; grid-template-columns:1fr 1fr; gap:.9rem 1.25rem; }
        @@media (max-width:520px) { .field-row { grid-template-columns:1fr; } }

        .field-group { display:flex; flex-direction:column; gap:.3rem; margin-bottom:.85rem; }
        .field-group:last-child { margin-bottom:0; }
        .field-label {
            font-size:.76rem; font-weight:600; color:#374151; letter-spacing:.02em;
        }
        .field-wrap { position:relative; }
        .field-icon {
            position:absolute; left:12px; top:50%;
            transform:translateY(-50%);
            font-size:1.05rem; color:#94a3b8;
            pointer-events:none; transition:color .18s;
        }
        .field-input, .field-select {
            width:100%;
            padding:.72rem .95rem .72rem 2.5rem;
            border:1.5px solid #e2e8f0;
            border-radius:10px;
            font-size:.875rem; font-family:inherit;
            color:#0f172a; background:#f8fafc;
            transition:all .18s; outline:none;
            appearance:none;
        }
        .field-input::placeholder { color:#cbd5e1; }
        .field-input:focus, .field-select:focus {
            border-color:var(--primary);
            background:#fff;
            box-shadow:0 0 0 3px var(--primary-glow);
        }
        .field-wrap:focus-within .field-icon { color:var(--primary); }

        /* section label inside form */
        .section-label {
            font-size:.7rem; font-weight:700; text-transform:uppercase;
            letter-spacing:.6px; color:#94a3b8;
            margin-bottom:.65rem; margin-top:.25rem;
        }

        .btn-submit {
            width:100%; margin-top:1.4rem;
            padding:.85rem;
            background:var(--primary); color:#fff;
            border:none; border-radius:11px;
            font-size:.975rem; font-weight:700; font-family:inherit;
            cursor:pointer;
            display:flex; align-items:center; justify-content:center; gap:.5rem;
            transition:all .22s;
            box-shadow:0 6px 18px rgba(188,24,35,.28);
        }
        .btn-submit:hover:not(:disabled) {
            background:var(--primary-dark);
            transform:translateY(-1px);
            box-shadow:0 10px 26px rgba(188,24,35,.38);
        }
        .btn-submit:disabled { opacity:.65; cursor:not-allowed; }

        .spinner {
            width:17px; height:17px;
            border:2.5px solid rgba(255,255,255,.3);
            border-top-color:#fff;
            border-radius:50%;
            animation:spin .65s linear infinite;
            display:inline-block;
        }
        @@keyframes spin { to { transform:rotate(360deg); } }

        .signin-link {
            text-align:center; margin-top:1rem;
            font-size:.82rem; color:#64748b;
        }
        .signin-link a { color:var(--primary); font-weight:600; text-decoration:none; }
        .signin-link a:hover { text-decoration:underline; }
    </style>
</head>
<body>

<div class="page-card">

    <!-- ══ HEADER ══ -->
    <div class="page-header">
        <div class="brand">
            <img src="/savepic/retailio.png" alt="Logo" style="height: 120px; object-fit: contain;" />
        </div>
        <div class="header-right">
            Already have an account? <a href="/Account/Login">Sign in</a>
        </div>
    </div>

    <!-- ══ BODY ══ -->
    <div class="page-body">

        <!-- ── LEFT: Plan Picker ── -->
        <div class="plan-panel">
            <div class="panel-title">Choose your plan</div>

            <!-- Free Trial -->
            <div class="plan-card active" data-plan="free_trial" id="card-free" onclick="selectPlan('free_trial',this)">
                <div class="plan-top">
                    <span class="plan-badge badge-free">Free Trial</span>
                    <div class="plan-price-wrap">
                        <div class="plan-price">$0 <sub>/ 14 days</sub></div>
                    </div>
                </div>
                <div class="plan-label">Free Trial</div>
                <button type="button" class="plan-select-btn btn-free">Start Free Trial</button>
            </div>

            <!-- Professional -->
            <div class="plan-card" data-plan="professional" id="card-professional" onclick="selectPlan('professional',this)">
                
                <div class="plan-top">
                    <span class="plan-badge badge-pro">Professional</span>
                    <div class="plan-price-wrap">
                        <div class="plan-price">$49 <sub>/ mo</sub></div>
                    </div>
                </div>
                <div class="plan-label">Professional</div>
                <button type="button" class="plan-select-btn btn-pro">Get Professional</button>
            </div>

            <!-- Enterprise -->
            <div class="plan-card" data-plan="enterprise" id="card-enterprise" onclick="selectPlan('enterprise',this)">
                <div class="plan-top">
                    <span class="plan-badge badge-ent">Enterprise</span>
                    <div class="plan-price-wrap">
                        <div class="plan-price">$99 <sub>/ mo</sub></div>
                    </div>
                </div>
                <div class="plan-label">Enterprise</div>
                <button type="button" class="plan-select-btn btn-ent">Get Enterprise</button>
            </div>
        </div>

        <!-- ── RIGHT: Register Form ── -->
        <div class="form-panel">
            <div class="form-top">
                <div class="form-title">Create your account</div>
                <div class="form-sub">Fill in your details to get started</div>
                <div class="form-divider"></div>
            </div>

            <!-- Selected plan chip -->
            <div class="plan-chip chip-free" id="planChip">
                <i class="ph-gift"></i>
                <span id="planChipText">Free Trial — 14 days free, no credit card</span>
            </div>

            <!-- Validation errors -->
            @{
                var errors = ViewData.ModelState.Values
                    .SelectMany(v => v.Errors)
                    .Select(e => e.ErrorMessage)
                    .Where(m => !string.IsNullOrEmpty(m))
                    .ToList();
            }
            @if (errors.Any())
            {
                <div class="alert-error">
                    <i class="ph-warning-circle"></i>
                    <span>@string.Join(" ", errors)</span>
                </div>
            }

            <!-- Paid plan notice (hidden by default) -->
            <div class="alert-warn" id="paymentNotice" style="display:none;">
                <i class="ph-credit-card"></i>
                <span>You'll be redirected to complete payment before accessing the system.</span>
            </div>

            <form method="post" id="registerForm">
                <input type="hidden" asp-for="SelectedPlan" id="selectedPlanInput" value="free_trial" />

                <div class="section-label">Account Details</div>
                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Username</label>
                        <div class="field-wrap">
                            <i class="ph-user field-icon"></i>
                            <input asp-for="Username" type="text" class="field-input"
                                   placeholder="johndoe" required />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Email Address</label>
                        <div class="field-wrap">
                            <i class="ph-envelope field-icon"></i>
                            <input asp-for="Email" type="email" class="field-input"
                                   placeholder="you@example.com" required />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Password</label>
                        <div class="field-wrap">
                            <i class="ph-lock field-icon"></i>
                            <input asp-for="Password" type="password" class="field-input"
                                   placeholder="Min. 6 characters" required />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Confirm Password</label>
                        <div class="field-wrap">
                            <i class="ph-lock-key field-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" class="field-input"
                                   placeholder="Repeat password" required />
                        </div>
                    </div>
                </div>
                <div class="field-row" style="margin-top: 0.5rem;">
                    <div class="field-group">
                        <label class="field-label">Contact Number</label>
                        <div class="field-wrap">
                            <i class="ph-phone field-icon"></i>
                            <input asp-for="Contact" type="text" class="field-input"
                                   placeholder="e.g. 0300-1234567" required />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">CNIC</label>
                        <div class="field-wrap">
                            <i class="ph-identification-card field-icon"></i>
                            <input asp-for="Cnic" type="text" class="field-input"
                                   placeholder="e.g. 42101-1234567-1" required />
                        </div>
                    </div>
                </div>

                <div class="section-label" style="margin-top:.5rem;">Business Details</div>
                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Business Name</label>
                        <div class="field-wrap">
                            <i class="ph-storefront field-icon"></i>
                            <input asp-for="BusinessName" type="text" class="field-input"
                                   placeholder="My Retail Store" required />
                        </div>
                    </div>
                    <div class="field-group">
                        <label class="field-label">Business Type</label>
                        <div class="field-wrap">
                            <i class="ph-tag field-icon"></i>
                            <select asp-for="BusinessType" class="field-select" required>
                                <option value="">— Select Type —</option>
                                <option value="Retail Store">Retail Store</option>
                                <option value="Grocery / Supermarket">Grocery / Supermarket</option>
                                <option value="Pharmacy">Pharmacy</option>
                                <option value="Electronics">Electronics</option>
                                <option value="Clothing & Apparel">Clothing &amp; Apparel</option>
                                <option value="Food & Beverage">Food &amp; Beverage</option>
                                <option value="Hardware & Tools">Hardware &amp; Tools</option>
                                <option value="Beauty & Cosmetics">Beauty &amp; Cosmetics</option>
                                <option value="Furniture & Home">Furniture &amp; Home</option>
                                <option value="Wholesale">Wholesale</option>
                                <option value="Service-based">Service-based</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <span id="submitText">Create Account</span>
                    <i class="ph-arrow-right" id="submitIcon"></i>
                </button>
            </form>

            <div class="signin-link">
                Already have an account? <a href="/Account/Login">Sign in here</a>
            </div>
        </div>

    </div><!-- /page-body -->
</div><!-- /page-card -->

<script>
(function () {
    var current = 'free_trial';

    var cfg = {
        free_trial:   { chip: 'chip-free', chipText: 'Free Trial \u2014 14 days free, no credit card', btn: 'Start Free Trial',     paid: false },
        professional: { chip: 'chip-pro',  chipText: 'Professional \u2014 $49/month',                  btn: 'Continue to Payment',  paid: true  },
        enterprise:   { chip: 'chip-ent',  chipText: 'Enterprise \u2014 $99/month',                    btn: 'Continue to Payment',  paid: true  }
    };

    window.selectPlan = function (plan, el) {
        current = plan;
        document.getElementById('selectedPlanInput').value = plan;

        // highlight cards
        document.querySelectorAll('.plan-card').forEach(function (c) { c.classList.remove('active'); });
        el.classList.add('active');

        // update chip
        var c = cfg[plan];
        var chip = document.getElementById('planChip');
        chip.className = 'plan-chip ' + c.chip;
        document.getElementById('planChipText').textContent = c.chipText;

        // payment notice
        document.getElementById('paymentNotice').style.display = c.paid ? 'flex' : 'none';

        // submit button text
        document.getElementById('submitText').textContent = c.btn;
    };

    // form submit spinner
    var form = document.getElementById('registerForm');
    var btn  = document.getElementById('submitBtn');
    if (form && btn) {
        form.addEventListener('submit', function () {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span><span>Processing\u2026</span>';
        });
    }
})();
</script>
</body>
</html>
